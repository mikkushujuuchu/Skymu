<Window x:Class="Skymu.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Skymu"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Title="About" Height="454" Width="501">
    <Window.Background>
        <ImageBrush ImageSource="/Resources/Light/Backgrounds/aboutBackground.png" Stretch="Uniform" /> 
    </Window.Background>
    <StackPanel Orientation="Vertical">
        <Image Source="/Resources/Universal/Branding/skymu-about-logo.png" HorizontalAlignment="Center" Height="111" Margin="0,115,11,0" />
        <TextBlock Text="Take another breath" HorizontalAlignment="Center" FontFamily="Tahoma" FontWeight="Bold" FontSize="16" Margin="0,12,16,0"/>
        <TextBlock Text="Open-source software, licensed under the Skymu License&#x0a;You can find our repository over at GitHub listed under the Skymu name.&#x0a;Skymu is not associated with Skype or Microsoft. However, Skymu contains assets created by Skype Limited and utilized under the doctrine of fair use." LineHeight="16" Width="390" TextWrapping="Wrap" Foreground="#363636" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,23,13,0" FontFamily="Tahoma" FontSize="11" />
        <TextBlock Text="Warning: If you have paid for this software with real money, request a chargeback from your bank. Skymu is free software today, tomorrow, and forevermore, so if you come across a paid listing please send and report it to support@hubaxe.fr. We will handle the situation and take it down." LineHeight="16" Width="390" TextWrapping="Wrap" Foreground="#363636" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,16,13,0" FontFamily="Tahoma" FontSize="11"/>
    </StackPanel>
</Window>