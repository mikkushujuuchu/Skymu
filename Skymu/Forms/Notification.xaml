<Window
    x:Class="Skymu.Forms.Notification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:global="clr-namespace:Skymu"
    xmlns:preferences="clr-namespace:Skymu.Preferences"
    Title="Notification"
    Width="240"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Tahoma"
    FontSize="11"
    MouseEnter="Window_MouseEnter"
    MouseLeave="Window_MouseLeave"
    MouseRightButtonDown="Window_MouseRightButtonDown"
    ShowActivated="False"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Style="{StaticResource Window}"
    Topmost="True"
    WindowStyle="None">
    <Window.Resources>
        
        <converters:AssetLoader x:Key="AssetLoader" />
    </Window.Resources>
    <Grid>
        <global:SliceControl
            x:Name="bubble"
            HorizontalAlignment="Stretch"
            DefaultIndex="0"
            ElementCount="1"
            SliceMode="2"
            Source="{Binding Converter={StaticResource AssetLoader}, Source='Assets/Themeable/Notifications/bubble-orange.png'}" />
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Image
                Grid.Row="0"
                Width="33"
                Height="15"
                Margin="5,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Source="{Binding Converter={StaticResource AssetLoader}, Source='Assets/Universal/Branding/logo-notification.png'}"
                Stretch="Fill" />
            <global:SliceControl
                x:Name="close"
                Grid.Row="0"
                Margin="6,0"
                HorizontalAlignment="Right"
                DefaultIndex="2"
                ElementCount="5"
                HoverIndex="1"
                MouseLeftButtonDown="CloseButton_Click"
                PressedIndex="0"
                SliceMode="0"
                Source="{Binding Converter={StaticResource AssetLoader}, Source='Assets/Universal/Notifications/close.png'}"
                StackDirection="Vertical"
                Visibility="Hidden" />
            <Border Grid.Row="1" Padding="8,7">
                <StackPanel x:Name="MessagesContainer" Orientation="Vertical" />
            </Border>
        </Grid>
    </Grid>
</Window>