<Window
    x:Class="Skymu.Forms.WindowBase"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:local="clr-namespace:Skymu"
    Title="Skype™ - Window"
    Width="518"
    Height="394"
    Background="{StaticResource Card.Background}"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    Style="{StaticResource Window}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <converters:AssetLoader x:Key="AssetLoader" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <local:SliceControl
            x:Name="HeaderImage"
            Grid.RowSpan="2"
            Width="48"
            Margin="11,10,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Panel.ZIndex="10"
            DefaultIndex="0"
            ElementCount="36"
            HoverIndex="-1"
            Interactive="False"
            PressedIndex="-1"
            SliceMode="0"
            Source="{Binding Converter={StaticResource AssetLoader}, Source='Assets/Universal/Dialog/icons.png'}"
            StackDirection="Horizontal" />
        <!--  Top Header Section  -->
        <Grid
            Grid.Row="0"
            Height="45"
            Panel.ZIndex="0">
            <Border
                Name="GradientTop"
                Background="{StaticResource Strip.Background}"
                BorderBrush="{StaticResource Card.Border}"
                BorderThickness="0,0,0,1" />
            <TextBlock
                x:Name="Header"
                Height="23"
                Margin="70,3,0,0"
                FontFamily="Arial"
                FontSize="13"
                FontWeight="Bold"
                Foreground="{StaticResource Text.HighContrast}"
                Text="Caption goes here" />
        </Grid>
        <Frame
            x:Name="PageHost"
            Grid.Row="1"
            Margin="77,23,35,7"
            NavigationUIVisibility="Hidden" />

        <!--  Bottom Button Section  -->
        <Grid Grid.Row="2" Height="44">
            <Border
                Name="GradientBottom"
                Background="{StaticResource Strip.Background}"
                BorderBrush="{StaticResource Card.Border}"
                BorderThickness="0,1,0,0" />
            <Button
                x:Name="ButtonEdgeLeft"
                Height="23"
                MinWidth="73"
                Margin="10,0,0,0"
                Padding="12,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Click="bELClick"
                Content="Back"
                FontFamily="Tahoma"
                FontSize="11"
                IsDefault="False"
                Visibility="Collapsed" />
            <StackPanel
                x:Name="BottomControlsGrid"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    x:Name="ButtonLeft"
                    Height="23"
                    MinWidth="73"
                    Margin="0,0,10,0"
                    Padding="12,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Click="bLClick"
                    Content="{Binding [sF_CONFIRM_OK_BTN], Source={StaticResource Lang}}"
                    FontFamily="Tahoma"
                    FontSize="11"
                    IsDefault="True"
                    Visibility="Visible" />
                <Button
                    x:Name="ButtonMiddle"
                    Height="23"
                    MinWidth="73"
                    Margin="0,0,10,0"
                    Padding="12,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="bMClick"
                    Content="{Binding [sZAPBUTTON_DUMMYMIDDLE], Source={StaticResource Lang}}"
                    FontFamily="Tahoma"
                    FontSize="11"
                    IsDefault="False"
                    Visibility="Collapsed" />
                <Button
                    x:Name="ButtonRight"
                    Height="23"
                    MinWidth="73"
                    Margin="0,0,10,0"
                    Padding="12,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="bRClick"
                    Content="{Binding [sZAPBUTTON_CANCEL], Source={StaticResource Lang}}"
                    FontFamily="Tahoma"
                    FontSize="11" />
            </StackPanel>
        </Grid>

    </Grid>
</Window>