<!-- TODO: Change assets path to Skype 4 -->
<Page
    x:Class="Skymu.Forms.Pages.AddContact"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:global="clr-namespace:Skymu"
    xmlns:local="clr-namespace:Skymu.Forms.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:uc="clr-namespace:Skymu.UserControls"
    mc:Ignorable="d"
    Title="Add a contact"
    FontFamily="Tahoma"
    Style="{StaticResource Page}"
    d:Background="#FFFFFF" >
    <Page.Resources>
        <Style TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <converters:ByteArrayToImageSourceConverter x:Key="ProfilePictureConverter" />
        <converters:NullDependentVisibilityConverter x:Key="NullDependentVisibilityConverter" />
        <converters:SkyLangParseConverter x:Key="SkyLangParseConverter" />
        <converters:StatusToTextConverter x:Key="StatIntToText" />
        <converters:ConnectionStatusConverter x:Key="ConnectionStatusConverter" />
        <DataTemplate x:Key="MoreShitYouCanDo">
            <StackPanel
                Margin="0,0,0,30"
                Orientation="Vertical" >
                <uc:QuickLTB
                    FontFamily="Tahoma"
                    FontSize="11"
                    Key="sAC_MORE_CAPTION" />
                <Separator
                    Margin="0,10,0,8"/>
                <global:SliceControl
                    Source="/Sapphire/Assets/Universal/Icon/plus.png"
                    Text="{Binding Path='[sAC_MORE_ADDPSTN]', Source={StaticResource Lang}}"
                    TextColor="{StaticResource Text.Hyperlink}"
                    TextFont="Tahoma"
                    TextLeftMargin="22"
                    TextSize="11"/>
                <global:SliceControl
                    Margin="0,2,0,0"
                    Source="/Sapphire/Assets/Universal/Icon/add.png"
                    Text="{Binding Path='[sAC_MORE_IMPORT]', Source={StaticResource Lang}}"
                    TextColor="{StaticResource Text.Hyperlink}"
                    TextFont="Tahoma"
                    TextLeftMargin="22"
                    TextSize="11"/>
                <global:SliceControl
                    Margin="0,2,0,0"
                    Source="/Sapphire/Assets/Universal/Icon/megaphone.png"
                    Text="{Binding Path='[sAC_MORE_SHARE]', Source={StaticResource Lang}}"
                    TextColor="{StaticResource Text.Hyperlink}"
                    TextFont="Tahoma"
                    TextLeftMargin="22"
                    TextSize="11"/>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>
    <TabControl
        x:Name="MainTabControl"
        Width="650"
        MinHeight="515"
        HorizontalAlignment="Left"
        VerticalAlignment="Stretch"
        Background="Transparent" 
        BorderThickness="0"
        SelectedIndex="0" 
        d:TabStripPlacement="Right" > <!--  Right is the least distracting  -->
        <TabItem Visibility="Collapsed" d:Visibility="Visible">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid
                    Grid.Row="0"
                    Width="Auto"
                    Height="Auto"
                    Margin="0,10,0,0"
                    Visibility="Visible"
                    HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="346*"/>
                        <ColumnDefinition Width="131*"/>
                        <ColumnDefinition Width="131*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Name="TopCaption"
                        Grid.Row="0"
                        FontFamily="Tahoma"
                        FontSize="11"
                        FontWeight="Bold"
                        Margin="0,0,0,10"
                        Text="{Binding Path='[sADDADDAFRIEND_SCR1_CAPTION]', Source={StaticResource Lang}}"
                        Grid.ColumnSpan="2"/>
                    <uc:QuickLTB
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="0,0,0,18"
                        FontFamily="Tahoma"
                        FontSize="11"
                        Key="sF_ADDFRIEND_FIND_LABEL" />
                    <Grid
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="0,31,0,13"
                        Grid.RowSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="255" />
                            <ColumnDefinition Width="122" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="UserDetailsInput"
                            Grid.Column="0"
                            FontFamily="Tahoma"
                            FontSize="11"
                            Height="20"
                            Text="Sensei Wu"/>
                        <Button
                            x:Name="UserFindBtn"
                            Grid.Column="1"
                            Click="FindFriend"
                            Content="{Binding Path='[sF_ADDFRIEND_FIND_BTN]', Source={StaticResource Lang}}"
                            FontFamily="Tahoma"
                            FontSize="11"
                            Height="23"
                            IsDefault="True"
                            IsEnabled="False"
                            Margin="8,0,0,0"/>
                    </Grid>
                    <TextBlock
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Grid.RowSpan="2"
                        FontFamily="Tahoma"
                        FontSize="11"
                        Margin="0,15,0,26"
                        Text="{Binding Path='[sF_SEARCH_MANDALAY_LB_INTRO]', Source={StaticResource Lang}}"
                        TextWrapping="Wrap"/>
                    <!--  TODO: Progressbar accuracy  -->
                    <ProgressBar
                        x:Name="FindPBar"
                        Grid.Row="3"
                        Width="Auto"
                        Height="10"
                        HorizontalAlignment="Stretch"
                        Visibility="Collapsed"/>
                    <uc:QuickLTB
                        x:Name="SelectContactHint"
                        Grid.Row="3"
                        Margin="0,15,0,26"
                        FontFamily="Tahoma"
                        FontSize="11"
                        Key="sAC_FOUND"
                        Visibility="Collapsed" />

                    <StackPanel
                        x:Name="ErrorField"
                        Grid.Row="4"
                        Grid.ColumnSpan="2"
                        Margin="0,35,0,0"
                        Width="Auto"
                        Height="Auto"
                        Orientation="Vertical"
                        Visibility="Collapsed">
                        <global:SliceControl
                            x:Name="ErrorText"
                            Source="Assets/AddContact/warning.png"
                            Text="{Binding Path='[sF_ADDFRIEND_LABEL4]', Source={StaticResource Lang}}"
                            TextColor="Red"
                            TextFont="Tahoma"
                            TextLeftMargin="22"
                            TextSize="11"
                            TextWeight="Bold"/>
                        <DockPanel Margin="20,0,0,0">
                            <BulletDecorator VerticalAlignment="Center">
                                <BulletDecorator.Bullet>
                                    <Ellipse Width="4" Height="4" Fill="Gray"/>
                                </BulletDecorator.Bullet>
                            </BulletDecorator>
                            <TextBlock
                                Margin="5,0,0,0"
                                VerticalAlignment="Bottom"
                                Text="{Binding Path='[sF_ADDFRIEND_LABEL4_1]', Source={StaticResource Lang}}"
                                TextWrapping="Wrap"/>
                        </DockPanel>
                        <DockPanel Margin="20,0,0,0">
                            <BulletDecorator VerticalAlignment="Center">
                                <BulletDecorator.Bullet>
                                    <Ellipse Width="4" Height="4" Fill="Gray"/>
                                </BulletDecorator.Bullet>
                            </BulletDecorator>
                            <TextBlock
                                Margin="5,0,0,0"
                                VerticalAlignment="Bottom"
                                TextWrapping="Wrap">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} {1}">
                                        <Binding Path="[sF_ADDFRIEND_LABEL4_2]" Source="{StaticResource Lang}"/>
                                        <Binding Path="[sF_ADDFRIEND_LABEL4_3]" Source="{StaticResource Lang}"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DockPanel>
                        <DockPanel Margin="20,0,0,0">
                            <BulletDecorator VerticalAlignment="Center">
                                <BulletDecorator.Bullet>
                                    <Ellipse Width="4" Height="4" Fill="Gray"/>
                                </BulletDecorator.Bullet>
                            </BulletDecorator>
                            <TextBlock
                                Margin="5,0,0,0"
                                VerticalAlignment="Bottom"
                                TextWrapping="Wrap"
                                Text="{Binding Path='[sF_ADDFRIEND_LABEL4_4]', Source={StaticResource Lang}}"/>
                        </DockPanel>
                        <global:SliceControl
                            Margin="0,25,0,0"
                            Source="Assets/AddContact/megaphone.png"
                            Text="{Binding Path='[sAC_INVITE_UNFOUND]', Source={StaticResource Lang}}"
                            TextColor="{StaticResource Text.Hyperlink}"
                            TextLeftMargin="22"
                            TextSize="11"/>
                    </StackPanel>
                    <!--  TOOD: Accuracy  -->
                    <ListView
                        x:Name="UserListView"
                        Grid.Row="5"
                        Grid.ColumnSpan="2"
                        Visibility="Collapsed"
                        SelectionChanged="UserListView_Selected"
                        SelectionMode="Single">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn
                                    Header="{Binding Path='[sF_SEARCH_FIELD_FULLNAME]', Source={StaticResource Lang}}"
                                    DisplayMemberBinding="{Binding DisplayName}"
                                    Width="150" />
                                <GridViewColumn
                                    Header="{Binding Path='[sF_SEARCH_FIELD_USERNAME]', Source={StaticResource Lang}}"
                                    DisplayMemberBinding="{Binding Username}"
                                    Width="100" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
                <ContentPresenter
                    x:Name="BottomField"
                    Grid.Row="1"
                    ContentTemplate="{StaticResource MoreShitYouCanDo}" />
            </Grid>
        </TabItem>
        <TabItem Visibility="Collapsed" d:Visibility="Visible">
            <Grid
                Margin="0,10,0,0"
                Width="650"
                HorizontalAlignment="Left"
                DataContext="{Binding FoundUser, RelativeSource={RelativeSource AncestorType=local:AddContact}}" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <uc:QuickLTB
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Key="sAC_ADD_CONFIRM_CAPTION" >
                    <Binding Path="DisplayName" />
                </uc:QuickLTB>

                <!--  Temp  -->
                <TextBox
                    x:Name="ContactMessage"
                    Grid.Row="1"
                    Width="250"
                    FontFamily="Tahoma"
                    Text="Hello, Skymu user here!" />
                <!--  Details of found contact  -->
                <!--  TODO: Fix this up  -->
                <Border
                    x:Name="FoundContactDetails"
                    Grid.Row="2"
                    Background="#FFF"
                    BorderBrush="{StaticResource Card.Border}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,4,4">
                    <Grid>
                        <Grid
                            Grid.Row="1"
                            Height="120">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!--  Profile picture column  -->
                            <Image
                                x:Name="CPAProfilePic"
                                Grid.Column="0"
                                Margin="4,4,5,9"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Stretch="UniformToFill">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                        <Binding Path="ProfilePicture" />
                                        <Binding />
                                    </MultiBinding>
                                </Image.Source>
                                <Image.Effect>
                                    <DropShadowEffect
                                        BlurRadius="4"
                                        Direction="270"
                                        ShadowDepth="1"
                                        Color="{StaticResource Avatar.Shadow}" />
                                </Image.Effect>
                            </Image>
                            <!--  Information column  -->
                            <StackPanel
                                Grid.Column="1"
                                Margin="12,12"
                                Orientation="Vertical">
                                <!-- Display name -->
                                <TextBlock
                                    Margin="9,0,0,0"
                                    FontFamily="Tahoma"
                                    FontSize="11"
                                    Text="{Binding DisplayName, TargetNullValue='Unnamed'}"
                                    TextTrimming="CharacterEllipsis" />
                                <!--  Text status row ("I'm bored", etc)  -->
                                <StackPanel
                                    Margin="0,0,0,15"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal"
                                    Visibility="{Binding Status, Converter={StaticResource NullDependentVisibilityConverter}}">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="/Skyaeris/Assets/Universal/Chat/mood.png" />
                                    <TextBlock
                                        Margin="9,0,0,0"
                                        FontFamily="Tahoma"
                                        FontSize="11"
                                        Text="{Binding Status, TargetNullValue=''}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <!--  Time row for remote user. TODO: implement this in MiddleMan  -->
                                <StackPanel
                                    x:Name="TimeRow"
                                    Margin="0,0,0,15"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="/Skyaeris/Assets/Universal/Chat/clock.png" />
                                    <TextBlock
                                        Margin="9,0,0,0"
                                        FontFamily="Tahoma"
                                        FontSize="11"
                                        Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat={}{0:h:mm tt}}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <!--  Connection status row (online, offline, away, dnd)  -->
                                <StackPanel
                                    x:Name="StatusRow"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal">
                                    <global:SliceControl
                                        Width="14"
                                        Height="14"
                                        DefaultIndex="{Binding ConnectionStatus, Converter={StaticResource ConnectionStatusConverter}}"
                                        ElementCount="22"
                                        Interactive="False"
                                        SliceMode="0"
                                        Source="/Skyaeris/Assets/Universal/Icon/skype-status-small.png"
                                        StackDirection="Horizontal" />
                                    <TextBlock
                                        Margin="11,0,0,0"
                                        FontFamily="Tahoma"
                                        FontSize="11"
                                        Text="{Binding ConnectionStatus, Converter={StaticResource StatIntToText}}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
        <TabItem Visibility="Collapsed" d:Visibility="Visible">
            <Grid
                Grid.Row="0"
                Width="650"
                Margin="0,10,0,0"
                HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Vertical">
                    <!--  joke explaination  -->
                    <!--  Masuo is a YouTuber with a channel "MasuoTV"  -->
                    <!--  On the very first video, they said "Do MasuoTV exist? MasuoTV exists!!  -->
                    <!--  hikakin_mania is a YTP community that makes YTP of HikakinTV SeikinTV, and sometimes MasuoTV -->
                    <!--  And... one of these YTP put an out of context "It absolutely does not exist/not true clip" after the MasuoTV intro vid  -->
                    <!--  Therefore, MasuoTV does not exist  -->
                    <!--  Rest is perfection DOESNT EXIST!!!!!!!!!'s lyrics taken  -->
                    <TextBlock Text="I don't understand why I expеct MasuoTV" />
                    <TextBlock Text="'Cause isn't it something that doesn't exist?" />
                    <!--  hopefully because the Tox plugin is quite messy, sry!  -->
                    <TextBlock Text="(hopefully the contact has been added" />
                </StackPanel>
                <ContentPresenter
                    Grid.Row="1"
                    ContentTemplate="{StaticResource MoreShitYouCanDo}" />
            </Grid>
        </TabItem>
    </TabControl>
</Page>
