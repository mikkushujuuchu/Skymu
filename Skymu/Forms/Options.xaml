<Window
    x:Class="Skymu.Views.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:classes="clr-namespace:Skymu.Classes"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:global="clr-namespace:Skymu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:preferences="clr-namespace:Skymu.Preferences"
    xmlns:theming="clr-namespace:Skymu.Theming"
    Width="716"
    Height="612"
    HorizontalAlignment="Left"
    VerticalAlignment="Top"
    Background="#d4e2f2"
    DataContext="{StaticResource Lang}"
    FontFamily="Tahoma"
    FontSize="11"
    ResizeMode="CanMinimize"
    Style="{StaticResource Window}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Title>
        <MultiBinding StringFormat="{}{0}™ {1}">
            <Binding Path="[sMAINMENU_SKYPE]" Source="{StaticResource Lang}" />
            <Binding Path="[sF_OPTIONS_CAPTION]" Source="{StaticResource Lang}" />
        </MultiBinding>
    </Window.Title>

    <Window.Resources>
        <converters:BoolInverterConverter x:Key="BoolInverterConverter" />
        <converters:StringToDoubleConverter x:Key="StringToDoubleConverter" />
        <converters:StringToIntegerConverter x:Key="StringToIntegerConverter" />
        <converters:SharedAssetPathGenerator x:Key="SharedAssetPathGenerator" />
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator" />
        <Style x:Key="SidebarHeaderStyle" TargetType="ContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Grid Margin="0,0,0,3">
                            <global:SliceControl
                                HorizontalAlignment="Stretch"
                                DefaultIndex="0"
                                ElementCount="5"
                                HoverIndex="1"
                                PressedIndex="2"
                                Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source=Options/header_background.png}"
                                StackDirection="Vertical" />
                            <TextBlock
                                Margin="39,12,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                FontFamily="Tahoma"
                                FontSize="11"
                                Foreground="{StaticResource Text.MediumContrast}"
                                Text="{TemplateBinding Content}" />
                            <Image
                                Height="24"
                                Margin="10,7,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Source="{TemplateBinding Tag}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderThickness="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="182" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,3,0">
                <ContentControl
                    Padding="6,0"
                    Content="{Binding [sF_OPTIONS_PAGE_GENERAL]}"
                    Style="{StaticResource SidebarHeaderStyle}"
                    Tag="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source=Options/general.png}" />
                <ContentControl
                    Padding="6,0"
                    Content="{Binding [sF_OPTIONS_PAGE_PRIVACY]}"
                    Style="{StaticResource SidebarHeaderStyle}"
                    Tag="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source=Options/privacy.png}" />
                <ContentControl
                    Padding="6,0"
                    Content="{Binding [sF_OPTIONS_PAGE_NOTIFICATIONS]}"
                    Style="{StaticResource SidebarHeaderStyle}"
                    Tag="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source=Options/notifications.png}" />
                <ContentControl
                    Padding="6,0"
                    Content="{Binding [sF_OPTIONS_CALLS]}"
                    Style="{StaticResource SidebarHeaderStyle}"
                    Tag="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source=Options/calls.png}" />
                <ContentControl
                    Padding="6,0"
                    Content="{Binding [sF_OPTIONS_CHATS_SMS]}"
                    Style="{StaticResource SidebarHeaderStyle}"
                    Tag="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source=Options/im_and_sms.png}" />
                <ContentControl
                    Padding="6,0"
                    Content="{Binding [sF_OPTIONS_PAGE_DEBUG]}"
                    Style="{StaticResource SidebarHeaderStyle}"
                    Tag="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source=Options/advanced.png}" />
            </StackPanel>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <global:SliceControl
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        BottomHeight="3"
                        DefaultIndex="3"
                        ElementCount="5"
                        ElementSpan="2"
                        Interactive="False"
                        SliceMode="2"
                        Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source=Options/header_background.png}"
                        StackDirection="Vertical"
                        TopHeight="37" />
                    <StackPanel
                        Margin="10,12,0,6"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Panel.ZIndex="2"
                        Orientation="Horizontal">
                        <TextBlock
                            FontFamily="Tahoma"
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="{StaticResource Text.HighContrast}"
                            Text="Skymu Customization:" />
                        <TextBlock
                            Margin="7,0"
                            FontFamily="Tahoma"
                            FontSize="11"
                            Foreground="{StaticResource Text.HighContrast}"
                            Text="Modify the way Skymu looks, feels, and behaves" />
                    </StackPanel>
                    <TabControl
                        Margin="15,25"
                        Padding="0"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderThickness="0"
                        SelectedIndex="1">
                        <TabItem
                            Background="Transparent"
                            Header="TabItem"
                            Opacity="0">
                            <Border
                                x:Name="OptionCategoryContainer1"
                                BorderBrush="{StaticResource Card.Border}"
                                BorderThickness="1,0,1,1">
                                <ScrollViewer>
                                    <StackPanel Orientation="Vertical">
                                        <Label
                                            Padding="6,0"
                                            Content="Visual style of the window"
                                            FontWeight="Bold" />
                                        <StackPanel Margin="0,5">
                                            <RadioButton
                                                x:Name="RadioSkype"
                                                Margin="0,5"
                                                Padding="6,0"
                                                Checked="RadioSkype_Checked"
                                                Content="Skype"
                                                GroupName="VisualStyle" />
                                            <RadioButton
                                                x:Name="RadioClassic"
                                                Margin="0,5"
                                                Padding="6,0"
                                                Checked="RadioClassic_Checked"
                                                Content="Classic Windows"
                                                GroupName="VisualStyle" />
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </TabItem>
                        <TabItem
                            Background="{x:Null}"
                            Header="TabItem"
                            Opacity="0">
                            <Grid>
                                <ScrollViewer>
                                    <StackPanel Orientation="Vertical">

                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="Branding name" />
                                            <TextBox
                                                x:Name="SC_BrandingNameBox"
                                                Width="250"
                                                FontFamily="Tahoma"
                                                Text="{Binding Path=[BrandingName], Mode=TwoWay, Source={x:Static preferences:Settings.Default}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding [sF_USERINFO_LABEL_LANGUAGE]}" />
                                            <ComboBox
                                                Width="250"
                                                DisplayMemberPath="Key"
                                                ItemsSource="{Binding Languages}"
                                                SelectedValue="{Binding Path=[Language], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}"
                                                SelectedValuePath="Key" />
                                        </StackPanel>
                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <CheckBox
                                                Padding="6,0"
                                                Content="Follow system regional variances (time format, date format, units)"
                                                IsChecked="{Binding Path=[UseSystemCulture], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource Text.MediumContrast}"
                                                Text="(Requires restart)" />
                                        </StackPanel>
                                        <Rectangle
                                            Height="1"
                                            Margin="0,10,10,10"
                                            Fill="{StaticResource Card.Border}" />

                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="User interface" />
                                            <ComboBox
                                                Width="250"
                                                SelectedValue="{Binding Path=[Interface], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}"
                                                SelectedValuePath="Tag">
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Skype 5"
                                                    Tag="Skyaeris" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Skype 6"
                                                    Tag="Pontis" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Skype 7"
                                                    Tag="SeanKype" />
                                            </ComboBox>
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource Text.MediumContrast}"
                                                Text="(Requires restart)" />
                                        </StackPanel>


                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="Window frame" />
                                            <ComboBox Width="250" SelectedIndex="{Binding Path=[WindowFrame], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}">
                                                <ComboBoxItem Padding="6,0" Content="Skype Aero" />
                                                <ComboBoxItem Padding="6,0" Content="Skype Basic" />
                                                <ComboBoxItem Padding="6,0" Content="Use the system window frame" />
                                            </ComboBox>
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource Text.MediumContrast}"
                                                Text="(Requires restart)" />
                                        </StackPanel>

                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="Color theme" />
                                            <ComboBox
                                                Width="250"
                                                DisplayMemberPath="Key"
                                                ItemsSource="{x:Static theming:ThemeManager.ColorThemes}"
                                                SelectedValue="{Binding Path=[ColorTheme], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}"
                                                SelectedValuePath="Key" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource Text.MediumContrast}"
                                                Text="(Requires restart)" />
                                        </StackPanel>

                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="Sound pack" />
                                            <ComboBox
                                                x:Name="ComboSoundPack"
                                                Width="250"
                                                SelectedValue="{Binding Path=[SoundPack], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}"
                                                SelectedValuePath="Tag">
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Standard"
                                                    Tag="Skymu" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Skype 1 and 2"
                                                    Tag="Skype1" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Skype 3 to 7"
                                                    Tag="Skype7" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Skype 8"
                                                    Tag="Skype8" />
                                            </ComboBox>
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource Text.MediumContrast}"
                                                Text="(Requires restart)" />
                                        </StackPanel>


                                        <!-- <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="Application theme" />
                                            <ComboBox
                                                Width="250"
                                                SelectedValue="{Binding Path=[ThemeRoot], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}"
                                                SelectedValuePath="Tag">
                                                <ComboBoxItem Padding="6,0" Content="Light" Tag="Light" />
                                                <ComboBoxItem Padding="6,0" Content="Dark" Tag="Dark" />
                                            </ComboBox>
                                        </StackPanel>-->

                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="Base theme (scrollbar, buttons, etc)" />
                                            <ComboBox
                                                Width="250"
                                                SelectedValue="{Binding Path=[PresFrame], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}"
                                                SelectedValuePath="Tag">
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Windows XP"
                                                    Tag="Luna.NormalColor" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Windows XP (Olive)"
                                                    Tag="Luna.Homestead" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Windows XP (Silver)"
                                                    Tag="Luna.Metallic" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Windows XP Media Center"
                                                    Tag="Royale.NormalColor" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Windows Vista"
                                                    Tag="Aero.NormalColor" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Windows 8"
                                                    Tag="Aero2.NormalColor" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Windows 8 Basic"
                                                    Tag="AeroLite.NormalColor" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="Windows Classic"
                                                    Tag="Classic" />
                                            </ComboBox>
                                        </StackPanel>

                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Use the 'Classic Windows' Skype main color instead of the dynamic colors"
                                            IsChecked="{Binding Path=[FallbackFillColors], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />

                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Use the unreleased 'room-style' call UI from the mid-2012 Skype 5.5 mockups"
                                            IsChecked="{Binding Path=[RoomCallUI], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />

                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Use the call reconnecting sound instead of normal call out sound"
                                            IsChecked="{Binding Path=[CallOutToReconnectSound], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />

                                        <StackPanel Margin="0,5,0,10" Grid.IsSharedSizeScope="True">

                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FontRadioCol" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FontLabelCol" />
                                                </Grid.ColumnDefinitions>

                                                <RadioButton
                                                    x:Name="UseDefaultFontRenderingRadio"
                                                    Grid.Column="0"
                                                    Margin="0,3,0,0"
                                                    VerticalAlignment="Top"
                                                    GroupName="FontRenderingModeGroup"
                                                    IsChecked="{Binding Path=[UseClearType], Mode=TwoWay, Source={x:Static preferences:Settings.Default}, Converter={StaticResource BoolInverterConverter}}" />

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="5,1,10,0"
                                                    VerticalAlignment="Center">
                                                    <TextBlock Text="Use WPF's default grayscale font rendering" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FontRadioCol" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FontLabelCol" />
                                                </Grid.ColumnDefinitions>

                                                <RadioButton
                                                    x:Name="UseClearTypeRadio"
                                                    Grid.Column="0"
                                                    Margin="0,3,0,0"
                                                    VerticalAlignment="Top"
                                                    GroupName="FontRenderingModeGroup"
                                                    IsChecked="{Binding Path=[UseClearType], Mode=TwoWay, Source={x:Static preferences:Settings.Default}, UpdateSourceTrigger=PropertyChanged}" />

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="5,1,10,0"
                                                    VerticalAlignment="Center">
                                                    <TextBlock Text="Use accurate ClearType font rendering " />
                                                </StackPanel>
                                            </Grid>

                                        </StackPanel>

                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Replace all dialog icons with 'Niko' from the game 'Oneshot'"
                                            IsChecked="{Binding Path=[NikoIcons], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />

                                        <Rectangle
                                            Height="1"
                                            Margin="0,10,10,10"
                                            Fill="{StaticResource Card.Border}" />

                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Remember positioning (window size, location, sidebar size)"
                                            IsChecked="{Binding Path=[SaveWindowPlacement], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />



                                        <StackPanel Margin="0,5,0,5" Grid.IsSharedSizeScope="True">
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SidebarRadioCol" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SidebarLabelCol" />
                                                </Grid.ColumnDefinitions>

                                                <RadioButton
                                                    x:Name="StaticSidebarTabsRadio"
                                                    Grid.Column="0"
                                                    Margin="0,3,0,0"
                                                    VerticalAlignment="Top"
                                                    GroupName="SidebarTabSizeModeGroup"
                                                    IsChecked="{Binding Path=[DynamicSidebarTabs], Mode=TwoWay, Source={x:Static preferences:Settings.Default}, Converter={StaticResource BoolInverterConverter}}" />
                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="5,1,10,0"
                                                    VerticalAlignment="Center">
                                                    <TextBlock Text="Static sidebar tabs: do not resize tab width based on selection state" />
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SidebarRadioCol" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SidebarLabelCol" />
                                                </Grid.ColumnDefinitions>

                                                <RadioButton
                                                    x:Name="DynamicSidebarTabsRadio"
                                                    Grid.Column="0"
                                                    Margin="0,3,0,0"
                                                    VerticalAlignment="Top"
                                                    GroupName="SidebarTabSizeModeGroup"
                                                    IsChecked="{Binding Path=[DynamicSidebarTabs], Mode=TwoWay, Source={x:Static preferences:Settings.Default}, UpdateSourceTrigger=PropertyChanged}" />

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="5,1,10,0"
                                                    VerticalAlignment="Center">
                                                    <TextBlock Text="Accurate sidebar tabs: dynamically resize width based on selection state" />
                                                </StackPanel>
                                            </Grid>

                                        </StackPanel>

                                        <Rectangle
                                            Height="1"
                                            Margin="0,10,10,10"
                                            Fill="{StaticResource Card.Border}" />


                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Enable automatic login if credentials are saved"
                                            IsChecked="{Binding Path=[AutoLogin], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />

                                        <CheckBox
                                            x:Name="CredDebugSepCB"
                                            Margin="0,5"
                                            Content="Separate credentials when Skymu is built as debug"
                                            IsChecked="{Binding Path=[SeparateCredentialsForDebug], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}"
                                            Visibility="Collapsed" />



                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="Amount of messages to fetch during initial conversation load" />
                                            <TextBox
                                                Width="40"
                                                FontFamily="Tahoma"
                                                Text="{Binding [MsgLoadCount], Converter={StaticResource StringToIntegerConverter}, Mode=TwoWay, Source={x:Static preferences:Settings.Default}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Start with the window minimized"
                                            IsChecked="{Binding Path=[StartMinimized], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />
                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Run the speed test on each startup (uses 10 MB of bandwidth for no real benefit)"
                                            IsChecked="{Binding Path=[AutoSpeedTest], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />
                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="{Binding [sF_USERENTRY_CB_START_SKYPE]}"
                                            IsChecked="{Binding Path=[StartOnStartup], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />
                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Retain original versions of edited and deleted messages (MessageLogger)"
                                            IsChecked="{Binding Path=[MessageLogger], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />

                                        <Rectangle
                                            Height="1"
                                            Margin="0,10,10,10"
                                            Fill="{StaticResource Card.Border}" />


                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="Amount of Skype Credit (visual only)" />
                                            <TextBox
                                                Width="80"
                                                FontFamily="Tahoma"
                                                Text="{Binding Path=[CredsText], Mode=TwoWay, Source={x:Static preferences:Settings.Default}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="Amount of Skype subscriptions (visual only)" />
                                            <TextBox
                                                Width="40"
                                                FontFamily="Tahoma"
                                                Text="{Binding [CredsSubCount], Converter={StaticResource StringToIntegerConverter}, Mode=TwoWay, Source={x:Static preferences:Settings.Default}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <Rectangle
                                            Height="1"
                                            Margin="0,10,10,10"
                                            Fill="{StaticResource Card.Border}" />


                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Enable notifications"
                                            IsChecked="{Binding Path=[EnableNotifications], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />
                                        <StackPanel Margin="0,5" Orientation="Horizontal">
                                            <TextBlock
                                                Padding="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Text="Display a notification for" />
                                            <ComboBox
                                                Width="250"
                                                SelectedValue="{Binding Path=[NotificationTrigger], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}"
                                                SelectedValuePath="Tag">
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="all recieved messages"
                                                    Tag="{x:Static classes:NotificationTriggerType.ALL}" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="direct messages, replies, and pings"
                                                    Tag="{x:Static classes:NotificationTriggerType.PDM}" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="replies and pings"
                                                    Tag="{x:Static classes:NotificationTriggerType.PING}" />
                                                <ComboBoxItem
                                                    Padding="6,0"
                                                    Content="direct messages"
                                                    Tag="{x:Static classes:NotificationTriggerType.DM}" />
                                            </ComboBox>
                                        </StackPanel>
                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Force active notifications to be blue instead of the accurate orange"
                                            IsChecked="{Binding Path=[BlueNotifications], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />

                                        <Rectangle
                                            Height="1"
                                            Margin="0,10,10,10"
                                            Fill="{StaticResource Card.Border}" />

                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Enable the 'Skype Home' feature (experimental, may use 20-60 MB of additional RAM)"
                                            IsChecked="{Binding Path=[EnableSkypeHome], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />
                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Do not display community ads while using Skype Home"
                                            IsChecked="{Binding Path=[EnableAdBlock], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />


                                        <Rectangle
                                            Height="1"
                                            Margin="0,10,10,10"
                                            Fill="{StaticResource Card.Border}" />


                                        <CheckBox
                                            Margin="0,5"
                                            Padding="6,0"
                                            Content="Anonymize my username and display name in Skymu's connected user statistics"
                                            IsChecked="{Binding Path=[Anonymize], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}" />

                                        <CheckBox
                                            MaxWidth="450"
                                            Margin="0,5"
                                            HorizontalAlignment="Left"
                                            IsChecked="{Binding Path=[DisablePingbacks], Mode=TwoWay, Source={x:Static preferences:Settings.Default}}">
                                            <TextBlock Margin="2,0" TextWrapping="Wrap"><Run Text="Completely block communication with the Skymu server and the updater (warning: not recommended, doing this breaks features in the Skymu client!)" /></TextBlock>
                                        </CheckBox>

                                        <Rectangle
                                            Height="1"
                                            Margin="0,10,10,10"
                                            Fill="{StaticResource Card.Border}" />

                                        <StackPanel Grid.IsSharedSizeScope="True">

                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="RadioCol" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol" />
                                                </Grid.ColumnDefinitions>

                                                <RadioButton
                                                    x:Name="UseSystemCert"
                                                    Grid.Column="0"
                                                    Margin="0,3,0,0"
                                                    VerticalAlignment="Top"
                                                    GroupName="CertSourceGroup"
                                                    IsChecked="{Binding Path=[UseCustomCert], Mode=TwoWay, Source={x:Static preferences:Settings.Default}, Converter={StaticResource BoolInverterConverter}}" />

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="5,1,10,0"
                                                    VerticalAlignment="Center">
                                                    <TextBlock Text="Use default system certificate store" />
                                                </StackPanel>
                                            </Grid>


                                            <Grid Margin="0,10,0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="RadioCol" />
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelCol" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <RadioButton
                                                    x:Name="UseCustomCert"
                                                    Grid.Column="0"
                                                    Margin="0,3,0,0"
                                                    VerticalAlignment="Top"
                                                    GroupName="CertSourceGroup"
                                                    IsChecked="{Binding Path=[UseCustomCert], Mode=TwoWay, Source={x:Static preferences:Settings.Default}, UpdateSourceTrigger=PropertyChanged}" />

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="5,1,10,0"
                                                    VerticalAlignment="Center"
                                                    Orientation="Vertical">
                                                    <TextBlock Text="Use custom certificate store (cacert.pem)" />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="11"
                                                        Foreground="{StaticResource Text.MediumContrast}"
                                                        Text="(Requires restart)" />
                                                </StackPanel>

                                                <TextBox
                                                    x:Name="SC_CertPathBox"
                                                    Grid.Column="2"
                                                    Width="120"
                                                    Margin="0,1,0,0"
                                                    VerticalAlignment="Top"
                                                    FontFamily="Tahoma"
                                                    IsEnabled="{Binding ElementName=UseCustomCert, Path=IsChecked}"
                                                    Text="{Binding Path=[CertPath], Mode=TwoWay, Source={x:Static preferences:Settings.Default}, UpdateSourceTrigger=PropertyChanged}" />

                                                <Button
                                                    Grid.Column="3"
                                                    Margin="5,0,0,0"
                                                    Padding="6,0"
                                                    VerticalAlignment="Top"
                                                    Click="CertBrowseButtonClick"
                                                    Content="Browse"
                                                    IsEnabled="{Binding ElementName=UseCustomCert, Path=IsChecked}" />
                                            </Grid>

                                        </StackPanel>

                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
                <StackPanel
                    Grid.Row="2"
                    Height="23"
                    Margin="0,10,3,3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <Button
                        Height="23"
                        MinWidth="73"
                        Margin="0,0,12,0"
                        Padding="12,0"
                        Click="SaveButtonClick"
                        Content="{Binding [sF_OPTIONS_BUTTON_SAVE]}"
                        FontSize="11" />
                    <Button
                        Height="23"
                        MinWidth="73"
                        Margin="0,0,12,0"
                        Padding="12,0"
                        Click="RestartButtonClick"
                        Content="Save and restart"
                        FontSize="11" />
                    <Button
                        Height="23"
                        MinWidth="73"
                        Margin="0,0,12,0"
                        Padding="12,0"
                        Click="ResetButtonClick"
                        Content="{Binding [sF_OPTIONS_BTN_RESET]}"
                        FontSize="11" />
                    <Button
                        Height="23"
                        MinWidth="73"
                        Padding="12,0"
                        Click="CancelButtonClick"
                        Content="{Binding [sF_OPTIONS_BUTTON_CANCEL]}"
                        FontSize="11" />
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>