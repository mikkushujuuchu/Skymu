<Window
    x:Class="Skymu.Skype6.Main"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:diag="clr-namespace:System.Diagnostics;assembly=WindowsBase"
    xmlns:global="clr-namespace:Skymu"
    xmlns:local="clr-namespace:Skymu.Skype6"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:preferences="clr-namespace:Skymu.Preferences"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:uc="clr-namespace:Skymu.UserControls"
    xmlns:yggdrasil="clr-namespace:Yggdrasil.Models;assembly=Yggdrasil"
    Title="Skymu"
    Width="1448"
    Height="856"
    MinWidth="600"
    MinHeight="450"
    Activated="Window_Activated"
    AllowsTransparency="False"
    Background="{StaticResource Metro.Background}"
    Closing="Main_Closing"
    Deactivated="Window_Deactivated"
    FontFamily="Tahoma"
    FontSize="11"
    ResizeMode="CanResize"
    Style="{StaticResource Window}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="SingleBorderWindow"
    mc:Ignorable="d">
    <Window.Resources>
        <Style x:Key="TextBlockViewerStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Tahoma" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <converters:ByteArrayToImageSourceConverter x:Key="ProfilePictureConverter" />
        <converters:MsgByteArrayToImageConverter x:Key="MsgByteArrayToImageConverter" />
        <converters:SenderToColorConverter x:Key="SenderToColorConverter" />
        <converters:NullDependentVisibilityConverter x:Key="NullDependentVisibilityConverter" />
        <converters:NullDependentMarginConverter x:Key="NullDependentMarginConverter" />
        <converters:NullDependentBoolean x:Key="NullDependentBoolean" />
        <converters:StatusToTextConverter x:Key="StatIntToText" />
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator" />
        <converters:ForwardedMessageStatusConverter x:Key="ForwardedMessageStatusConverter" />
        <converters:HalfValueConverter x:Key="HalfValueConverter" />
        <converters:ReplyBodyConverter x:Key="ReplyBodyConverter" />
        <converters:ConnectionStatusConverter x:Key="ConnectionStatusConverter" />
        <converters:ChannelTypeConverter x:Key="ChannelTypeConverter" />
        <converters:TextStatusConverter x:Key="TextStatusConverter" />
        <converters:MsgIDMultiToVisibilityConverter x:Key="IDToVisibilityConverter" />
        <converters:PreviewVisibilityConverter x:Key="PreviewVisibilityConverter" />
        <converters:CompactConversationTypeConverter x:Key="CompactConversationTypeConverter" />
        <converters:FormatFullTextConverter x:Key="FormatFullTextConverter" ViewerStyle="{StaticResource TextBlockViewerStyle}" />
        <converters:FormatFullActionMessageConverter x:Key="FormatFullActionMessageConverter" ViewerStyle="{StaticResource TextBlockViewerStyle}" />
        <Style x:Key="WindowButtonStyle" TargetType="global:SliceControl">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="-1,0,0,0" />
            <Setter Property="HoverTransition" Value="False" />
            <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor" />
            <Setter Property="SliceMode" Value="0" />
            <Setter Property="ElementCount" Value="4" />
            <Setter Property="StackDirection" Value="Vertical" />
            <Setter Property="DefaultIndex" Value="0" />
            <Setter Property="HoverIndex" Value="2" />
            <Setter Property="PressedIndex" Value="3" />
        </Style>
        <Style x:Key="LongIconStyle" TargetType="Image">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Width" Value="36" />
        </Style>
        <!--  CONTACT ITEM TEMPLATE START  -->
        <!--  shared style for both targeted templates  -->
        <Style x:Key="ContactUsernameStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Tahoma" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ContactStatusStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Tahoma" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text.LowContrast}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <!--  User template  -->
        <DataTemplate DataType="{x:Type yggdrasil:DirectMessage}">
            <Grid Height="32" Margin="2,4,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2" />
                    <RowDefinition Height="14" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Profile picture  -->
                <Grid
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    Margin="2,0,0,0">
                    <Border Background="Transparent">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="2"
                                Direction="270"
                                Opacity="0.50"
                                ShadowDepth="1"
                                Color="{StaticResource Avatar.Shadow}" />
                        </Border.Effect>
                        <Grid>
                            <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                        <Binding Path="ProfilePicture" />
                                        <Binding Source="user" />
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                            <Border BorderBrush="{StaticResource Avatar.Border}" BorderThickness="1" />
                        </Grid>
                    </Border>
                </Grid>
                <global:SliceControl
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="14"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    DefaultIndex="{Binding Partner.ConnectionStatus, Converter={StaticResource ConnectionStatusConverter}}"
                    ElementCount="22"
                    HoverIndex="-1"
                    PressedIndex="-1"
                    SliceMode="0"
                    Source="Assets/Universal/Icon/skype-status-small.png"
                    StackDirection="Horizontal" />
                <!--  Name + status text  -->
                <TextBlock
                    x:Name="usernameText"
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Style="{StaticResource ContactUsernameStyle}"
                    Text="{Binding DisplayName}" />
                <TextBlock
                    x:Name="statusText"
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="10,1,0,0"
                    Style="{StaticResource ContactStatusStyle}"
                    Text="{Binding Partner.Status, TargetNullValue=''}" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="usernameText" Property="Foreground" Value="White" />
                    <Setter TargetName="statusText" Property="Foreground" Value="White" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <!--  Group template  -->
        <DataTemplate DataType="{x:Type yggdrasil:Group}">
            <Grid Height="32" Margin="2,4,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2" />
                    <RowDefinition Height="14" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Profile picture  -->
                <Grid
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    Margin="2,0,0,0">
                    <Border Background="Transparent">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="2"
                                Direction="270"
                                Opacity="0.50"
                                ShadowDepth="1"
                                Color="{StaticResource Avatar.Shadow}" />
                        </Border.Effect>
                        <Grid>
                            <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                        <Binding Path="ProfilePicture" />
                                        <Binding Source="group" />
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                            <Border BorderBrush="{StaticResource Avatar.Border}" BorderThickness="1" />
                        </Grid>
                    </Border>
                </Grid>
                <global:SliceControl
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="14"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    DefaultIndex="21"
                    ElementCount="22"
                    HoverIndex="-1"
                    PressedIndex="-1"
                    SliceMode="0"
                    Source="Assets/Universal/Icon/skype-status-small.png"
                    StackDirection="Horizontal" />
                <!--  Name + member count  -->
                <TextBlock
                    x:Name="usernameText"
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Style="{StaticResource ContactUsernameStyle}"
                    Text="{Binding DisplayName}" />
                <TextBlock
                    x:Name="statusText"
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="10,1,0,0"
                    Style="{StaticResource ContactStatusStyle}"
                    Text="{Binding Members.Length, StringFormat={}{0} members}" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="usernameText" Property="Foreground" Value="White" />
                    <Setter TargetName="statusText" Property="Foreground" Value="White" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <!--  Server template  -->
        <HierarchicalDataTemplate DataType="{x:Type yggdrasil:Server}" ItemsSource="{Binding GroupedChannels}">
            <HierarchicalDataTemplate.ItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type global:CategoryHeaderItem}">
                                <Border
                                    Height="20"
                                    Margin="0"
                                    Padding="8,0"
                                    Background="{StaticResource Sidebar.Header}">
                                    <TextBlock
                                        Margin="2,0,0,1"
                                        VerticalAlignment="Center"
                                        FontFamily="Tahoma"
                                        FontSize="11"
                                        Foreground="{StaticResource Text.VeryHighContrast}"
                                        Text="{Binding CategoryName}" />
                                </Border>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type yggdrasil:ServerChannel}">
                                <Grid Height="22" Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <global:SliceControl
                                        Grid.Column="0"
                                        Width="14"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Left"
                                        DefaultIndex="{Binding ChannelType, Converter={StaticResource ChannelTypeConverter}}"
                                        ElementCount="11"
                                        HoverIndex="-1"
                                        PressedIndex="-1"
                                        SliceMode="0"
                                        Source="Assets/Universal/Icon/skype-channel.png"
                                        StackDirection="Horizontal" />
                                    <TextBlock
                                        x:Name="channelText"
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="Black"
                                        Style="{StaticResource ContactStatusStyle}"
                                        Text="{Binding DisplayName}" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                        <Setter TargetName="channelText" Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </DataTemplate>
            </HierarchicalDataTemplate.ItemTemplate>
            <Grid Height="32" Margin="2,4,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2" />
                    <RowDefinition Height="14" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  Profile picture  -->
                <Grid
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    Margin="2,0,0,0">
                    <Border Background="Transparent">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="2"
                                Direction="270"
                                ShadowDepth="1"
                                Color="{StaticResource Avatar.Shadow}" />
                        </Border.Effect>
                        <Grid>
                            <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                        <Binding Path="ProfilePicture" />
                                        <Binding Source="group" />
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                            <Border BorderBrush="{StaticResource Avatar.Border}" BorderThickness="1" />
                        </Grid>
                    </Border>
                </Grid>

                <TextBlock
                    x:Name="usernameText"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Style="{StaticResource ContactUsernameStyle}"
                    Text="{Binding DisplayName}" />
                <TextBlock
                    x:Name="statusText"
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="10,1,0,0"
                    Style="{StaticResource ContactStatusStyle}"
                    Text="{Binding MemberCount, StringFormat={}{0} members}" />
                <ToggleButton
                    Grid.RowSpan="3"
                    Grid.Column="2"
                    Width="16"
                    Height="16"
                    Margin="0,0,4,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsChecked="{Binding Path=IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}, Mode=TwoWay}">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid Width="12" Height="12">
                                <Image
                                    Width="12"
                                    Height="12"
                                    Source="Assets/Universal/Sidebar/collapse-toggle-background.png" />
                                <Image
                                    x:Name="ToggleImage"
                                    Width="12"
                                    Height="12"
                                    RenderTransformOrigin="0.5,0.5"
                                    Source="Assets/Universal/Sidebar/collapse-toggle-arrow.png">
                                    <Image.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ToggleImage" Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="90" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
            </Grid>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                    <Setter TargetName="usernameText" Property="Foreground" Value="White" />
                    <Setter TargetName="statusText" Property="Foreground" Value="White" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
        <!--  CONTACT ITEM TEMPLATE END  -->
        <!--  COMPACT RECENTS TEMPLATES START  -->
        <DataTemplate x:Key="DateHeaderTemplate" DataType="{x:Type global:DateHeaderItem}">
            <Border
                Height="20"
                Margin="0"
                Padding="8,0"
                Background="{StaticResource Sidebar.Header}">
                <TextBlock
                    Margin="2,0,0,1"
                    VerticalAlignment="Center"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Foreground="{StaticResource Text.VeryHighContrast}"
                    Text="{Binding DateText}" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="CompactDirectMessageTemplate" DataType="{x:Type yggdrasil:DirectMessage}">
            <Grid Height="22" Margin="8,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <global:SliceControl
                    Grid.Column="0"
                    Width="14"
                    Height="14"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    DefaultIndex="{Binding Partner.ConnectionStatus, Converter={StaticResource ConnectionStatusConverter}}"
                    ElementCount="22"
                    HoverIndex="-1"
                    PressedIndex="-1"
                    SliceMode="0"
                    Source="Assets/Universal/Icon/skype-status-small.png"
                    StackDirection="Horizontal" />
                <TextBlock
                    x:Name="compactName"
                    Grid.Column="1"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Text="{Binding DisplayName}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="compactName" Property="Foreground" Value="White" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <DataTemplate x:Key="CompactGroupTemplate" DataType="{x:Type yggdrasil:Group}">
            <Grid Height="22" Margin="8,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <global:SliceControl
                    Grid.Column="0"
                    Width="14"
                    Height="14"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    DefaultIndex="21"
                    ElementCount="22"
                    HoverIndex="-1"
                    PressedIndex="-1"
                    SliceMode="0"
                    Source="Assets/Universal/Icon/skype-status-small.png"
                    StackDirection="Horizontal" />
                <TextBlock
                    x:Name="compactGroupName"
                    Grid.Column="1"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Text="{Binding DisplayName}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="compactGroupName" Property="Foreground" Value="White" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <!--  COMPACT RECENTS TEMPLATES END  -->
        <!--  CONVERSATION ITEM TEMPLATES START  -->
        <!--  MessageItem Template  -->
        <DataTemplate DataType="{x:Type yggdrasil:ActionMessage}">
            <Grid HorizontalAlignment="Stretch">
                <Grid
                    x:Name="ConversationGrid"
                    MaxWidth="626"
                    Margin="0,10,65,0"
                    HorizontalAlignment="Stretch">
                    <!--  148 + 428 + 50  -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="148" />
                        <ColumnDefinition Width="*" MaxWidth="428" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <!--  Center area  -->
                    <!--  Reply header  -->
                    <Grid
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,0,20,2"
                        Visibility="{Binding ParentMessage, Converter={StaticResource NullDependentVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image
                            Grid.Column="0"
                            Width="12"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            SnapsToDevicePixels="True"
                            Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, ConverterParameter=Skype5, Source='Chat/reply-arrow.png'}" />
                        <TextBlock
                            Grid.Column="1"
                            FontFamily="Tahoma"
                            FontSize="11"
                            Foreground="{StaticResource Text.LowContrast}"
                            LineHeight="1"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Replying to {0} - &quot;{1}&quot;">
                                    <Binding Path="ParentMessage.Author.DisplayName" />
                                    <Binding Converter="{StaticResource ReplyBodyConverter}" Path="ParentMessage.Text" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <!--  Message body + attachment  -->
                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="0,0,20,0"
                        Orientation="Vertical">
                        <ContentControl Content="{Binding Converter={StaticResource FormatFullActionMessageConverter}}" Visibility="{Binding Text, Converter={StaticResource NullDependentVisibilityConverter}}" />
                        <Image
                            MaxWidth="300"
                            MaxHeight="300"
                            Margin="{Binding Converter={StaticResource NullDependentMarginConverter}}"
                            HorizontalAlignment="Left"
                            Cursor="Hand"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Source="{Binding Attachments, Converter={StaticResource MsgByteArrayToImageConverter}}"
                            Stretch="Uniform"
                            Visibility="{Binding Attachments, Converter={StaticResource NullDependentVisibilityConverter}}">
                            <Image.InputBindings>
                                <MouseBinding
                                    Command="{Binding DataContext.OpenImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Attachments}"
                                    MouseAction="LeftClick" />
                            </Image.InputBindings>
                        </Image>
                    </StackPanel>
                    <!--  Timestamp  -->
                    <Grid
                        Grid.Row="1"
                        Grid.Column="2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                        <TextBlock
                            FontFamily="Tahoma"
                            FontSize="11"
                            Foreground="{StaticResource Text.LowContrast}"
                            Text="{Binding Time, StringFormat=h:mm tt}"
                            Visibility="{Binding Identifier, Converter={StaticResource PreviewVisibilityConverter}, ConverterParameter=invert}" />
                        <global:SliceControl
                            Width="10"
                            Height="10"
                            AnimationFps="60"
                            DefaultIndex="0"
                            ElementCount="72"
                            IsAnimation="True"
                            SliceMode="0"
                            Source="Assets/Universal/Chat/loading.png"
                            StackDirection="Vertical"
                            Visibility="{Binding Identifier, Converter={StaticResource PreviewVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type yggdrasil:Message}">
            <Grid
                HorizontalAlignment="Stretch"
                ContextMenu="{DynamicResource MessageContextMenu}"
                Tag="{DynamicResource Lang}">
                <Grid
                    x:Name="ConversationGrid"
                    MaxWidth="626"
                    Margin="0,10,65,0"
                    HorizontalAlignment="Stretch">
                    <!--  148 + 428 + 50  -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="148" />
                        <ColumnDefinition Width="*" MaxWidth="428" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <!--  Sender name  -->
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,16,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        FontFamily="Tahoma"
                        FontSize="11"
                        TextTrimming="CharacterEllipsis">
                        <TextBlock.Foreground>
                            <MultiBinding Converter="{StaticResource SenderToColorConverter}">
                                <Binding Path="Sender.Identifier" />
                                <Binding Path="IsForwarded" />
                            </MultiBinding>
                        </TextBlock.Foreground>
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource ForwardedMessageStatusConverter}">
                                <Binding Path="Sender.DisplayName" />
                                <Binding Path="IsForwarded" />
                            </MultiBinding>
                        </TextBlock.Text>
                        <TextBlock.Visibility>
                            <MultiBinding Converter="{StaticResource IDToVisibilityConverter}">
                                <Binding Path="PreviousMessageIdentifier" />
                                <Binding Path="Sender.Identifier" />
                                <Binding Path="PreviousMessageIsAction" />
                            </MultiBinding>
                        </TextBlock.Visibility>
                    </TextBlock>
                    <!--  Center area  -->
                    <!--  Reply header  -->
                    <Grid
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,0,20,2"
                        Visibility="{Binding ParentMessage, Converter={StaticResource NullDependentVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image
                            Grid.Column="0"
                            Width="12"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            SnapsToDevicePixels="True"
                            Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, ConverterParameter=Skype6, Source='Chat/reply-arrow.png'}" />
                        <TextBlock
                            Grid.Column="1"
                            FontFamily="Tahoma"
                            FontSize="11"
                            Foreground="{StaticResource Text.LowContrast}"
                            LineHeight="1"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Replying to {0} - &quot;{1}&quot;">
                                    <Binding Path="ParentMessage.Author.DisplayName" />
                                    <Binding Converter="{StaticResource ReplyBodyConverter}" Path="ParentMessage.Text" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <!--  Message body + attachment  -->
                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="0,0,20,0"
                        Orientation="Vertical">
                        <ContentControl Content="{Binding Text, Converter={StaticResource FormatFullTextConverter}}" Visibility="{Binding Text, Converter={StaticResource NullDependentVisibilityConverter}}" />
                        <Image
                            MaxWidth="300"
                            MaxHeight="300"
                            Margin="{Binding Text, Converter={StaticResource NullDependentMarginConverter}}"
                            HorizontalAlignment="Left"
                            Cursor="Hand"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Source="{Binding Attachments, Converter={StaticResource MsgByteArrayToImageConverter}}"
                            Stretch="Uniform"
                            Visibility="{Binding Attachments, Converter={StaticResource NullDependentVisibilityConverter}}">
                            <Image.InputBindings>
                                <MouseBinding
                                    Command="{Binding DataContext.OpenImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Attachments}"
                                    MouseAction="LeftClick" />
                            </Image.InputBindings>
                        </Image>
                    </StackPanel>
                    <!--  Timestamp  -->
                    <Grid
                        Grid.Row="1"
                        Grid.Column="2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                        <TextBlock
                            FontFamily="Tahoma"
                            FontSize="11"
                            Foreground="{StaticResource Text.LowContrast}"
                            Text="{Binding Time, StringFormat=h:mm tt}"
                            Visibility="{Binding Identifier, Converter={StaticResource PreviewVisibilityConverter}, ConverterParameter=invert}" />
                        <global:SliceControl
                            Width="10"
                            Height="10"
                            AnimationFps="60"
                            DefaultIndex="0"
                            ElementCount="72"
                            IsAnimation="True"
                            SliceMode="0"
                            Source="Assets/Universal/Chat/loading.png"
                            StackDirection="Vertical"
                            Visibility="{Binding Identifier, Converter={StaticResource PreviewVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </Grid>
        </DataTemplate>
        <!--  CallStartedItem Template  -->
        <DataTemplate DataType="{x:Type yggdrasil:CallStartedNotice}">
            <Grid Margin="0,9.5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="114" />
                    <ColumnDefinition Width="430" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="1"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Foreground="{StaticResource Text.LowContrast}"
                    Text="{Binding StartedBy, StringFormat='Call started by: {0}'}" />
