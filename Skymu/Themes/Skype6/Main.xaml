                                            Margin="7,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource Text.LowContrast}"
                                            Text="Sky Multiprotocol. All rights reserved." />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                        <ContentControl
                            x:Name="SelectedItemHolder"
                            Grid.Row="0"
                            Visibility="Collapsed" />
                        <Border
                            x:Name="SkypeSplitter"
                            Grid.Column="1"
                            BorderBrush="{StaticResource Metro.Border}"
                            BorderThickness="0,0,1,0"
                            Cursor="SizeWE"
                            MouseLeftButtonDown="SkypeSplitter_Press"
                            MouseMove="SkypeSplitter_MouseMove" />
                        <Grid
                            x:Name="ChatArea"
                            Grid.Column="2"
                            Margin="0,1"
                            DataContext="{Binding SelectedItem, ElementName=ConversationList}">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="ChatTopBarRow" Height="Auto" />
                                <RowDefinition
                                    x:Name="TopbarWindowRow"
                                    Height="120"
                                    MinHeight="107"
                                    MaxHeight="171" />
                                <RowDefinition x:Name="ChatTopbarSplitterRow" Height="4" />
                                <RowDefinition x:Name="MessageWindowRow" Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Grid.Row="0"
                                Margin="8,3,8,0"
                                BorderBrush="{StaticResource Metro.Border}"
                                BorderThickness="0,0,0,1">
                                <Grid
                                    Height="32"
                                    Margin="0,0,0,4"
                                    Visibility="Visible">
                                    <global:SliceControl
                                        x:Name="Topbar"
                                        Grid.Row="0"
                                        HorizontalAlignment="Stretch"
                                        DefaultIndex="0"
                                        ElementCount="4"
                                        HoverIndex="1"
                                        IsRadioButton="False"
                                        PressedIndex="2"
                                        Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, ConverterParameter=Skype6, Source='Sidebar/header.png'}"
                                        StackDirection="Vertical"
                                        Text="{Binding DisplayName}"
                                        TextColor="{StaticResource Text.HighContrast}"
                                        TextFont="Arial"
                                        TextLeftMargin="13"
                                        TextSize="13"
                                        TextWeight="Bold" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1">
                                <WebBrowser
                                    x:Name="browser"
                                    Grid.Row="1"
                                    Visibility="Collapsed" />
                                <Frame
                                    x:Name="HomeUnavailable"
                                    Grid.Row="1"
                                    Visibility="Collapsed" />
                                <ContentControl x:Name="FillMessagePanelHost" Visibility="Collapsed" />
                                <ContentControl x:Name="ChatProfileArea" Content="{Binding DataContext, ElementName=ChatArea}">
                                    <ContentControl.Resources>
                                        <DataTemplate DataType="{x:Type yggdrasil:DirectMessage}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <!--  Profile picture column  -->
                                                <Image
                                                    x:Name="CPAProfilePic"
                                                    Grid.Column="0"
                                                    Margin="4,4,5,9"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                    Stretch="UniformToFill">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                                            <Binding Path="ProfilePicture" />
                                                            <Binding Source="user" />
                                                        </MultiBinding>
                                                    </Image.Source>
                                                    <Image.Effect>
                                                        <DropShadowEffect
                                                            BlurRadius="4"
                                                            Direction="270"
                                                            ShadowDepth="1"
                                                            Color="{StaticResource Avatar.Shadow}" />
                                                    </Image.Effect>
                                                </Image>
                                                <!--  Information column  -->
                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="12,12"
                                                    Orientation="Vertical">
                                                    <!--  Text status row ("I'm bored", etc)  -->
                                                    <StackPanel
                                                        Margin="0,0,0,15"
                                                        HorizontalAlignment="Left"
                                                        Orientation="Horizontal"
                                                        Visibility="{Binding Partner.Status, Converter={StaticResource NullDependentVisibilityConverter}}">
                                                        <Image
                                                            Width="16"
                                                            Height="16"
                                                            Source="Assets/Universal/Chat/mood.png" />
                                                        <TextBlock
                                                            Margin="9,0,0,0"
                                                            FontFamily="Tahoma"
                                                            FontSize="11"
                                                            Text="{Binding Partner.Status, TargetNullValue=''}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <!--  Time row for remote user. TODO: implement this in Yggdrasil  -->
                                                    <StackPanel
                                                        x:Name="TimeRow"
                                                        Margin="0,0,0,15"
                                                        HorizontalAlignment="Left"
                                                        Orientation="Horizontal"
                                                        Visibility="Collapsed">
                                                        <Image
                                                            Width="16"
                                                            Height="16"
                                                            Source="Assets/Universal/Chat/clock.png" />
                                                        <TextBlock
                                                            Margin="9,0,0,0"
                                                            FontFamily="Tahoma"
                                                            FontSize="11"
                                                            Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat={}{0:h:mm tt}}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <!--  Connection status row (online, offline, away, dnd)  -->
                                                    <StackPanel
                                                        x:Name="StatusRow"
                                                        HorizontalAlignment="Left"
                                                        Orientation="Horizontal">
                                                        <global:SliceControl
                                                            Width="14"
                                                            Height="14"
                                                            DefaultIndex="{Binding Partner.ConnectionStatus, Converter={StaticResource ConnectionStatusConverter}}"
                                                            ElementCount="22"
                                                            Interactive="False"
                                                            SliceMode="0"
                                                            Source="Assets/Universal/Icon/skype-status-small.png"
                                                            StackDirection="Horizontal" />
                                                        <TextBlock
                                                            Margin="11,0,0,0"
                                                            FontFamily="Tahoma"
                                                            FontSize="11"
                                                            Text="{Binding Partner.ConnectionStatus, Converter={StaticResource StatIntToText}}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type yggdrasil:Group}">
                                            <ItemsControl ItemsSource="{Binding Members}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type yggdrasil:User}">
                                                        <StackPanel
                                                            Width="120"
                                                            Margin="10,0"
                                                            Orientation="Vertical">
                                                            <!--  Name row with status icon  -->
                                                            <StackPanel
                                                                Margin="0,0,0,2"
                                                                HorizontalAlignment="Center"
                                                                Orientation="Horizontal">
                                                                <global:SliceControl
                                                                    Width="16"
                                                                    Height="16"
                                                                    VerticalAlignment="Center"
                                                                    DefaultIndex="{Binding ConnectionStatus, Converter={StaticResource ConnectionStatusConverter}}"
                                                                    ElementCount="22"
                                                                    Interactive="False"
                                                                    SliceMode="0"
                                                                    Source="Assets/Universal/Icon/skype-status.png"
                                                                    StackDirection="Horizontal" />
                                                                <TextBlock
                                                                    MaxWidth="100"
                                                                    Margin="5,0,0,1"
                                                                    VerticalAlignment="Center"
                                                                    FontFamily="Tahoma"
                                                                    FontSize="11"
                                                                    Text="{Binding DisplayName}"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    TextWrapping="NoWrap" />
                                                            </StackPanel>
                                                            <!--  Profile picture  -->
                                                            <Image
                                                                Width="85"
                                                                Margin="0,3,0,0"
                                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                                Stretch="UniformToFill">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                                                        <Binding Path="ProfilePicture" />
                                                                        <Binding Source="user" />
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                                <Image.Effect>
                                                                    <DropShadowEffect
                                                                        BlurRadius="4"
                                                                        Direction="270"
                                                                        ShadowDepth="1"
                                                                        Color="{StaticResource Avatar.Shadow}" />
                                                                </Image.Effect>
                                                            </Image>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type yggdrasil:Server}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <!--  Profile picture column  -->
                                                <Image
                                                    x:Name="CPAProfilePic"
                                                    Grid.Column="0"
                                                    Margin="4,4,5,9"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                    Stretch="UniformToFill">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                                            <Binding Path="ProfilePicture" />
                                                            <Binding Source="group" />
                                                        </MultiBinding>
                                                    </Image.Source>
                                                    <Image.Effect>
                                                        <DropShadowEffect
                                                            BlurRadius="4"
                                                            Direction="270"
                                                            ShadowDepth="1"
                                                            Color="{StaticResource Avatar.Shadow}" />
                                                    </Image.Effect>
                                                </Image>
                                                <!--  Information column  -->
                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="12,12"
                                                    Orientation="Vertical">
                                                    <!--  Server channel count row  -->
                                                    <StackPanel
                                                        x:Name="StatusRow"
                                                        HorizontalAlignment="Left"
                                                        Orientation="Horizontal">
                                                        <global:SliceControl
                                                            Width="14"
                                                            Height="14"
                                                            DefaultIndex="2"
                                                            ElementCount="11"
                                                            Interactive="False"
                                                            SliceMode="0"
                                                            Source="Assets/Universal/Icon/skype-channel.png"
                                                            StackDirection="Horizontal" />
                                                        <TextBlock
                                                            Margin="11,0,0,0"
                                                            FontFamily="Tahoma"
                                                            FontSize="11"
                                                            Text="{Binding Channels.Length, StringFormat='{}Server - {0} channels'}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                        <DataTemplate DataType="{x:Type yggdrasil:ServerChannel}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <!--  Profile picture column  -->
                                                <Image
                                                    x:Name="CPAProfilePic"
                                                    Grid.Column="0"
                                                    Margin="4,4,5,9"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                    Stretch="UniformToFill">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                                            <Binding Path="ProfilePicture" />
                                                            <Binding Source="group" />
                                                        </MultiBinding>
                                                    </Image.Source>
                                                    <Image.Effect>
                                                        <DropShadowEffect
                                                            BlurRadius="4"
                                                            Direction="270"
                                                            ShadowDepth="1"
                                                            Color="{StaticResource Avatar.Shadow}" />
                                                    </Image.Effect>
                                                </Image>
                                                <!--  Information column  -->
                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="12,12"
                                                    Orientation="Vertical">
                                                    <!--  Server channel descriptor row  -->
                                                    <StackPanel
                                                        x:Name="StatusRow"
                                                        HorizontalAlignment="Left"
                                                        Orientation="Horizontal">
                                                        <global:SliceControl
                                                            Width="14"
                                                            Height="14"
                                                            DefaultIndex="{Binding ChannelType, Converter={StaticResource ChannelTypeConverter}}"
                                                            ElementCount="11"
                                                            Interactive="False"
                                                            SliceMode="0"
                                                            Source="Assets/Universal/Icon/skype-channel.png"
                                                            StackDirection="Horizontal" />
                                                        <TextBlock
                                                            Margin="11,0,0,0"
                                                            FontFamily="Tahoma"
                                                            FontSize="11"
                                                            Text="Server channel"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ContentControl.Resources>
                                </ContentControl>
                            </Grid>

                            <Rectangle
                                x:Name="ChatTopBarSplitter"
                                Grid.Row="2"
                                Cursor="SizeNS"
                                Fill="Transparent"
                                MouseLeftButtonDown="ChatTopBarSplitter_Press"
                                MouseMove="ChatTopBarSplitter_MouseMove" />
                            <Border
                                x:Name="MessageWindow"
                                Grid.Row="3"
                                Margin="0,4,0,0"
                                Background="{StaticResource Metro.Background}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition x:Name="ChatButtonRow" Height="34" />
                                        <RowDefinition Height="1" />
                                        <RowDefinition Height="181*" />
                                        <RowDefinition Height="367*" />
                                        <RowDefinition Height="20" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel
                                        Grid.Row="0"
                                        Margin="7,0,0,2"
                                        HorizontalAlignment="Left"
                                        Orientation="Horizontal">
                                        <global:SliceControl
                                            x:Name="VideoCallButton"
                                            Width="Auto"
                                            Command="{Binding DataContext.VideoCallCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            DefaultIndex="0"
                                            ElementCount="5"
                                            HoverIndex="1"
                                            LeftWidth="22"
                                            PressedIndex="2"
                                            RightWidth="22"
                                            Source="Assets/Universal/Chat/btn_video_call.png"
                                            StackDirection="Vertical"
                                            Text="{Binding Source={StaticResource Lang}, Path=[sZAPBUTTON_STARTVIDEOCALL]}"
                                            TextColor="White"
                                            TextFont="Arial"
                                            TextLeftMargin="25"
                                            TextRightMargin="9"
                                            TextSize="13"
                                            TextWeight="Bold" />
                                        <global:SliceControl
                                            x:Name="CallButton"
                                            Width="Auto"
                                            Margin="10,0,0,0"
                                            DefaultIndex="0"
                                            ElementCount="5"
                                            HoverIndex="1"
                                            LeftWidth="23"
                                            MouseLeftButtonUp="CallButtonClick"
                                            PressedIndex="2"
                                            RightWidth="4"
                                            Source="Assets/Universal/Chat/btn_call_left.png"
                                            StackDirection="Vertical"
                                            Text="{Binding Source={StaticResource Lang}, Path=[sZAPBUTTON_CALL]}"
                                            TextColor="White"
                                            TextFont="Arial"
                                            TextLeftMargin="26"
                                            TextSize="13"
                                            TextWeight="Bold" />
                                        <global:SliceControl
                                            x:Name="CallDropdown"
                                            Width="24"
                                            DefaultIndex="0"
                                            ElementCount="5"
                                            HoverIndex="1"
                                            LeftWidth="1"
                                            PressedIndex="2"
                                            RightWidth="1"
                                            Source="Assets/Universal/Chat/btn_call_right.png"
                                            StackDirection="Vertical" />
                                        <global:SliceControl
                                            Width="37"
                                            Margin="10,0,0,0"
                                            DefaultIndex="0"
                                            ElementCount="5"
                                            HoverIndex="1"
                                            MouseLeftButtonUp="AddButtonClick"
                                            PressedIndex="2"
                                            SliceMode="0"
                                            Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, ConverterParameter=Skype6, Source='Chat/add.png'}"
                                            StackDirection="Vertical" />
                                        <global:SliceControl
                                            x:Name="WifiButton"
                                            Width="44"
                                            Margin="10,0,0,0"
                                            Command="{Binding DataContext.RunSpeedTestCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            DefaultIndex="0"
                                            ElementCount="5"
                                            HoverIndex="1"
                                            PressedIndex="2"
                                            SliceMode="0"
                                            Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, ConverterParameter=Skype6, Source='Chat/network-none.png'}"
                                            StackDirection="Vertical" />
                                    </StackPanel>
                                    <Rectangle
                                        Grid.Row="1"
                                        Height="1"
                                        Fill="{StaticResource Chatbar.Divider}" />
                                    <Image
                                        x:Name="throbber"
                                        Grid.Row="3"
                                        Width="90"
                                        Height="90"
                                        Margin="523,48.333,523,229"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        RenderTransformOrigin="0.5,0.5"
                                        Source="Assets/Universal/Animations/spinner.png"
                                        Visibility="Visible">
                                        <Image.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform />
                                                <SkewTransform />
                                                <RotateTransform x:Name="SpinnerRotate" Angle="0" />
                                                <TranslateTransform />
                                            </TransformGroup>
                                        </Image.RenderTransform>
                                        <Image.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation
                                                            RepeatBehavior="Forever"
                                                            Storyboard.TargetName="SpinnerRotate"
                                                            Storyboard.TargetProperty="Angle"
                                                            From="0"
                                                            To="360"
                                                            Duration="0:0:2.133333" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Image.Triggers>
                                    </Image>
                                    <ListBox
                                        x:Name="ConversationItemsList"
                                        Grid.Row="2"
                                        Grid.RowSpan="2"
                                        Margin="0,0,0,0"
                                        VerticalAlignment="Bottom"
                                        BorderThickness="0"
                                        Loaded="ConversationItemsList_Loaded"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        Style="{StaticResource NoInsetListBox}"
                                        VirtualizingPanel.IsVirtualizing="True"
                                        VirtualizingPanel.ScrollUnit="Pixel"
                                        VirtualizingPanel.VirtualizationMode="Standard"
                                        mc:Ignorable="d">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemBorder" Background="Transparent">
                                                                <ContentPresenter />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                    <Grid
                                        Grid.Row="5"
                                        Margin="0,0,0,5"
                                        VerticalAlignment="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel
                                            Grid.Column="1"
                                            Width="429"
                                            Orientation="Vertical">
                                            <StackPanel
                                                x:Name="TypingIndicator"
                                                Margin="0,0,0,7"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Visibility="Collapsed">
                                                <global:SliceControl
                                                    x:Name="TypingIndicatorIcon"
                                                    Width="23"
                                                    AnimationFps="30"
                                                    DefaultIndex="0"
                                                    ElementCount="37"
                                                    HoverIndex="-1"
                                                    IsAnimation="True"
                                                    PressedIndex="-1"
                                                    SliceMode="0"
                                                    Source="Assets/Universal/Chat/pencil-write.png"
                                                    StackDirection="Vertical" />
                                                <TextBlock
                                                    x:Name="TypingIndicatorText"
                                                    Margin="3,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource Text.MediumContrast}" />
                                            </StackPanel>
                                            <Border
                                                x:Name="MessageBoxPanel"
                                                HorizontalAlignment="Center"
                                                BorderBrush="{StaticResource Sidebar.Header}"
                                                BorderThickness="1">
                                                <Grid>
                                                    <global:SliceControl
                                                        x:Name="EmojiButton"
                                                        Width="18"
                                                        Height="17"
                                                        Margin="0,4,4,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        DefaultIndex="0"
                                                        ElementCount="5"
                                                        HoverIndex="1"
                                                        MouseLeftButtonUp="EmojiButton_Click"
                                                        PressedIndex="2"
                                                        SliceMode="0"
                                                        Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, ConverterParameter=Skype6, Source='Chat/emoji.png'}"
                                                        StackDirection="Vertical" />
                                                    <Popup
                                                        x:Name="EmojiFlyout"
                                                        AllowsTransparency="True"
                                                        HorizontalOffset="-20"
                                                        Placement="Top"
                                                        PlacementTarget="{Binding ElementName=EmojiButton}"
                                                        StaysOpen="False">
                                                        <Border
                                                            Padding="2"
                                                            Background="{StaticResource EmojiFlyout.Background}"
                                                            BorderBrush="{StaticResource EmojiFlyout.Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="4">
                                                            <ScrollViewer
                                                                MaxWidth="257"
                                                                MaxHeight="278"
                                                                HorizontalScrollBarVisibility="Disabled"
                                                                VerticalScrollBarVisibility="Visible">
                                                                <ScrollViewer.Resources>
                                                                    <Style TargetType="ScrollBar">
                                                                        <Setter Property="Width" Value="8" />
                                                                        <Setter Property="Background" Value="Transparent" />
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="ScrollBar">
                                                                                    <Grid
                                                                                        Width="8"
                                                                                        HorizontalAlignment="Right"
                                                                                        Background="Transparent">
                                                                                        <Track Name="PART_Track" IsDirectionReversed="True">
                                                                                            <Track.Thumb>
                                                                                                <Thumb Width="6" HorizontalAlignment="Center">
                                                                                                    <Thumb.Template>
                                                                                                        <ControlTemplate TargetType="Thumb">
                                                                                                            <Border
                                                                                                                Width="6"
                                                                                                                HorizontalAlignment="Center"
                                                                                                                Background="White"
                                                                                                                CornerRadius="3"
                                                                                                                Opacity="0.9" />
                                                                                                        </ControlTemplate>
                                                                                                    </Thumb.Template>
                                                                                                </Thumb>
                                                                                            </Track.Thumb>
                                                                                        </Track>
                                                                                    </Grid>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </ScrollViewer.Resources>
                                                                <WrapPanel x:Name="EmojiWrapPanel" Orientation="Horizontal" />
                                                            </ScrollViewer>
                                                        </Border>
                                                    </Popup>
                                                    <RichTextBox
                                                        x:Name="MessageTextBox"
                                                        MinHeight="37"
                                                        MaxHeight="{Binding ActualHeight, ElementName=MessageWindow, Converter={StaticResource HalfValueConverter}}"
                                                        Padding="2,4,30,4"
                                                        AcceptsReturn="True"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontFamily="Tahoma"
                                                        FontSize="11"
                                                        GotKeyboardFocus="MessageTextBox_Focused"
                                                        LostKeyboardFocus="MessageTextBox_Unfocused"
                                                        PreviewKeyDown="MessageTextBox_PreviewKeyDown"
                                                        SnapsToDevicePixels="True"
                                                        TextChanged="MessageTextBox_TextChanged"
                                                        UseLayoutRounding="True"
                                                        VerticalScrollBarVisibility="Auto">
                                                        <RichTextBox.Document>
                                                            <FlowDocument>
                                                                <Paragraph Margin="0" />
                                                            </FlowDocument>
                                                        </RichTextBox.Document>
                                                    </RichTextBox>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                        <global:SliceControl
                                            x:Name="SendMsgButton"
                                            Grid.Column="2"
                                            Width="Auto"
                                            Margin="8,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            DefaultIndex="0"
                                            ElementCount="5"
                                            Focusable="False"
                                            HoverIndex="1"
                                            IsEnabled="False"
                                            LeftWidth="22"
                                            MouseLeftButtonUp="OnMsgSendClickButton"
                                            PressedIndex="2"
                                            RightWidth="22"
                                            Source="Assets/Universal/Chat/msg-send-button-full.png"
                                            StackDirection="Vertical"
                                            Text="{Binding Source={StaticResource Lang}, Path=[sZAPBUTTON_SENDMESSAGE]}"
                                            TextColor="White"
                                            TextFont="Arial"
                                            TextLeftMargin="26"
                                            TextSize="13"
                                            TextWeight="Bold" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>