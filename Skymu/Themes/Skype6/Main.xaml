                    VerticalAlignment="Top"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Foreground="{StaticResource Text.LowContrast}"
                    Text="{Binding Time, StringFormat=h:mm tt}" />
            </Grid>
        </DataTemplate>
        <!--  CONVERSATION ITEM TEMPLATE END  -->
