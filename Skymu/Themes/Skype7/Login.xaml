    <StackPanel Orientation="Vertical">
        <!--  selector strip  -->
        <Grid
            Grid.Row="0"
            Height="30"
            Background="{StaticResource Accent}">
            <StackPanel
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    x:Name="ProtocolText"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontFamily="Segoe UI Historic"
                    FontSize="12"
                    Foreground="White"
                    Text="Messaging service" />
                <ComboBox
                    x:Name="ProtocolComboBox"
                    Width="180"
                    FontFamily="Segoe UI Historic"
                    FontSize="12"
                    SelectionChanged="ProtocolSelectionChanged" />
            </StackPanel>
        </Grid>
        <Grid
            Name="MainGrid"
            Background="{StaticResource Metro.Background}"
            Focusable="True"
            KeyDown="Grid_KeyDown">
            <Border
                Grid.ColumnSpan="2"
                Width="720"
                Height="472"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{StaticResource Metro.Text.VeryHighContrast}"
                BorderThickness="0">
                <Grid>
                    <Image
                        x:Name="N1"
                        Width="138.5"
                        Height="61.5"
                        Margin="0,36,0,0"
                        VerticalAlignment="Top"
                        Source="{DynamicResource SkypeLogo}">
                        <Image.RenderTransform>
                            <TranslateTransform x:Name="N1Transform" Y="156" />
                        </Image.RenderTransform>
                    </Image>
                    <Image
                        x:Name="Spinner"
                        Width="128"
                        Height="128"
                        Margin="0,0,0,48"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        RenderTransformOrigin="0.50785,0.5001"
                        Source="Assets/Universal/Animations/spinner.png"
                        Visibility="Collapsed">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <SkewTransform />
                                <RotateTransform x:Name="SpinnerRotate" Angle="0" />
                                <TranslateTransform />
                            </TransformGroup>
                        </Image.RenderTransform>
                        <Image.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="SpinnerRotate"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:2.133333" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Image.Triggers>
                    </Image>
                    <Grid x:Name="ControlsGrid">
                        <Label
                            x:Name="Header"
                            Margin="0,97,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="{x:Null}"
                            Content="{Binding [sZAPBUTTON_SIGNIN]}"
                            FontFamily="Segoe UI Light"
                            FontSize="34"
                            Foreground="{StaticResource Metro.Text.VeryHighContrast}"
                            Opacity="0"
                            TextOptions.TextFormattingMode="Ideal"
                            TextOptions.TextRenderingMode="ClearType">
                            <Label.RenderTransform>
                                <TranslateTransform x:Name="HeaderTransform" Y="156" />
                            </Label.RenderTransform>
                        </Label>
                        <Label
                            x:Name="SubHeader"
                            Margin="0,143,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="{x:Null}"
                            Content="with your account"
                            FontFamily="Segoe UI Semilight"
                            FontSize="16"
                            Foreground="{StaticResource Metro.Text.VeryHighContrast}"
                            Opacity="0"
                            TextOptions.TextFormattingMode="Ideal"
                            TextOptions.TextRenderingMode="ClearType">
                            <Label.RenderTransform>
                                <TranslateTransform x:Name="SubHeaderTransform" Y="156" />
                            </Label.RenderTransform>
                        </Label>

                        <Grid
                            x:Name="N4"
                            Width="280"
                            Height="32"
                            Margin="0,-55,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0">
                            <Rectangle
                                Height="0.5"
                                VerticalAlignment="Bottom"
                                Fill="{StaticResource Accent}" />
                            <TextBox
                                Name="UsernameBox"
                                Padding="-2,0,0,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="14"
                                Foreground="{StaticResource Metro.Text.VeryHighContrast}" />
                            <TextBlock
                                x:Name="UsernameHint"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{StaticResource Text.MediumContrast}"
                                IsHitTestVisible="False"
                                Text="{Binding [sF_USERENTRY_LABEL_USERNAME]}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text.Length, ElementName=UsernameBox}" Value="0" />
                                                    <Condition Binding="{Binding IsFocused, ElementName=UsernameBox}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="N4Transform" Y="156" />
                            </Grid.RenderTransform>
                        </Grid>

                        <Grid
                            x:Name="N5"
                            Width="280"
                            Height="32"
                            Margin="0,30,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0">
                            <Rectangle
                                Height="0.5"
                                VerticalAlignment="Bottom"
                                Fill="{StaticResource Accent}" />
                            <PasswordBox
                                Name="PasswordTokenBox"
                                Padding="-2,0,0,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="14"
                                Foreground="{StaticResource Metro.Text.VeryHighContrast}" />
                            <TextBlock
                                x:Name="PasswordHint"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{StaticResource Metro.Text.MediumContrast}"
                                IsHitTestVisible="False"
                                Text="{Binding [sF_USERENTRY_LABEL_PASSWORD]}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Password.Length, ElementName=PasswordTokenBox}" Value="0" />
                                                    <Condition Binding="{Binding IsFocused, ElementName=PasswordTokenBox}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="N5Transform" Y="156" />
                            </Grid.RenderTransform>
                        </Grid>

                        <Border
                            x:Name="LoginButton"
                            Width="125"
                            Height="41"
                            Margin="0,292,0,0"
                            VerticalAlignment="Top"
                            Background="{StaticResource Metro.Text.Highlight}"
                            CornerRadius="21,21,21,21"
                            Cursor="Hand"
                            MouseLeftButtonUp="LoginButton_Click"
                            Opacity="0">
                            <TextBlock
                                x:Name="LoginButtonLabel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Cursor="Hand"
                                FontFamily="Segoe UI Historic"
                                FontSize="14"
                                Foreground="White"
                                Text="{Binding [sZAPBUTTON_SIGNIN]}" />

                            <Border.RenderTransform>
                                <TranslateTransform x:Name="LoginButtonTransform" Y="156" />
                            </Border.RenderTransform>
                        </Border>
                        <Grid x:Name="N7" Opacity="0">
                            <TextBlock
                                Margin="303,360,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                FontFamily="Segoe UI Historic"
                                FontSize="14"
                                TextDecorations="None">
                                <Hyperlink Foreground="{StaticResource Metro.Text.Highlight}" TextDecorations="Underline">
                                    Create an account
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock
                                Margin="14,0,0,10"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                FontFamily="Segoe UI Historic"
                                FontSize="13"
                                TextDecorations="None">
                                <Hyperlink Foreground="{StaticResource Metro.Text.Highlight}" TextDecorations="Underline">
                                    Trouble signing in?
                                </Hyperlink>
                            </TextBlock>

                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="N7Transform" Y="156" />
                            </Grid.RenderTransform>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </StackPanel>
</Window>
