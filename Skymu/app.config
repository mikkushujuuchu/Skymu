                        <value>45</value>
                </setting>
                <setting name="EnableNotifications" serializeAs="String">
                        <value>True</value>
                </setting>
                <setting name="AccurateNotifications" serializeAs="String">
                        <value>False</value>
                </setting>
                <setting name="Homepage" serializeAs="String">
                        <value>https://infinitemac.org/embed?disk=Mac+OS+8.0&amp;infinite_hd=true&amp;machine=Quadra+650</value>
