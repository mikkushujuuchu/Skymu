<UserControl x:Class="Skymu.SliceControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="Root" SnapsToDevicePixels="True" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="NearestNeighbor" Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Rectangle x:Name="LeftSlice" Grid.Column="0" Width="20"/>
        <Rectangle x:Name="MiddleSlice" Grid.Column="1"/>
        <Rectangle x:Name="RightSlice" Grid.Column="2" Width="20"/>
        <TextBlock x:Name="OverlayText" Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Center" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis" IsHitTestVisible="False" Panel.ZIndex="10"/>
    </Grid>
</UserControl>