<UserControl x:Class="Skymu.SliceControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="Root" SnapsToDevicePixels="True" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="NearestNeighbor" Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Rectangle x:Name="TopLeftSlice"  Grid.Row="0" Grid.Column="0" Visibility="Collapsed"/>
        <Rectangle x:Name="TopMidSlice"   Grid.Row="0" Grid.Column="1" Visibility="Collapsed"/>
        <Rectangle x:Name="TopRightSlice" Grid.Row="0" Grid.Column="2" Visibility="Collapsed"/>

        <Rectangle x:Name="LeftSlice"   Grid.Row="1" Grid.Column="0" Width="20"/>
        <Rectangle x:Name="MiddleSlice" Grid.Row="1" Grid.Column="1"/>
        <Rectangle x:Name="RightSlice"  Grid.Row="1" Grid.Column="2" Width="20"/>

        <Rectangle x:Name="BotLeftSlice"  Grid.Row="2" Grid.Column="0" Visibility="Collapsed"/>
        <Rectangle x:Name="BotMidSlice"   Grid.Row="2" Grid.Column="1" Visibility="Collapsed"/>
        <Rectangle x:Name="BotRightSlice" Grid.Row="2" Grid.Column="2" Visibility="Collapsed"/>

        <TextBlock x:Name="OverlayText" Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Grid.ColumnSpan="3"
                   VerticalAlignment="Center" HorizontalAlignment="Left"
                   TextTrimming="CharacterEllipsis" IsHitTestVisible="False" Panel.ZIndex="10"/>
    </Grid>
</UserControl>