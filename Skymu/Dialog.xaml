<Window x:Class="Skymu.Dialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:Skymu" Title="Dialog" ResizeMode="NoResize" WindowStyle="SingleBorderWindow" SizeToContent="Height" MinHeight="235" Style="{StaticResource Window}" MaxHeight="800" Width="383">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <local:SliceControl Slice="False" x:Name="DialogImage" Source="/Resources/Universal/Dialog/icons.png" HorizontalAlignment="Left" Width="48" DefaultIndex="0" IsHitTestVisible="False" HoverIndex="-1" PressedIndex="-1" ElementCount="29" StackDirection="Horizontal" Panel.ZIndex="10" Grid.RowSpan="2" VerticalAlignment="Top" Margin="11,10,0,0"/>
        <!-- Top Header Section -->
        <Grid Grid.Row="0" Panel.ZIndex="0" Height="45">
            <Border Name="GradientTop" BorderThickness="0,0,0,1" BorderBrush="#DADADA">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F2F2F2" Offset="0"/>
                        <GradientStop Color="#E6E6E6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <TextBlock Height="23" x:Name="Header" Text="Title goes here" Margin="70,3,0,0" FontFamily="Arial" FontWeight="Bold" Foreground="#333333" FontSize="13"/>
        </Grid>
        <!-- Content Section (grows with text) -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Image x:Name="BodyImg" Visibility="Collapsed"/>
            <ScrollViewer x:Name="tb" VerticalScrollBarVisibility="Auto" MaxHeight="600" HorizontalAlignment="Left" Width="260" Margin="77,7,10,7">
                <TextBlock LineHeight="16" TextWrapping="Wrap" Name="Description" Text="Message goes here" FontFamily="Tahoma" FontSize="11"/>
            </ScrollViewer>
        </Grid>
        <!-- Bottom Button Section -->
        <Grid Grid.Row="2" Height="44">
            <Border Name="GradientBottom" BorderThickness="0,1,0,0" BorderBrush="#DADADA">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F2F2F2" Offset="0"/>
                        <GradientStop Color="#E6E6E6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Grid x:Name="BottomControlsGrid">
                <TextBox x:Name="DialogTextBox" Visibility="Hidden" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Height="23" VerticalAlignment="Center" HorizontalAlignment="Left" FontFamily="Tahoma" FontSize="11" TextOptions.TextHintingMode="Fixed" Margin="10,0,0,0" Width="250"/>
                <Button Content="Exit" Click="bLClick" x:Name="ButtonLeft" Width="73" VerticalAlignment="Center" Visibility="Collapsed" HorizontalAlignment="Right" Margin="0,0,95,0" Height="23" FontFamily="Tahoma" FontSize="11"/>
                <Button Content="OK" Click="bRClick" IsDefault="True" x:Name="ButtonRight" Width="73" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" Height="23" FontSize="11" FontFamily="Tahoma"/>
            </Grid>
        </Grid>
    </Grid>
</Window>