<Window Style="{StaticResource Window}" x:Class="Skymu.Views.Notification" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:global="clr-namespace:Skymu"  xmlns:converters="clr-namespace:Skymu.Converters" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Notification" xmlns:properties="clr-namespace:Skymu.Properties" SizeToContent="Height" Width="240" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True" ShowActivated="False" FontFamily="Tahoma" FontSize="11">
    <Window.Resources>
        <converters:ThemeImageConverter x:Key="ThemeImageConverter"/>
    </Window.Resources>
    <Grid>
        <global:SliceControl x:Name="bubble" Source="../Skyaeris/Assets/Light/Notifications/bubble-orange.png" IsNineSlice="True" HorizontalAlignment="Stretch" StackDirection="Vertical" ElementCount="1" DefaultIndex="0"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Image Grid.Row="0" Margin="5,0,0,0" Stretch="Fill"
    Width="33"
    Height="15" Source="../Skyaeris/Assets/Light/Notifications/logo.png" VerticalAlignment="Center" HorizontalAlignment="Left">
            </Image>
            <Border Grid.Row="1" Padding="8,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <global:SliceControl Grid.Row="0" Grid.Column="0" x:Name="StatusIcon" Source="Assets/Universal/Icon Bitmap/skype-status.png" ElementCount="22" StackDirection="Horizontal" DefaultIndex="2" HorizontalAlignment="Left" Margin="0,0,4,0" HoverIndex="-1" PressedIndex="-1" Slice="false" Width="16"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TitleText" FontWeight="Normal" Foreground="Black" VerticalAlignment="Center" Text="Title"/>
                    <ContentControl Grid.Row="1" Grid.Column="1" x:Name="Message" Margin="0,1,0,6"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>