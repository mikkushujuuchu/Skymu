<Page x:Class="Skymu.Views.Pages.Updater"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Skymu.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Updater"
      FontFamily="Tahoma" FontSize="11"
      Style="{StaticResource Page}">

   
        <StackPanel Orientation="Vertical" VerticalAlignment="Top" Height="210">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="210">
                <TextBlock VerticalAlignment="Stretch" TextWrapping="Wrap" Name="Description" Text="There's a new version of Skype available. Update now to get the latest features and improvements." LineHeight="16" />
            </ScrollViewer>
            <Grid Name="ProgressGrid" HorizontalAlignment="Left" Visibility="Collapsed" Width="370" Margin="0,30,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- UpdateStatusText -->
                    <RowDefinition Height="Auto"/>
                    <!-- ProgressBar -->
                    <RowDefinition Height="Auto"/>
                    <!-- FileSize -->
                </Grid.RowDefinitions>
                <!-- Download status -->
                <TextBlock Name="UpdateStatusText" Grid.Row="0" Text="Update progress goes here" FontFamily="Tahoma" FontSize="11"/>
                <!-- Progress bar stretches to available width -->
                <ProgressBar x:Name="ProgBar" Margin="0,10,0,0" Grid.Row="1" Height="15" HorizontalAlignment="Stretch"/>
                <!-- File size aligned right -->
                <TextBlock Name="FileSize" Grid.Row="2" Text="File size 3233.5 KB" Visibility="Collapsed" HorizontalAlignment="Right" FontFamily="Tahoma" FontSize="11" Margin="0,4,0,0"/>
            </Grid>
        </StackPanel>
   
</Page>
