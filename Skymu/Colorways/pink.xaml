<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="Colorway.Name">Pink</sys:String>
    <sys:String x:Key="Colorway.Author">OmegaAOL</sys:String>
    <sys:String x:Key="Colorway.Description">A pink-accented variant of the default Skype colorway.</sys:String>
    <sys:Int32 x:Key="Colorway.Version">1</sys:Int32>
    <sys:Boolean x:Key="Colorway.IsDarkTheme">false</sys:Boolean>

    <LinearGradientBrush x:Key="Active.Titlebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FFE06BA8" />
        <GradientStop Offset="0.0634" Color="#FEF0F6" />
        <GradientStop Offset="0.0667" Color="#FED2E8" />
        <GradientStop Offset="1.0" Color="#FF8CC8" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Active.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FFC5DC" />
        <GradientStop Offset="1.0" Color="#FF8CC8" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Active.Menubar" Color="#FFC6DC" />
    <SolidColorBrush x:Key="Active.Background" Color="#FF8CC8" />

    <LinearGradientBrush x:Key="Inactive.Titlebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#f0f0f0" />
        <GradientStop Offset="0.0634" Color="#f8f8f8" />
        <GradientStop Offset="0.0667" Color="#f4f4f4" />
        <GradientStop Offset="1.0" Color="#d7d7d7" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Inactive.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#ebecf0" />
        <GradientStop Offset="1.0" Color="#d8dae1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Inactive.Menubar" Color="#f0edec" />
    <SolidColorBrush x:Key="Inactive.Background" Color="#d8dae1" />

    <SolidColorBrush x:Key="Background" Color="#F2D4E8" />
    <SolidColorBrush x:Key="Separator" Color="#E4E4E4" />
    <SolidColorBrush x:Key="Card.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Card.Border" Color="#26000000" />

    <SolidColorBrush x:Key="Text.VeryHighContrast" Color="#000000" />
    <SolidColorBrush x:Key="Text.HighContrast" Color="#333333" />
    <SolidColorBrush x:Key="Text.MediumContrast" Color="#666666" />
    <SolidColorBrush x:Key="Text.LowContrast" Color="#999999" />
    <SolidColorBrush x:Key="Text.VeryLowContrast" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Text.Hyperlink" Color="#CC0077" />
    <SolidColorBrush x:Key="Text.Highlight" Color="#FF44AA" />

    <SolidColorBrush x:Key="Metro.Background" Color="#FFF5FA" />
    <SolidColorBrush x:Key="Metro.Border" Color="#F0D0E4" />
    <SolidColorBrush x:Key="Metro.Sidebar.UserCountTab" Color="#FAF0F6" />
    <SolidColorBrush x:Key="Accent" Color="#EE0088" />

    <SolidColorBrush x:Key="Metro.Background.Tinted" Color="#FFFFF0F8" />
    <SolidColorBrush x:Key="Metro.Separator" Color="#FFE8D9E4" />
    <SolidColorBrush x:Key="Metro.Separator.Tinted" Color="#FFD8C8D4" />
    <SolidColorBrush x:Key="Metro.Avatar.Background" Color="#FFEEAAD4" />
    <SolidColorBrush x:Key="Metro.Text.VeryHighContrast" Color="#FF010101" />
    <SolidColorBrush x:Key="Metro.Text.HighContrast" Color="#FF2B2030" />
    <SolidColorBrush x:Key="Metro.Text.MediumContrast" Color="#FF6E5068" />
    <SolidColorBrush x:Key="Metro.Text.LowContrast" Color="#FFA888A0" />
    <SolidColorBrush x:Key="Metro.Text.Highlight" Color="#FF44AA" />

    <SolidColorBrush x:Key="Metro.Bubble" Color="#FDE8F4" />
    <SolidColorBrush x:Key="Metro.Bubble.Tinted" Color="#FCCFE8" />
    <SolidColorBrush x:Key="Message.Author.Me" Color="#999999" />
    <SolidColorBrush x:Key="Message.Author.Other" Color="#FF44AA" />
    <SolidColorBrush x:Key="Message.Author.Unread" Color="#FFCC11" />
    <SolidColorBrush x:Key="Message.Author.Forward" Color="#00cc88" />
    <SolidColorBrush x:Key="Message.Border" Color="#EDE4EA" />

    <SolidColorBrush x:Key="Chatbar.Divider" Color="#E8D9E4" />
    <SolidColorBrush x:Key="Sidebar.Header" Color="#E5E5E5" />
    <SolidColorBrush x:Key="Sidebar.Divider.Opaque" Color="#E6D9E2" />
    <SolidColorBrush x:Key="Sidebar.Divider.Translucent" Color="#D1C5C5C5" />

    <SolidColorBrush x:Key="Avatar.Border" Color="#80BBBBBB" />

    <SolidColorBrush x:Key="EmojiFlyout.Background" Color="#CC202020" />
    <SolidColorBrush x:Key="EmojiFlyout.Border" Color="#666666" />

    <SolidColorBrush x:Key="Settings.ActiveTab" Color="#FF44AA" />

    <LinearGradientBrush x:Key="Strip.Background" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#F2F2F2" />
        <GradientStop Offset="1" Color="#E6E6E6" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Metro.Strip.Background" Color="#E5E9EE" />

    <Color x:Key="Avatar.Shadow">#80A0A0A0</Color>
    <Color x:Key="WindowFrame.Button.Close.Glow">#FF0000</Color>
    <Color x:Key="WindowFrame.Button.Generic.Glow">#EE0088</Color>

</ResourceDictionary>