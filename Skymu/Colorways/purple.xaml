<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="Colorway.Name">Purple</sys:String>
    <sys:String x:Key="Colorway.Author">mikkushujuuchu</sys:String>
    <sys:String x:Key="Colorway.Description">A purple-accented variant of the default Skype colorway.</sys:String>
    <sys:Int32 x:Key="Colorway.Version">1</sys:Int32>
    <sys:Boolean x:Key="Colorway.IsDarkTheme">false</sys:Boolean>

    <LinearGradientBrush x:Key="Active.Titlebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FFaa87b8" />
        <GradientStop Offset="0.0634" Color="#f9f1f7" />
        <GradientStop Offset="0.0667" Color="#ead9ec" />
        <GradientStop Offset="1.0" Color="#c9a5d6" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Active.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#e5cfe1" />
        <GradientStop Offset="1.0" Color="#c9a5d6" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Active.Menubar" Color="#e5d0e1" />
    <SolidColorBrush x:Key="Active.Background" Color="#c9a5d6" />

    <LinearGradientBrush x:Key="Inactive.Titlebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#f0f0f0" />
        <GradientStop Offset="0.0634" Color="#f8f8f8" />
        <GradientStop Offset="0.0667" Color="#f4f4f4" />
        <GradientStop Offset="1.0" Color="#d7d7d7" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Inactive.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#eeebf0" />
        <GradientStop Offset="1.0" Color="#dbdae1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Inactive.Menubar" Color="#f0edec" />
    <SolidColorBrush x:Key="Inactive.Background" Color="#d8dae1" />

    <SolidColorBrush x:Key="Background" Color="#e4d9eb" />
    <SolidColorBrush x:Key="Separator" Color="#E4E4E4" />
    <SolidColorBrush x:Key="Card.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Card.Border" Color="#26000000" />

    <SolidColorBrush x:Key="Text.VeryHighContrast" Color="#000000" />
    <SolidColorBrush x:Key="Text.HighContrast" Color="#333333" />
    <SolidColorBrush x:Key="Text.MediumContrast" Color="#666666" />
    <SolidColorBrush x:Key="Text.LowContrast" Color="#999999" />
    <SolidColorBrush x:Key="Text.VeryLowContrast" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Text.Hyperlink" Color="#834696" />
    <SolidColorBrush x:Key="Text.Highlight" Color="#ad77c6" />
    <SolidColorBrush x:Key="Text.Header" Color="#9a51aa" />

    <SolidColorBrush x:Key="Metro.Background" Color="#fcf6fa" />
    <SolidColorBrush x:Key="Metro.Border" Color="#e2d6e7" />
    <SolidColorBrush x:Key="Metro.Sidebar.UserCountTab" Color="#FAF0F6" />
    <SolidColorBrush x:Key="Accent" Color="#9a51aa" />

    <SolidColorBrush x:Key="Message.Bubble.Me" Color="#f7f1f6" />
    <SolidColorBrush x:Key="Message.Bubble.Other" Color="#e7d7ec" />
    <SolidColorBrush x:Key="Message.Author.Me" Color="#999999" />
    <SolidColorBrush x:Key="Message.Author.Other" Color="#ad77c6" />
    <SolidColorBrush x:Key="Message.Author.Unread" Color="#ff778e" />
    <SolidColorBrush x:Key="Message.Author.Forward" Color="#7dbe85" />
    <SolidColorBrush x:Key="Message.Border" Color="#ebe5eb" />

    <SolidColorBrush x:Key="Chatbar.Divider" Color="#e2dbe5" />
    <SolidColorBrush x:Key="Sidebar.Header" Color="#E5E5E5" />
    <SolidColorBrush x:Key="Sidebar.Divider.Opaque" Color="#e2dbe3" />
    <SolidColorBrush x:Key="Sidebar.Divider.Translucent" Color="#D1C5C5C5" />

    <SolidColorBrush x:Key="Avatar.Border" Color="#80BBBBBB" />

    <SolidColorBrush x:Key="EmojiFlyout.Background" Color="#CC202020" />
    <SolidColorBrush x:Key="EmojiFlyout.Border" Color="#666666" />

    <SolidColorBrush x:Key="Settings.ActiveTab" Color="#ad77c6" />

    <LinearGradientBrush x:Key="Strip.Background" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#F2F2F2" />
        <GradientStop Offset="1" Color="#E6E6E6" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Metro.Strip.Background" Color="#e9e8ee" />

    <Color x:Key="Avatar.Shadow">#80A0A0A0</Color>
    <Color x:Key="WindowFrame.Button.Close.Glow">#ff0080</Color>
    <Color x:Key="WindowFrame.Button.Generic.Glow">#9a51aa</Color>

</ResourceDictionary>
