    <SolidColorBrush x:Key="Separator" Color="#E4E4E4" />
    <SolidColorBrush x:Key="Card.Background" Color="#FF36393F" />
    <SolidColorBrush x:Key="Card.Border" Color="#66262626" />

    <SolidColorBrush x:Key="Text.VeryHighContrast" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Text.HighContrast" Color="#FFDCDDDE" />
    <SolidColorBrush x:Key="Text.MediumContrast" Color="#FFB9BBBE" />
    <SolidColorBrush x:Key="Text.LowContrast" Color="#FF72767D" />
    <SolidColorBrush x:Key="Text.VeryLowContrast" Color="#FF40444B" />
