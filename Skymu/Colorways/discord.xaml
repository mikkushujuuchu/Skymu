        <GradientStop Offset="0" Color="#33343b" />
        <GradientStop Offset="1" Color="#25292e" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Metro.Strip.Background" Color="#323338" />

    <Color x:Key="Avatar.Shadow">#80000000</Color>
    <Color x:Key="WindowFrame.Button.Close.Glow">#ED4245</Color>
    <Color x:Key="WindowFrame.Button.Generic.Glow">#7289DA</Color>

</ResourceDictionary>