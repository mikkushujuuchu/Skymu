<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="Colorway.Name">Discord</sys:String>
    <sys:String x:Key="Colorway.Author">Discord, OmegaAOL</sys:String>
    <sys:String x:Key="Colorway.Description">Dark colorway using Discord's classic blurple colors.</sys:String>
    <sys:Int32 x:Key="Colorway.Version">1</sys:Int32>
    <sys:Boolean x:Key="Colorway.IsDarkTheme">true</sys:Boolean>

    <LinearGradientBrush x:Key="Active.Titlebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF4E5D94" />
        <GradientStop Offset="0.0634" Color="#FF5865A8" />
        <GradientStop Offset="0.0667" Color="#FF4E5D94" />
        <GradientStop Offset="1.0" Color="#FF3B4A7A" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Active.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF36393F" />
        <GradientStop Offset="1.0" Color="#FF2F3136" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Active.Menubar" Color="#FF2F3136" />
    <SolidColorBrush x:Key="Active.Background" Color="#FF2F3136" />

    <LinearGradientBrush x:Key="Inactive.Titlebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF292B2F" />
        <GradientStop Offset="0.0634" Color="#FF2F3136" />
        <GradientStop Offset="0.0667" Color="#FF292B2F" />
        <GradientStop Offset="1.0" Color="#FF202225" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Inactive.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF2F3136" />
        <GradientStop Offset="1.0" Color="#FF292B2F" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Inactive.Menubar" Color="#FF292B2F" />
    <SolidColorBrush x:Key="Inactive.Background" Color="#FF292B2F" />

    <SolidColorBrush x:Key="Background" Color="#FF2F3136" />
