    <SolidColorBrush x:Key="Message.Border" Color="#FF202225" />

    <SolidColorBrush x:Key="Chatbar.Divider" Color="#FF202225" />
    <SolidColorBrush x:Key="Sidebar.Header" Color="#FF292B2F" />
    <SolidColorBrush x:Key="Sidebar.Divider.Opaque" Color="#FF202225" />
    <SolidColorBrush x:Key="Sidebar.Divider.Translucent" Color="#AA202225" />
    <!--  TODO  -->
    <SolidColorBrush x:Key="Avatar.Border" Color="#807289DA" />

    <SolidColorBrush x:Key="EmojiFlyout.Background" Color="#CC18191C" />
