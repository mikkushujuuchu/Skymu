<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Colorway.Name">Metro Black</sys:String>
    <sys:String x:Key="Colorway.Author">Skype, OmegaAOL, Xaero</sys:String>
    <sys:String x:Key="Colorway.Description">Color theme of the dark mode that was used in the UWP version of Skype</sys:String>
    <sys:Int32 x:Key="Colorway.Version">1</sys:Int32>
    <sys:Boolean x:Key="Colorway.IsDarkTheme">true</sys:Boolean>

    <LinearGradientBrush x:Key="Active.Titlebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF007AAA" />
        <GradientStop Offset="0.0634" Color="#FF009ACC" />
        <GradientStop Offset="0.0667" Color="#FF007AAA" />
        <GradientStop Offset="1.0" Color="#FF005F88" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Active.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF021420" />
        <GradientStop Offset="1.0" Color="#FF010E17" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Active.Menubar" Color="#FF021420" />
    <SolidColorBrush x:Key="Active.Background" Color="#FF021420" />

    <LinearGradientBrush x:Key="Inactive.Titlebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF010E17" />
        <GradientStop Offset="0.0634" Color="#FF021420" />
        <GradientStop Offset="0.0667" Color="#FF010E17" />
        <GradientStop Offset="1.0" Color="#FF010B12" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Inactive.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF021420" />
        <GradientStop Offset="1.0" Color="#FF010E17" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Inactive.Menubar" Color="#FF010E17" />
    <SolidColorBrush x:Key="Inactive.Background" Color="#FF010E17" />

    <SolidColorBrush x:Key="Background" Color="#FF021420" />
    <SolidColorBrush x:Key="Separator" Color="#FF00AFF0" />
    <SolidColorBrush x:Key="Card.Background" Color="#FF000000" />
    <SolidColorBrush x:Key="Card.Border" Color="#33000000" />
    <SolidColorBrush x:Key="Accent" Color="#FF00AFF0" />

    <SolidColorBrush x:Key="Text.VeryHighContrast" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Text.HighContrast" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Text.MediumContrast" Color="#FF899299" />
    <SolidColorBrush x:Key="Text.LowContrast" Color="#FF4A5560" />
    <SolidColorBrush x:Key="Text.VeryLowContrast" Color="#FF021420" />
    <SolidColorBrush x:Key="Text.Hyperlink" Color="#FF00AFF0" />
    <SolidColorBrush x:Key="Text.Highlight" Color="#FF18B6F1" />
    <SolidColorBrush x:Key="Metro.Text.Highlight" Color="#00AFF0" />

    <SolidColorBrush x:Key="Metro.Background" Color="#FF021728" />
    <SolidColorBrush x:Key="Metro.Background.Tinted" Color="#FF021420" />
    <SolidColorBrush x:Key="Metro.Separator" Color="#FF002D3E" />
    <SolidColorBrush x:Key="Metro.Separator.Tinted" Color="#FF00AFF0" />
    <SolidColorBrush x:Key="Metro.Bubble" Color="#FF2C2B31" />
    <SolidColorBrush x:Key="Metro.Bubble.Tinted" Color="#FF2C2B31" />
    <SolidColorBrush x:Key="Metro.Border" Color="#FF002D3E" />
    <SolidColorBrush x:Key="Metro.Avatar.Background" Color="#FF84D9F8" />
    <SolidColorBrush x:Key="Metro.Sidebar.UserCountTab" Color="#FF021420" />
    <SolidColorBrush x:Key="Metro.Text.VeryHighContrast" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Metro.Text.HighContrast" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Metro.Text.MediumContrast" Color="#FF899299" />
    <SolidColorBrush x:Key="Metro.Text.LowContrast" Color="#FF899299" />

    <SolidColorBrush x:Key="Message.Author.Me" Color="#FF899299" />
    <SolidColorBrush x:Key="Message.Author.Other" Color="#FF00AFF0" />
    <SolidColorBrush x:Key="Message.Author.Unread" Color="#FFFFCC11" />
    <SolidColorBrush x:Key="Message.Author.Forward" Color="#FF00CC88" />
    <SolidColorBrush x:Key="Message.Border" Color="#FF002D3E" />

    <SolidColorBrush x:Key="Chatbar.Divider" Color="#FF00AFF0" />
    <SolidColorBrush x:Key="Sidebar.Header" Color="#FF021420" />
    <SolidColorBrush x:Key="Sidebar.Divider.Opaque" Color="#FF002D3E" />
    <SolidColorBrush x:Key="Sidebar.Divider.Translucent" Color="#AA002D3E" />
    <SolidColorBrush x:Key="Avatar.Border" Color="#8000AFF0" />

    <SolidColorBrush x:Key="EmojiFlyout.Background" Color="#CC010E17" />
    <SolidColorBrush x:Key="EmojiFlyout.Border" Color="#FF002D3E" />

    <SolidColorBrush x:Key="Settings.ActiveTab" Color="#FF00AFF0" />

    <LinearGradientBrush x:Key="Strip.Background" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#FF021E2E" />
        <GradientStop Offset="1" Color="#FF011520" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Metro.Strip.Background" Color="#FF021E2E" />

    <Color x:Key="Avatar.Shadow">#80000000</Color>
    <Color x:Key="WindowFrame.Button.Close.Glow">#FF0000</Color>
    <Color x:Key="WindowFrame.Button.Generic.Glow">#00AFF0</Color>
</ResourceDictionary>