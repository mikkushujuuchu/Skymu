<Window x:Class="Skymu.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Skymu"
        xmlns:properties="clr-namespace:Skymu.Properties"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" 
        Title="{Binding Source={x:Static properties:Settings.Default},
                           Path=BrandingName}" Closing="Login_Closing" Height="429" Width="526" ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow" Loaded="Login_Loaded"
        WindowStartupLocation="CenterScreen"
        Icon="/Skymu;component/Resources/Universal/Icon/skype.ico">
    <Window.Resources>
        <local:ThemeImageConverter x:Key="ThemeImageConverter"/>
        <Style x:Key="HoverUnderlineHyperlink" TargetType="{x:Type Hyperlink}">
            <Setter Property="Foreground" Value="{StaticResource Sk5Link}" />
            <Setter Property="TextDecorations" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Window.Background>
        <ImageBrush ImageSource="{Binding Source={x:Static properties:Settings.Default},Path=ThemeRoot,Converter={StaticResource ThemeImageConverter}, ConverterParameter='backgrounds/loginBackground.png'}" Stretch="Fill"/>
    </Window.Background>
    <Grid>
        <Image x:Name="BackgroundImg" Height="371" Width="510" Stretch="Fill" />

        <TextBlock x:Name="header" Text="{Binding Source={x:Static properties:Settings.Default},
                           Path=BrandingName,
                           StringFormat={}Welcome to {0}.}" Foreground="{StaticResource SkBlue}"
                   Height="32" HorizontalAlignment="Center" Margin="0,44,0,0"
                   VerticalAlignment="Top" FontFamily="Arial" FontWeight="Bold" FontSize="20" />
        <Image x:Name="throbber" Source="/Resources/Universal/Animations/login-throbber.png"
           Width="128"
           Height="128"
           Margin="0,0,0,48"
           RenderTransformOrigin="0.50785,0.5001" Visibility="Collapsed">

            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>

                    <RotateTransform x:Name="SpinnerRotate" Angle="0"/>

                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>

            <Image.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">

                            <DoubleAnimation
    Storyboard.TargetName="SpinnerRotate"
    Storyboard.TargetProperty="Angle"
    From="0"
    To="360"
    Duration="0:0:2.133333"
    RepeatBehavior="Forever"/>

                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Image.Triggers>

        </Image>
        <Grid x:Name="signInControls">
            <TextBlock x:Name="SkypeName" Text="Username" Height="28" HorizontalAlignment="Left"
                   Margin="136,140,0,0" VerticalAlignment="Top"
                   FontFamily="Tahoma" FontSize="11" FontWeight="Normal" />

            <TextBlock x:Name="protocolText" Text="Messaging service" Height="28" HorizontalAlignment="Left"
                   Margin="136,96,0,0" VerticalAlignment="Top"
                   FontFamily="Tahoma" FontSize="11" FontWeight="Normal" />

            <TextBlock x:Name="forgotPasswordLink" FontFamily="Tahoma" FontSize="11" FontWeight="Normal"
                   Height="28" HorizontalAlignment="Left" Margin="136,225,0,0"
                   VerticalAlignment="Top"><Hyperlink Style="{StaticResource HoverUnderlineHyperlink}"
                       NavigateUri="#" RequestNavigate="Hyperlink_RequestNavigate"><Run Text="Unable to login? Ask for help here!"/></Hyperlink></TextBlock>

            <TextBlock x:Name="Password" FontFamily="Tahoma" FontSize="11" FontWeight="Normal"
                   Height="28" HorizontalAlignment="Left" Margin="136,183,0,0"
                   Text="Password" VerticalAlignment="Top" />
            <ComboBox x:Name="comboProtocolBox" TextOptions.TextRenderingMode="ClearType" IsEditable="False"
                  TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Height="20"
                  HorizontalAlignment="Center" Margin="0,112,0,0" VerticalAlignment="Top" Width="240"
                  FontFamily="Tahoma" FontSize="11" SelectionChanged="ProtocolSelectionChanged" />
            <TextBox x:Name="usernameBox" TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display"
                 TextOptions.TextHintingMode="Fixed" Height="20" Margin="0,155,0,0" 
                 VerticalAlignment="Top" FontFamily="Tahoma" FontSize="11" Width="240" />
            <PasswordBox x:Name="passwordTokenBox" TextOptions.TextRenderingMode="ClearType"
                     TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Height="20"
                      Margin="0,198,0,0" VerticalAlignment="Top" Width="240"
                     FontFamily="Tahoma" FontSize="11" />

            <Canvas IsHitTestVisible="True">
                <Grid x:Name="BBuilderGrid" Margin="126,259,128,87" SnapsToDevicePixels="True" Canvas.Left="9"
                  Canvas.Top="-4" Width="240">
                    <TextBlock x:Name="SignIn" Grid.Column="1" IsHitTestVisible="False" Height="13" HorizontalAlignment="Center"
Margin="-1,6,0,0" TextOptions.TextRenderingMode="ClearType"
TextOptions.TextFormattingMode="Display" TextOptions.TextHintingMode="Fixed" Text="Sign in"
VerticalAlignment="Top" Panel.ZIndex="1" FontFamily="Tahoma" FontWeight="Bold" FontSize="11"
Foreground="#FF393A48" />
                    
                    <local:SliceControl
                    x:Name="LoginButton"
                    Grid.Row="0"
                    Cursor="Hand"
                    Source="{Binding Source={x:Static properties:Settings.Default},Path=ThemeRoot,Converter={StaticResource ThemeImageConverter}, ConverterParameter='Buttons/plain.png'}"
                    ElementCount="5"
                    StackDirection="Vertical"
                    DefaultIndex="0"
                    DisabledIndex="2"
                    IsEnabled="False"
                    HoverIndex="1"
                    PressedIndex="4"
                    Width="240" />
                    
                </Grid>
            </Canvas>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Footer panel -->
                <Rectangle x:Name="footerPanel"
                       Grid.Row="1"
                       Height="55"
                       Width="269"
                       Fill="#FFE5F7FD"
                       RadiusX="5"
                       RadiusY="5"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

                <!-- Checkboxes -->
                <StackPanel Grid.Row="1"
                        Margin="135,0,0,24"
                        VerticalAlignment="Bottom">

                    <CheckBox x:Name="autoSignInCheck"
                          Content="{Binding Source={x:Static properties:Settings.Default},
                      Path=BrandingName}"
    ContentStringFormat="{}Sign me in when {0} starts"
                          IsChecked="True"
                          FontFamily="Tahoma"
                          FontSize="11"
                          Height="16"
                          Margin="0,0,0,5"
                          TextOptions.TextRenderingMode="ClearType"
                          TextOptions.TextFormattingMode="Display"
                          TextOptions.TextHintingMode="Fixed"/>

                    <CheckBox x:Name="startupSeanKypeCheck"
                                                Content="{Binding Source={x:Static properties:Settings.Default},
                  Path=BrandingName}"
ContentStringFormat="{}Start {0} when computer starts"
                          FontFamily="Tahoma"
                          FontSize="11"
                          Height="16"
                          TextOptions.TextRenderingMode="ClearType"
                          TextOptions.TextFormattingMode="Display"
                          TextOptions.TextHintingMode="Fixed"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>