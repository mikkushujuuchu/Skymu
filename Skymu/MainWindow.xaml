                <local:SliceControl Source="/Resources/Universal/Window Frame/Aero/minimize.png" Style="{StaticResource WindowButtonStyle}" x:Name="minimize" Width="24" MouseEnter="TitleButton_MouseEnter" MouseLeave="TitleButton_MouseLeave" MouseLeftButtonDown="TitleButton_Pressed" MouseLeftButtonUp="TitleButton_Click"/>
