        StackDirection="Vertical"
        DefaultIndex="0"
        HoverIndex="1"
        PressedIndex="2"
        Text="Call"


        TextStartPositionX="26"
        TextFont="Arial"
        TextWeight="Bold"
        TextSize="13"
        TextColor="White"
        Width="81"
        LeftRightWidth="22"
        Margin="10,0,0,0" />
                                    <local:SliceControl
Source="/ResourcesLight/ChatWindow/btn_pill_small_add.png"
ElementCount="5"
StackDirection="Vertical"
DefaultIndex="0"
HoverIndex="1"


PressedIndex="2"
Width="44"
Slice="false"
Margin="10,0,0,0" />
