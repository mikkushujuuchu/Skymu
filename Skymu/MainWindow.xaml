                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="{Binding StartedBy, StringFormat='Call started by: {0}'}" FontSize="11" FontFamily="Tahoma" Foreground="#999999"/>
                <TextBlock Grid.Column="2" Text="{Binding Time, StringFormat=h:mm tt}" VerticalAlignment="Top" FontSize="11" FontFamily="Tahoma" Foreground="#999999" HorizontalAlignment="Left"/>
            </Grid>
        </DataTemplate>
        <!-- CallEndedItem Template -->
        <DataTemplate DataType="{x:Type plugin:CallEndedNotice}">
            <Grid Margin="0,9.5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="114"/>
                    <ColumnDefinition Width="430"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="{Binding Duration, StringFormat='Call ended, duration: {0}'}" FontSize="11" FontFamily="Tahoma" Foreground="#999999"/>
                <TextBlock Grid.Column="2" Text="{Binding Time, StringFormat=h:mm tt}" VerticalAlignment="Top" FontSize="11" FontFamily="Tahoma" Foreground="#999999" HorizontalAlignment="Left"/>
            </Grid>
        </DataTemplate>
        <!-- CONVERSATION ITEM TEMPLATE END -->
        <Style x:Key="NoInsetListBox" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer x:Name="ScrollViewer" Focusable="false" Padding="0" Margin="0" VerticalContentAlignment="Bottom">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
