<Window x:Class="Skymu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Skymu"
        xmlns:data="clr-namespace:MiddleMan;assembly=MiddleMan"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Title="Skype" Closing="MainWindow_Closing" Height="856" Width="1448" Deactivated="Window_Deactivated"
        StateChanged="Window_StateChanged" Activated="Window_Activated"
        Icon="/Skymu;component/UniversalResources/Icon/Skype.ico">
    <Window.Resources>
        <local:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageConverter"/>
        <local:IdentifierToColorConverter x:Key="IdToColorConverter"/>
        <local:ReplyIDToBoolConverter x:Key="ReplyCheckConverter"/>
        <local:StatusToTextConverter x:Key="StatIntToText"/>
        <Style x:Key="WindowButtonStyle" TargetType="Image">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>
        <Style x:Key="LongIconStyle" TargetType="Image">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Width" Value="36" />
        </Style>
        <DataTemplate x:Key="ContactItemTemplate">
            <Grid Margin="2,4,0,4" Height="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>


                <Grid Grid.Column="0" Grid.RowSpan="3" Width="32" Height="32" Margin="2,0,0,0">

                    <Border
        Background="Transparent"
        CornerRadius="0">
                        <Border.Effect>
                            <DropShadowEffect
                Color="#000000"
                BlurRadius="2"
                ShadowDepth="1"
    Direction="270"
                Opacity="0.50"/>
                        </Border.Effect>

                        <Grid>

                            <Image Stretch="UniformToFill"
       Source="{Binding ProfilePicture,
                        Converter={StaticResource ByteArrayToImageConverter}}" />
                            <!-- Inner border overlay -->
                            <Border
                BorderBrush="#80BBBBBB"
                BorderThickness="1"
                CornerRadius="0"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Status Icon -->
                <local:SliceControl
Grid.Column="1"
Source="/ResourcesLight/MainSidebar/ms_SkypeStatus_Small.png"
ElementCount="21"
StackDirection="Horizontal"
DefaultIndex="{Binding PresenceStatus}"
Margin="10,0,0,0"
HorizontalAlignment="Left"
HoverIndex="-1"
PressedIndex="-1"
Slice="false"
Width="14" Grid.Row="1"/>


                <!-- Contact Info -->

                <TextBlock x:Name="usernameText" Grid.Column="2" Grid.Row="1" Margin="10,0,0,0" Text="{Binding DisplayName}" 
                           FontSize="11"
                               FontFamily="Tahoma"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="statusText" Text="{Binding Status}" 
                               Grid.Column="2" Grid.Row="2" Margin="10,1,0,0"
                           FontSize="11"
    FontFamily="Tahoma"
                           Background="Transparent"
                           Foreground="#999999"
                           TextTrimming="CharacterEllipsis"/>



            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" 
                     Value="True">
                    <Setter TargetName="usernameText" Property="Foreground" Value="White"/>
                    <Setter TargetName="statusText" Property="Foreground" Value="#BABABA"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <DataTemplate x:Key="ConversationItemTemplate">
            <Grid Margin="0,9.5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="62"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="430"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Visibility="{Binding ReplyToID,
                        Converter={StaticResource ReplyCheckConverter}}" Grid.Row="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="78,0,0,2">
                    <Image Source="/ResourcesLight/ChatWindow/reply-arrow.png" Width="12" Margin="0,0,6,0" SnapsToDevicePixels="True" VerticalAlignment="Center" />
                    <TextBlock TextWrapping="NoWrap"
    TextTrimming="CharacterEllipsis" Width="400" FontSize="11" FontFamily="Tahoma" Foreground="#999999">
                        <TextBlock.Text>
                            <MultiBinding StringFormat='Replying to {0} - “{1}”'>
                                <Binding Path="ReplyToDN"/>
                                <Binding Path="ReplyBody"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="{Binding SentByDN}"
                   HorizontalAlignment="Right"
                   Margin="-1000,0,0,0"
                   FontSize="11"
                   FontFamily="Tahoma"
                   Foreground="{Binding SentByID,
                        Converter={StaticResource IdToColorConverter}}"/>

                <TextBlock Grid.Row="1" Grid.Column="2"
                   Width="430"
                   Text="{Binding Body}"
                   Padding="0,0,15,0"
                   FontSize="11"
                   VerticalAlignment="Top"
                   TextWrapping="Wrap"
                   FontFamily="Tahoma"
                   TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Row="1" Grid.Column="2"
                   Text="{Binding Duration, StringFormat='Call ended, duration: {0}'}"
                   FontSize="11"
                   FontFamily="Tahoma"
                   Foreground="#999999"/>

                <TextBlock Grid.Row="1" Grid.Column="2"
                   Text="{Binding StartedBy, StringFormat='Call started by: {0}'}"
                   FontSize="11"
                   FontFamily="Tahoma"
                   Foreground="#999999"/>

                <TextBlock Grid.Row="1" Grid.Column="3"
                   Text="{Binding Time, StringFormat=h:mm tt}"
                   FontSize="11"
                   FontFamily="Tahoma"
                   Foreground="#999999"/>
            </Grid>
        </DataTemplate>
        <Style x:Key="NoInsetListBox" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer x:Name="ScrollViewer"
                              Focusable="false"
                              Padding="0"
                              Margin="0">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="TitleBar" Height="30" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="121" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="1" x:Name="CaptionButtons" Margin="0,0,5,0">
                <Image Style="{StaticResource WindowButtonStyle}" x:Name="split" Margin="0" Width="26"
                       MouseEnter="TitleButton_MouseEnter" MouseLeave="TitleButton_MouseLeave"
                       MouseLeftButtonDown="TitleButton_Pressed" MouseLeftButtonUp="TitleButton_Click" />
                <Image Style="{StaticResource WindowButtonStyle}" x:Name="minimize" Width="24"
                       MouseEnter="TitleButton_MouseEnter" MouseLeave="TitleButton_MouseLeave"
                       MouseLeftButtonDown="TitleButton_Pressed" MouseLeftButtonUp="TitleButton_Click" />
                <Image Style="{StaticResource WindowButtonStyle}" x:Name="maximize" Width="24"
                       MouseEnter="TitleButton_MouseEnter" MouseLeave="TitleButton_MouseLeave"
                       MouseLeftButtonDown="TitleButton_Pressed" MouseLeftButtonUp="TitleButton_Click" />
                <Image Style="{StaticResource WindowButtonStyle}" x:Name="close" Width="42"
                       MouseEnter="TitleButton_MouseEnter" MouseLeave="TitleButton_MouseLeave"
                       MouseLeftButtonDown="TitleButton_Pressed" MouseLeftButtonUp="TitleButton_Click" />
            </StackPanel>
            <Grid Grid.Column="0" x:Name="IconText">
                <TextBlock
                    x:Name="TitleShadow" Text="{Binding WindowTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    Foreground="White"
                    VerticalAlignment="Top"
                    Margin="50,7,0,0"
                    Panel.ZIndex="2">
                    <TextBlock.Effect>
                        <BlurEffect
                            Radius="15.0"
                            KernelType="Gaussian" />
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock
                    x:Name="TitleShadow2" Text="{Binding WindowTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    Foreground="White"
                    VerticalAlignment="Top"
                    Margin="50,7,0,0"
                    Panel.ZIndex="2">
                    <TextBlock.Effect>
                        <BlurEffect
                            Radius="20.0"
                            KernelType="Gaussian" />
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock
                    x:Name="TitleShadow3" Text="{Binding WindowTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    Foreground="White"
                    VerticalAlignment="Top"
                    Margin="50,7,0,0"
                    Panel.ZIndex="2">
                    <TextBlock.Effect>
                        <BlurEffect
                            Radius="17.0"
                            KernelType="Gaussian" />
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock x:Name="TitleMain" Text="{Binding WindowTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="Black"
                           VerticalAlignment="Top"
                           Margin="50,7,0,0"
                           Panel.ZIndex="2">
                    <TextBlock.Effect>
                        <DropShadowEffect
                            ShadowDepth="0"
                            Direction="330"
                            Color="White"
                            Opacity="1"
                            BlurRadius="20" />
                    </TextBlock.Effect>
                </TextBlock>
                <Image Cursor="Hand" Style="{StaticResource LongIconStyle}" x:Name="tbli" MouseLeftButtonUp="tbli_Click"
                       Margin="8,0,0,0" />
            </Grid>
        </Grid>
        <Grid x:Name="WindowArea" MouseDown="WindowArea_MouseDown" Margin="8,30,8,8">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#c5defe" Offset="0.0"/>

                    <GradientStop Color="#8cbeff" Offset="0.12"/>

                    <GradientStop Color="#8cbeff" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="21" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Menu Grid.Row="0" Height="20" Background="Transparent" FontFamily="Tahoma" Name="menu1"
                  VerticalAlignment="Top" FontSize="11">
                <MenuItem Header="_Skype">
                    <MenuItem Header="Online Status" />
                    <Separator />
                    <MenuItem Header="Privacy..." />
                    <MenuItem Header="Account..." />
                    <MenuItem Header="Buy Skype Credit..." />
                    <Separator />
                    <MenuItem Header="Change Password..." />
                    <MenuItem Header="Sign Out" />
                    <MenuItem Header="Switch User" />
                    <MenuItem Header="Close" />
                </MenuItem>
                <MenuItem Header="C_ontacts">
                    <MenuItem Header="Add a Contact..." />
                    <MenuItem Header="New Contact..." />
                    <MenuItem Header="Search for Skype Users..." />
                    <MenuItem Header="Import Contacts..." />
                    <MenuItem Header="Create New Group..." />
                    <Separator />
                    <MenuItem Header="Contact Categories" />
                    <MenuItem Header="Show Outlook Contacts" />
                    <Separator />
                    <MenuItem Header="Remove from Contacts" />
                </MenuItem>
                <MenuItem Header="Co_nversation" />
                <MenuItem Header="_Call" />
                <MenuItem Header="_View" />
                <MenuItem Header="_Tools">
                    <MenuItem Header="Apps" Click="mn_Apps" />
                    <Separator />
                    <MenuItem Header="Change Language" Click="mn_Language" />
                    <Separator />
                    <MenuItem Header="Accessibility" Click="mn_Accessibility" />
                    <MenuItem Header="Share Skype with a Friend..." Click="mn_ShareWithFriend" />
                    <Separator />
                    <MenuItem Header="Skype Wi-Fi Access..." Click="mn_SkypeWifi" />
                    <Separator />
                    <MenuItem Header="Options..." Click="mn_Options" />
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="Get Help: Answers and Support" />
                    <MenuItem Header="Heartbeat (Skype Status)" />
                    <MenuItem Header="Welcome Screen" />
                    <Separator />
                    <MenuItem Header="Call Quality Guide" />
                    <MenuItem Header="Check for Updates" />
                    <MenuItem Header="Give feedback" />
                    <Separator />
                    <MenuItem Header="About Skype" />
                </MenuItem>
            </Menu>
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Fill="#8cbeff" />
            <Border Grid.Row="1" BorderBrush="Transparent" BorderThickness="4">
                <Grid x:Name="ContentArea">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SidebarColumn" MinWidth="190" Width="300" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" x:Name="Sidebar">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="64" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="22" />
                        </Grid.RowDefinitions>
                        <Grid x:Name="SidebarStatus" Grid.Row="0" VerticalAlignment="Top">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32" />
                                <RowDefinition Height="32" />

                            </Grid.RowDefinitions>
                            <local:SliceControl
                                Grid.Row="0"
                                x:Name="StatusBox"
                                Source="/ResourcesLight/MainSidebar/ms_Status_Top.png"
                                ElementCount="5"
                                StackDirection="Vertical"
                                DefaultIndex="0"
                                ButtonStateOnInit="Pressed"
                                IsRadioButton="True"
                                HoverIndex="-1"
                                PressedIndex="2"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Stretch" 
                                TextStartPositionX="43"
                                TextFont="Arial"
                                TextWeight="Bold"
                                TextSize="13"
                                TextColor="#FFFFFF"/>
                            <local:SliceControl
                                Grid.Row="0"
                                x:Name="StatusIcon"
                                Source="/ResourcesLight/MainSidebar/ms_SkypeStatus.png"
                                ElementCount="21"
                                StackDirection="Horizontal"
                                DefaultIndex="0"
                                HorizontalAlignment="Left"
                                Margin="9,0,0,0"
                                HoverIndex="-1"
                                PressedIndex="-1"
                                Slice="false"
                                Width="16"/>
                            <local:SliceControl
    Grid.Row="0"
    x:Name="SBHomeButton"
    Source="/ResourcesLight/MainSidebar/ms_HomeButton_Sprite.png"
    ElementCount="3"
    StackDirection="Horizontal"
    DefaultIndex="0"
                                ButtonStateOnInit="Pressed"
    HorizontalAlignment="Right"
    Margin="0,0,11,0"
                                IsHitTestVisible="False"
    HoverIndex="1"
    PressedIndex="2"
    Slice="false"
    Width="16"/>
                            <Image Grid.Row="0" Source="ResourcesLight/MainSidebar/ms_Status_DropArrow.png"
                                   Width="12"
                                   Height="16"
                                   IsHitTestVisible="True"
Cursor="Hand"
                                   HorizontalAlignment="Left"
                                   Margin="25,0,0,0"/>
                            <local:SliceControl
                                x:Name="SkypeCreditBox"
                                Grid.Row="1"
                                Source="/ResourcesLight/MainSidebar/ms_Status_Bottom.png"
                                ElementCount="5"
                                StackDirection="Vertical"
                                DefaultIndex="0"
                                HoverIndex="-1"
                                PressedIndex="-1"
                                Text="$ 0.00 - No subscription"
                                TextStartPositionX="34"
                                TextFont="Tahoma"
                                TextSize="11"
                                TextColor="#333333"
                                HorizontalAlignment="Stretch" />
                            <Image Grid.Row="1" Source="ResourcesLight/MainSidebar/ms_Credit.png"
                                   Width="16"
                                   Height="16"
                                   HorizontalAlignment="Left"
                                   Margin="9,0,0,0"/>
                        </Grid>
                        <Grid x:Name="SidebarTabs" Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <local:SliceControl
                                x:Name="btnContacts"
                                Grid.Column="0"
                                IsRadioButton="True"
                                Source="/ResourcesLight/MainSidebar/ms_Contacts.png"
                                ElementCount="5"
                                StackDirection="Vertical"
                                DefaultIndex="0"
                                HoverIndex="-1"
                                PressedIndex="-1"
                                Text="Contacts"
                                TextStartPositionX="30"
                                TextFont="Arial"
                                TextWeight="Bold"
                                TextSize="13"
                                TextColor="#333333"

                                HorizontalAlignment="Stretch" />
                            <local:SliceControl
                                x:Name="btnRecents"
                                Grid.Column="1"
                                IsRadioButton="True"
                                ButtonStateOnInit="Pressed"
                                Source="/ResourcesLight/MainSidebar/ms_Recents.png"
                                ElementCount="5"
                                StackDirection="Vertical"
                                DefaultIndex="0"
                                HoverIndex="-1"
                                PressedIndex="2"
                                Text="Recent"
                                TextStartPositionX="30"
                                TextFont="Arial"
                                TextWeight="Bold"
                                TextSize="13"
                                TextColor="#333333"
                                HorizontalAlignment="Stretch" />

                        </Grid>
                        <Border Grid.Row="3" Background="White" BorderBrush="#26000000"
                                BorderThickness="1,0,1,0">
                            <Grid x:Name="ContactsArea">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="31" />
                                    <RowDefinition Height="1" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="0" />
                                    <RowDefinition Height="1" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="1" />
                                </Grid.RowDefinitions>
                                <local:SliceControl
                                    Grid.Row="0"
                                    Cursor="IBeam"
                                    x:Name="PseudoSearchBox"
                                    Source="/ResourcesLight/MainSidebar/ms_SearchBox.png"
                                    ElementCount="2"
                                    StackDirection="Vertical"
                                    DefaultIndex="1"
                                    IsHitTestVisible="False"
                                    HoverIndex="-1"
                                    PressedIndex="0"
                                    HorizontalAlignment="Stretch" />
                                <TextBox
    Grid.Row="0"
    Cursor="IBeam"
    x:Name="SearchBox"
    GotKeyboardFocus="SearchBox_Focused"
    LostKeyboardFocus="SearchBox_Unfocused"
    Text="Search"
                                    BorderThickness="0"
    Padding="33,0,0,0"
    Background="Transparent"
    FontFamily="Tahoma"
    FontSize="11"
    Foreground="#999999"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    TextOptions.TextHintingMode="Fixed"
    HorizontalAlignment="Stretch"
    VerticalContentAlignment="Center"/>
                                <Rectangle Grid.Row="1" Height="1" Fill="#b4c0ce" />
                                <ListBox x:Name="ContactsList"  
    Grid.Row="2"        
    BorderThickness="0"
    Style="{StaticResource NoInsetListBox}"
    ItemTemplate="{StaticResource ContactItemTemplate}"
    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="True"
    SelectionChanged="ContactList_SelectionChanged"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" >
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="ItemBorder" Background="Transparent">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="ItemBorder" Property="Background">
                                                                    <Setter.Value>
                                                                        <ImageBrush ImageSource="/ResourcesLight/MainSidebar/ms_ContactListBgSelected.png" Stretch="Fill"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                                <Rectangle Grid.Row="4" Height="1" Fill="#b4c0ce" />
                                <local:SliceControl
                                    Grid.Row="5"
                                    Source="/ResourcesLight/MainSidebar/ms_CallPhones.png"
                                    ElementCount="5"
                                    StackDirection="Vertical"
                                    DefaultIndex="0"
                                    HoverIndex="1"
                                    PressedIndex="2"
                                    Text="Call phones"
                                    TextStartPositionX="32"
                                    TextFont="Arial"
                                    TextWeight="Bold"
                                    TextSize="13"
                                    TextColor="#333333"
                                    HorizontalAlignment="Stretch" />
                                <Rectangle Grid.Row="6" Height="1" Fill="#b4c0ce" />
                            </Grid>
                        </Border>
                        <Border
                            Grid.Row="4"
                            Background="#dce6f4"
                            BorderBrush="#26000000"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <TextBlock Text="Skymu Beta. All rights reserved."
                                       x:Name="GlobalUserCount"
                                       Margin="6,0,0,0"
                                       FontFamily="Tahoma"
                                       FontSize="11"
                                       Foreground="#999999"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>

                    </Grid>
                    <Rectangle x:Name="SkypeSplitter" Grid.Column="1" MouseLeftButtonDown="SkypeSplitter_Press"
                               MouseMove="SkypeSplitter_MouseMove" Fill="Transparent" Cursor="SizeWE" />
                    <Grid Grid.Column="2" x:Name="chatWindowArea" DataContext="{Binding SelectedItem, ElementName=ContactsList}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32" />
                            <RowDefinition x:Name="TopbarWindowRow" Height="120" />
                            <RowDefinition x:Name="MessageWindowRow" Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" x:Name="ChatTopbar" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="80"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <local:SliceControl
                            Grid.Column="0"
Source="/ResourcesLight/ChatWindow/blank-left-button.png"
ElementCount="5"
 x:Name="chatHeader"                               
StackDirection="Vertical"
DefaultIndex="0"
                          
HoverIndex="-1"
PressedIndex="-1"
TextStartPositionX="13"
Text="{Binding DisplayName}"                                
TextFont="Arial"
TextWeight="Bold"
TextSize="13"
TextColor="#333333"
HorizontalAlignment="Stretch" />

                            <local:SliceControl
                            Grid.Column="1"
Source="/ResourcesLight/ChatWindow/blank-right-button.png"
ElementCount="5"
 x:Name="ChatCloseButton"
MouseLeftButtonUp="ChatWindow_Close"
StackDirection="Vertical"
DefaultIndex="0"
                          
HoverIndex="-1"
PressedIndex="2"
TextStartPositionX="30"                          
Text="Close"                                
TextFont="Arial"
TextWeight="Bold"
TextSize="13"
TextColor="#333333"
HorizontalAlignment="Stretch" />

                            <Image Grid.Column="1" Source="/ResourcesLight/ChatWindow/icon-close.png"
Width="16"
Height="16"
IsHitTestVisible="False"
HorizontalAlignment="Left"
Margin="8,0,0,0"/>

                        </Grid>
                        <Grid Grid.Row="0" x:Name="HomeTopbar" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="128" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <local:SliceControl
                            Grid.Column="0"
Source="/ResourcesLight/ChatWindow/blank-left-button.png"
ElementCount="5"
 x:Name="MainPageButton"                               
StackDirection="Vertical"
DefaultIndex="0"
   IsRadioButton="True"    
                                ButtonStateOnInit="Pressed"
HoverIndex="-1"
PressedIndex="2"
TextStartPositionX="31"
Text="Skype Home"                                
TextFont="Arial"
TextWeight="Bold"
TextSize="13"
TextColor="#333333"
HorizontalAlignment="Stretch" />
                            <Image Grid.Column="0" Source="/ResourcesLight/ChatWindow/settings_skype.png"
       Width="16"
                                   IsHitTestVisible="False"
       Height="16"
       HorizontalAlignment="Left"
       Margin="8,0,0,0"/>
                            <local:SliceControl
                            Grid.Column="1"
Source="/ResourcesLight/ChatWindow/blank-square-button.png"
ElementCount="5"
 x:Name="ProfileButton"                               
StackDirection="Vertical"
DefaultIndex="0"
    IsRadioButton="True"                      
HoverIndex="-1"
PressedIndex="-1"
TextStartPositionX="31"
Text="Profile"                                
TextFont="Arial"
TextWeight="Bold"
TextSize="13"
TextColor="#333333"
HorizontalAlignment="Stretch" />
                            <Image Grid.Column="1" Source="/ResourcesLight/ChatWindow/info_pressed.png"
       Width="16"
                                   IsHitTestVisible="False"
       Height="16"
       HorizontalAlignment="Left"
