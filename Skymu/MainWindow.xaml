<Window x:Class="Skymu.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:Skymu" xmlns:properties="clr-namespace:Skymu.Properties" xmlns:plugin="clr-namespace:MiddleMan;assembly=MiddleMan" xmlns:diag="clr-namespace:System.Diagnostics;assembly=WindowsBase" xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" WindowStyle="None" FontFamily="Tahoma" FontSize="11" Style="{StaticResource Window}" Background="#8cbeff" AllowsTransparency="False" ResizeMode="CanResize" WindowStartupLocation="CenterScreen" Title="{Binding [sMAINMENU_SKYPE]}" Closing="MainWindow_Closing" Height="856" Width="1448" Deactivated="Window_Deactivated" StateChanged="Window_StateChanged" Activated="Window_Activated" DataContext="{StaticResource Lang}">
    <Window.Resources>
        <Style x:Key="MessageTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="430"/>
            <Setter Property="Padding" Value="0,0,15,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <local:ByteArrayToImageSourceConverter x:Key="ProfilePictureConverter"/>
        <local:MsgByteArrayToImageConverter x:Key="MsgByteArrayToImageConverter"/>
        <local:IdentifierToColorConverter x:Key="IdToColorConverter"/>
        <local:NullDependentVisibilityConverter x:Key="NullDependentVisibilityConverter"/>
        <local:NullDependentBoolean x:Key="NullDependentBoolean"/>
        <local:StatusToTextConverter x:Key="StatIntToText"/>
        <local:ThemeImageConverter x:Key="ThemeImageConverter"/>
        <local:ReplyBodyConverter x:Key="ReplyBodyConverter"/>
        <local:PresenceStatusConverter x:Key="PresenceStatusConverter"/>
        <local:TextStatusConverter x:Key="TextStatusConverter"/>
        <local:MsgIDMultiToVisibilityConverter x:Key="IDToVisibilityConverter"/>
        <local:FormatFullTextConverter x:Key="FormatFullTextConverter" TextBlockStyle="{StaticResource MessageTextBlockStyle}"/>
