            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <!-- User template -->
        <DataTemplate DataType="{x:Type plugin:User}">
            <Grid Margin="2,4,0,4" Height="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Profile picture -->
                <Grid Grid.Column="0" Grid.RowSpan="3" Width="32" Height="32" Margin="2,0,0,0">
                    <Border Background="Transparent" CornerRadius="0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="2" ShadowDepth="1" Direction="270" Opacity="0.50"/>
                        </Border.Effect>
                        <Grid>
                            <Image Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                        <Binding Path="ProfilePicture"/>
                                        <Binding Source="user"/>
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                            <Border BorderBrush="#80BBBBBB" BorderThickness="1" CornerRadius="0"/>
                        </Grid>
                    </Border>
                </Grid>
                <local:SliceControl Grid.Column="1" Grid.Row="1" Source="/Resources/Universal/Icon Bitmap/skype-status-small.png" ElementCount="22" StackDirection="Horizontal" DefaultIndex="{Binding PresenceStatus,
                Converter={StaticResource PresenceStatusConverter}}" Margin="10,0,0,0" HorizontalAlignment="Left" HoverIndex="-1" PressedIndex="-1" Slice="false" Width="14"/>
                <!-- Name + status text -->
                <TextBlock x:Name="usernameText" Grid.Column="2" Grid.Row="1" Margin="10,0,0,0" Text="{Binding DisplayName}" Style="{StaticResource ContactUsernameStyle}"/>
                <TextBlock x:Name="statusText" Grid.Column="2" Grid.Row="2" Margin="10,1,0,0" Style="{StaticResource ContactStatusStyle}" Text="{Binding Status, TargetNullValue=''}"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected,
            RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="usernameText" Property="Foreground" Value="White"/>
                    <Setter TargetName="statusText" Property="Foreground" Value="White"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <!-- Group template -->
        <DataTemplate DataType="{x:Type plugin:Group}">
            <Grid Margin="2,4,0,4" Height="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Profile picture -->
                <Grid Grid.Column="0" Grid.RowSpan="3" Width="32" Height="32" Margin="2,0,0,0">
                    <Border Background="Transparent" CornerRadius="0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="2" ShadowDepth="1" Direction="270" Opacity="0.50"/>
                        </Border.Effect>
                        <Grid>
                            <Image Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
