Source="/ResourcesLight/ChatWindow/btn_video_call.png"
ElementCount="5"
StackDirection="Vertical"
DefaultIndex="0"
HoverIndex="1"
PressedIndex="2"



Text="Video call"
TextStartPositionX="25"
TextFont="Arial"
TextWeight="Bold"
TextSize="13"
LeftRightWidth="22"
TextColor="White"
Width="98"/>

