                                        <Binding Source="group"/>
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                            <Border BorderBrush="#80BBBBBB" BorderThickness="1" CornerRadius="0"/>
                        </Grid>
                    </Border>
                </Grid>
                <local:SliceControl Grid.Column="1" Grid.Row="1" Source="/Resources/Universal/Icon Bitmap/skype-status-small.png" ElementCount="22" StackDirection="Horizontal" DefaultIndex="21" Margin="10,0,0,0" HorizontalAlignment="Left" HoverIndex="-1" PressedIndex="-1" Slice="false" Width="14"/>
                <!-- Name + member count -->
                <TextBlock x:Name="usernameText" Grid.Column="2" Grid.Row="1" Margin="10,0,0,0" Text="{Binding DisplayName}" Style="{StaticResource ContactUsernameStyle}"/>
                <TextBlock x:Name="statusText" Grid.Column="2" Grid.Row="2" Margin="10,1,0,0" Style="{StaticResource ContactStatusStyle}">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource TextStatusConverter}">
                            <Binding Path="Status"/>
                            <Binding Path="MemberCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected,
            RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="usernameText" Property="Foreground" Value="White"/>
                    <Setter TargetName="statusText" Property="Foreground" Value="White"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <!-- CONTACT ITEM TEMPLATE END -->
        <!-- CONVERSATION ITEM TEMPLATES START -->
        <!-- MessageItem Template -->
        <DataTemplate DataType="{x:Type plugin:Message}">
            <Grid x:Name="ConversationGrid" Margin="0,9.5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="98"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="430"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <!-- Reply header -->
                <VirtualizingStackPanel Visibility="{Binding ParentMessage,
                Converter={StaticResource NullDependentVisibilityConverter}}" Grid.Row="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="114,0,0,2">
                    <Image Source="{Binding Source={x:Static properties:Settings.Default},
                    Path=ThemeRoot,
                    Converter={StaticResource ThemeImageConverter},
                    ConverterParameter='Chat/reply-arrow.png'}" Width="12" Margin="0,0,6,0" SnapsToDevicePixels="True" VerticalAlignment="Center"/>
                    <TextBlock LineHeight="1" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Width="400" FontSize="11" FontFamily="Tahoma" Foreground="#999999">
                        <TextBlock.Text>
                            <MultiBinding StringFormat='Replying to {0} - "{1}"'>
                                <Binding Path="ParentMessage.Sender.DisplayName"/>
                                <Binding Path="ParentMessage.Text" Converter="{StaticResource ReplyBodyConverter}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </VirtualizingStackPanel>
                <!-- Sender name -->
                <TextBlock Grid.Row="1" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-1000,0,0,0" FontSize="11" Text="{Binding Sender.DisplayName}" FontFamily="Tahoma" Foreground="{Binding Sender.Identifier,
                       Converter={StaticResource IdToColorConverter}}">
                    <TextBlock.Visibility>
                        <MultiBinding Converter="{StaticResource IDToVisibilityConverter}">
                            <Binding Path="PreviousMessageIdentifier"/>
                            <Binding Path="Sender.Identifier"/>
                        </MultiBinding>
                    </TextBlock.Visibility>
                </TextBlock>
                <!-- Message body + attachment -->
                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Vertical">
                    <ContentControl Visibility="{Binding Text,
                    Converter={StaticResource NullDependentVisibilityConverter}}" Content="{Binding Text,
                    Converter={StaticResource FormatFullTextConverter}}"/>
                    <Image RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Left" Margin="0,0,0,0" MaxWidth="300" MaxHeight="300" Stretch="Uniform" Source="{Binding Attachments[0].File,
                       Converter={StaticResource MsgByteArrayToImageConverter}}" Visibility="{Binding Attachments,
                       Converter={StaticResource NullDependentVisibilityConverter}}"/>
                </StackPanel>
                <!-- Timestamp -->
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Time, StringFormat=h:mm tt}" VerticalAlignment="Top" FontSize="11" FontFamily="Tahoma" Foreground="#999999" HorizontalAlignment="Left"/>
            </Grid>
        </DataTemplate>
        <!-- CallStartedItem Template -->
        <DataTemplate DataType="{x:Type plugin:CallStartedNotice}">
            <Grid Margin="0,9.5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="114"/>
                    <ColumnDefinition Width="430"/>
