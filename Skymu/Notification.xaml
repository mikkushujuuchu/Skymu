<Window Style="{StaticResource Window}" x:Class="Skymu.Notification" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:Skymu" Title="Notification" xmlns:properties="clr-namespace:Skymu.Properties" Height="100" Width="240" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True" ShowActivated="False" FontFamily="Tahoma">
    <Window.Resources>
        <local:ThemeImageConverter x:Key="ThemeImageConverter"/>
    </Window.Resources>
    <Grid>
        <local:SliceControl x:Name="bubble" Source="/Resources/Light/Notifications/bubble-blue.png" HorizontalAlignment="Stretch" StackDirection="Vertical" ElementCount="1" DefaultIndex="0"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>
            <Image Grid.Row="0" Margin="7,0,0,0" Stretch="None" Source="/Resources/Universal/Branding/skype-notif.png" HorizontalAlignment="Left">
                <Image.LayoutTransform>
                    <ScaleTransform ScaleX="0.75" ScaleY="0.75"/>
                </Image.LayoutTransform>
            </Image>
            <Border Grid.Row="1" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <local:SliceControl Grid.Row="0" Grid.Column="0" x:Name="StatusIcon" Source="/Resources/Universal/Icon Bitmap/skype-status.png" ElementCount="23" StackDirection="Horizontal" DefaultIndex="0" HorizontalAlignment="Left" Margin="0,0,5,0" HoverIndex="-1" PressedIndex="-1" Slice="false" Width="16"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TitleText" FontWeight="Normal" Foreground="Black" FontSize="14" Text="Title"/>
                    <ContentControl Grid.Row="1" Grid.Column="1" x:Name="Message" Margin="0,3,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>