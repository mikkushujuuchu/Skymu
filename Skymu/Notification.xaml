<Window x:Class="Skymu.Notification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Skymu"
        Title="Notification" 
        Height="100" Width="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        FontFamily="Tahoma">
    <Grid>
    <local:SliceControl Source="/Resources/Light/Notifications/bubble-blue.png" HorizontalAlignment="Stretch" StackDirection="Vertical" ElementCount="1" DefaultIndex="0"/>
    
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>
            <Image Grid.Row="0" Source="/Resources/Universal/Branding/skype-white-small.png" HorizontalAlignment="Left"/> 
            <Border Grid.Row="1" Padding="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <local:SliceControl
    Grid.Row="0"
    x:Name="StatusIcon"
    Source="/Resources/Universal/Icon Bitmap/skype-status.png"
    ElementCount="22"
    StackDirection="Horizontal"
    DefaultIndex="0"
    HorizontalAlignment="Left"
    Margin="0,0,5,0"
    HoverIndex="-1"
    PressedIndex="-1"
    Slice="false"
    Width="16"/>
                        <TextBlock x:Name="TitleText" FontWeight="Bold" Foreground="Black" FontSize="14" Text="Title"/>
                    </StackPanel>
                    <TextBlock x:Name="MessageText" MaxHeight="30" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" Foreground="#666666" FontSize="11" Text="Message goes here"/>
                </StackPanel>
            </Border>
        </Grid>
        
    </Grid>
</Window>
