<Window
    x:Class="Skymu.Views.Dialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:local="clr-namespace:Skymu"
    Title="Dialog"
    Width="383"
    MinHeight="235"
    MaxHeight="800"
    ResizeMode="NoResize"
    SizeToContent="Height"
    Style="{StaticResource Window}"
    WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <converters:SharedAssetPathGenerator x:Key="SharedAssetPathGenerator" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <local:SliceControl
            x:Name="DialogImage"
            Grid.RowSpan="2"
            Width="48"
            Margin="11,10,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Panel.ZIndex="10"
            DefaultIndex="0"
            ElementCount="36"
            HoverIndex="-1"
            IsHitTestVisible="False"
            PressedIndex="-1"
            SliceMode="0"
            Source="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Dialog/icons.png'}"
            StackDirection="Horizontal" />
        <!--  Top Header Section  -->
        <Grid
            Grid.Row="0"
            Height="45"
            Panel.ZIndex="0">
            <Border
                Name="GradientTop"
                BorderBrush="#DADADA"
                BorderThickness="0,0,0,1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#F2F2F2" />
                        <GradientStop Offset="1" Color="#E6E6E6" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <TextBlock
                x:Name="Header"
                Height="23"
                Margin="70,3,0,0"
                FontFamily="Arial"
                FontSize="13"
                FontWeight="Bold"
                Foreground="{StaticResource Text.HighContrast}"
                Text="Title goes here" />
        </Grid>
        <!--  Content Section (grows with text)  -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Image
                x:Name="BodyImg"
                Width="250"
                Height="250"
                Visibility="Collapsed" />
            <ScrollViewer
                x:Name="tb"
                Width="260"
                MaxHeight="600"
                Margin="77,7,10,7"
                HorizontalAlignment="Left"
                VerticalScrollBarVisibility="Auto">
                <TextBlock
                    Name="Description"
                    FontFamily="Tahoma"
                    FontSize="11"
                    LineHeight="16"
                    Text="Message goes here"
                    TextWrapping="Wrap" />
            </ScrollViewer>
        </Grid>
        <!--  Bottom Button Section  -->
        <Grid Grid.Row="2" Height="44">
            <Border
                Name="GradientBottom"
                BorderBrush="#DADADA"
                BorderThickness="0,1,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#F2F2F2" />
                        <GradientStop Offset="1" Color="#E6E6E6" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Grid x:Name="BottomControlsGrid" Width="Auto">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="DialogTextBox"
                    Grid.Column="0"
                    Width="255"
                    Height="23"
                    Margin="15,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    FontFamily="Tahoma"
                    FontSize="11"
                    TextAlignment="Center"
                    TextOptions.TextHintingMode="Fixed"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />
                <CheckBox
                    x:Name="CheckBox"
                    Margin="15,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Content="{Binding [sF_CONFIRM_CBNOMORE], Source={StaticResource Lang}}"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Visibility="Collapsed" />
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        x:Name="ButtonLeft"
                        Height="23"
                        MinWidth="73"
                        Margin="0,0,10,0"
                        Padding="12,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="bLClick"
                        Content="Exit"
                        FontFamily="Tahoma"
                        FontSize="11"
                        Visibility="Collapsed" />
                    <Button
                        x:Name="ButtonMiddle"
                        Height="23"
                        MinWidth="73"
                        Margin="0,0,10,0"
                        Padding="12,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="bMClick"
                        Content="Something"
                        FontFamily="Tahoma"
                        FontSize="11"
                        Visibility="Collapsed" />
                    <Button
                        x:Name="ButtonRight"
                        Height="23"
                        MinWidth="73"
                        Margin="0,0,10,0"
                        Padding="12,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="bRClick"
                        Content="OK"
                        FontFamily="Tahoma"
                        FontSize="11"
                        IsDefault="True" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>