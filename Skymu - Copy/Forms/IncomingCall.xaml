<Window
    x:Class="Skymu.Views.IncomingCall"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:global="clr-namespace:Skymu"
    xmlns:preferences="clr-namespace:Skymu.Preferences"
    Title="Incoming Call"
    Width="385"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Tahoma"
    FontSize="11"
    MouseLeftButtonDown="OnDrag"
    ResizeMode="NoResize"
    ShowActivated="False"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Style="{StaticResource Window}"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Window.Resources>
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator" />
        <converters:SharedAssetPathGenerator x:Key="SharedAssetPathGenerator" />
    </Window.Resources>
    <Grid>
        <global:SliceControl
            HorizontalAlignment="Stretch"
            BottomHeight="18"
            DefaultIndex="0"
            ElementCount="1"
            LeftWidth="15"
            RightWidth="15"
            SliceMode="2"
            Source="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Incoming Call/background.png'}"
            TopHeight="12" />
        <Grid Margin="11,8,11,14">
            <Grid.RowDefinitions>
                <!--  Header  -->
                <RowDefinition Height="25" />
                <!--  Border  -->
                <RowDefinition Height="1" />
                <!--  Content  -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Image
                    Width="36"
                    Height="16"
                    Margin="8,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Source="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Branding/logo-incoming-call.png'}"
                    Stretch="Fill" />
                <Grid
                    Grid.Row="0"
                    Margin="0,0,5,0"
                    HorizontalAlignment="Right">
                    <global:SliceControl
                        DefaultIndex="0"
                        ElementCount="5"
                        HoverIndex="1"
                        MouseLeftButtonDown="OnClose"
                        PressedIndex="2"
                        SliceMode="0"
                        Source="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Incoming Call/round-button.png'}"
                        StackDirection="Vertical"
                        Tag="NoDrag"
                        Visibility="Visible" />
                    <Image
                        Width="12"
                        Height="16"
                        Source="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Incoming Call/close.png'}"
                        Tag="NoDrag" />
                </Grid>

            </Grid>
            <Rectangle Grid.Row="1" Fill="#DDDDDD" />

            <Grid Grid.Row="2" Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image
                    x:Name="CallerAvatar"
                    Grid.Column="0"
                    Height="70"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, Source='Profile Pictures/man.png'}" />
                <Grid Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock
                        x:Name="CallerName"
                        VerticalAlignment="Top"
                        FontFamily="Arial"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Saul Goodman calling" />
                    <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal">
                        <global:SliceControl
                            x:Name="Answer"
                            Width="Auto"
                            Margin="0,0,5,0"
                            DefaultIndex="0"
                            ElementCount="5"
                            HoverIndex="1"
                            MouseLeftButtonUp="OnAnswer"
                            PressedIndex="2"
                            RightWidth="14"
                            SliceMode="1"
                            Source="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Incoming Call/answer.png'}"
                            StackDirection="Vertical"
                            Tag="NoDrag"
                            Text="{Binding Source={StaticResource Lang}, Path=[sZAPBUTTON_ANSWER]}"
                            TextColor="White"
                            TextFont="Arial"
                            TextLeftMargin="25"
                            TextRightMargin="10"
                            TextSize="13"
                            TextWeight="Bold" />
                        <global:SliceControl
                            x:Name="Decline"
                            Width="Auto"
                            DefaultIndex="0"
                            ElementCount="5"
                            HoverIndex="1"
                            MouseLeftButtonUp="OnDecline"
                            PressedIndex="2"
                            RightWidth="14"
                            SliceMode="1"
                            Source="{Binding Converter={StaticResource SharedAssetPathGenerator}, Source='Incoming Call/decline.png'}"
                            StackDirection="Vertical"
                            Tag="NoDrag"
                            Text="{Binding Source={StaticResource Lang}, Path=[sZAPBUTTON_DECLINE]}"
                            TextColor="White"
                            TextFont="Arial"
                            TextLeftMargin="25"
                            TextRightMargin="10"
                            TextSize="13"
                            TextWeight="Bold" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>