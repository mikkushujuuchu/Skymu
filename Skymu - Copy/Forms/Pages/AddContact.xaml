<!-- TODO: Change assets path to Skype 4 -->
<Page
    x:Class="Skymu.Views.Pages.AddContact"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="clr-namespace:Skymu.Converters"
    xmlns:global="clr-namespace:Skymu"
    xmlns:local="clr-namespace:Skymu.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:pages="clr-namespace:Skymu.Views.Pages"
    DataContext="{Binding Path='AddContact', Source='pages'}"
    Title="Add a contact"
    FontFamily="Tahoma"
    Style="{StaticResource Page}">
    <Page.Resources>
        <Style TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <converters:ByteArrayToImageSourceConverter x:Key="ProfilePictureConverter" />
        <converters:MsgByteArrayToImageConverter x:Key="MsgByteArrayToImageConverter" />
        <converters:SenderToColorConverter x:Key="SenderToColorConverter" />
        <converters:NullDependentVisibilityConverter x:Key="NullDependentVisibilityConverter" />
        <converters:NullDependentMarginConverter x:Key="NullDependentMargin" />
        <converters:NullDependentBoolean x:Key="NullDependentBoolean" />
        <converters:StatusToTextConverter x:Key="StatIntToText" />
        <converters:ThemedAssetPathGenerator x:Key="ThemedAssetPathGenerator" />
        <converters:ForwardedMessageStatusConverter x:Key="ForwardedChecker" />
        <converters:HalfValueConverter x:Key="HalfValueConverter" />
        <converters:ReplyBodyConverter x:Key="ReplyBodyConverter" />
        <converters:ConnectionStatusConverter x:Key="ConnectionStatusConverter" />
        <converters:ChannelTypeConverter x:Key="ChannelTypeConverter" />
        <converters:TextStatusConverter x:Key="TextStatusConverter" />
        <converters:MsgIDMultiToVisibilityConverter x:Key="IDToVisibilityConverter" />
        <converters:PreviewVisibilityConverter x:Key="PreviewVisibilityConverter" />
        <converters:CompactConversationTypeConverter x:Key="CompactConversationTypeConverter" />
    </Page.Resources>
    <Grid
        Width="650"
        MinHeight="515"
        HorizontalAlignment="Left"
        VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid
            x:Name="FirstStepGrid"
            Grid.Row="0"
            Width="Auto"
            Height="Auto"
            Margin="0,10,0,0"
            Visibility="Visible"
            HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="346*"/>
                <ColumnDefinition Width="131*"/>
                <ColumnDefinition Width="131*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                x:Name="TopCaption"
                Grid.Row="0"
                FontFamily="Tahoma"
                FontSize="11"
                FontWeight="Bold"
                Margin="0,0,0,10"
                Text="{Binding Path='[sADDADDAFRIEND_SCR1_CAPTION]', Source={StaticResource Lang}}"
                Grid.ColumnSpan="2"/>
            <TextBlock
                x:Name="FindContactDetails"
                Grid.Row="1"
                FontFamily="Tahoma"
                FontSize="11"
                Margin="0,0,0,18"
                Text="{Binding Path='[sF_ADDFRIEND_FIND_LABEL]', Source={StaticResource Lang}}"
                TextWrapping="Wrap" Grid.ColumnSpan="2"/>
            <Grid
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,31,0,13"
                Grid.RowSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="255" />
                    <ColumnDefinition Width="122" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="UserDetailsInput"
                    Grid.Column="0"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Height="20"
                    Text="Sensei Wu"/>
                <Button
                    x:Name="UserFindBtn"
                    Grid.Column="1"
                    Click="FindFriend"
                    Content="{Binding Path='[sF_ADDFRIEND_FIND_BTN]', Source={StaticResource Lang}}"
                    FontFamily="Tahoma"
                    FontSize="11"
                    Height="23"
                    IsDefault="True"
                    IsEnabled="False"
                    Margin="8,0,0,0"/>
            </Grid>
            <TextBlock
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Grid.RowSpan="2"
                FontFamily="Tahoma"
                FontSize="11"
                Margin="0,15,0,26"
                Text="{Binding Path='[sF_SEARCH_MANDALAY_LB_INTRO]', Source={StaticResource Lang}}"
                TextWrapping="Wrap"/>
            <!--TODO: Progressbar accuracy-->
            <ProgressBar
                x:Name="FindPBar"
                Grid.Row="3"
                Width="Auto"
                Height="10"
                HorizontalAlignment="Stretch"
                Visibility="Collapsed"/>
            <TextBlock
                x:Name="SelectContactHint"
                Grid.Row="3"
                Margin="0,15,0,26"
                FontFamily="Tahoma"
                FontSize="11"
                FontWeight="Bold"
                Text="{Binding Path='[sAC_FOUND]', Source={StaticResource Lang}}"
                TextWrapping="Wrap"
                Visibility="Collapsed"/>
            <StackPanel
                x:Name="ErrorField"
                Grid.Row="4"
                Grid.ColumnSpan="2"
                Margin="0,35,0,0"
                Width="Auto"
                Height="Auto"
                Orientation="Vertical"
                Visibility="Collapsed">
                <global:SliceControl
                    x:Name="ErrorText"
                    Source="Assets/AddContact/warning.png"
                    Text="{Binding Path='[sF_ADDFRIEND_LABEL4]', Source={StaticResource Lang}}"
                    TextColor="Red"
                    TextFont="Tahoma"
                    TextLeftMargin="22"
                    TextSize="11"
                    TextWeight="Bold"/>
                <Grid Margin="20,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Foreground="Gray"
                        VerticalAlignment="Center"
                        Text="•"/>
                    <TextBlock
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        VerticalAlignment="Bottom"
                        Text="{Binding Path='[sF_ADDFRIEND_LABEL4_1]', Source={StaticResource Lang}}"
                        TextWrapping="Wrap"/>
                </Grid>
                <Grid Margin="20,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Foreground="Gray"
                        VerticalAlignment="Center"
                        Text="•"/>
                    <TextBlock
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        VerticalAlignment="Bottom"
                        TextWrapping="Wrap">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} {1}">
                                <Binding Path="[sF_ADDFRIEND_LABEL4_2]" Source="{StaticResource Lang}"/>
                                <Binding Path="[sF_ADDFRIEND_LABEL4_3]" Source="{StaticResource Lang}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>
                <Grid Margin="20,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Foreground="Gray"
                        VerticalAlignment="Center"
                        Text="•"/>
                    <TextBlock
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        VerticalAlignment="Bottom"
                        TextWrapping="Wrap"
                        Text="{Binding Path='[sF_ADDFRIEND_LABEL4_4]', Source={StaticResource Lang}}"/>
                </Grid>
                <global:SliceControl
                    Margin="0,25,0,0"
                    Source="Assets/AddContact/megaphone.png"
                    Text="{Binding Path='[sAC_INVITE_UNFOUND]', Source={StaticResource Lang}}"
                    TextColor="#0066ff"
                    TextLeftMargin="22"
                    TextSize="11"/>
            </StackPanel>
            <!-- TOOD: Accuracy -->
            <ListView
                x:Name="UserListView"
                Grid.Row="5"
                Grid.ColumnSpan="2"
                Visibility="Collapsed"
                SelectionChanged="UserListView_Selected"
                SelectionMode="Single">
                <ListView.View>
                    <GridView>
                        <GridViewColumn
                            Header="{Binding Path='[sF_SEARCH_FIELD_FULLNAME]', Source={StaticResource Lang}}"
                            DisplayMemberBinding="{Binding DisplayName}"
                            Width="150" />
                        <GridViewColumn
                            Header="{Binding Path='[sF_SEARCH_FIELD_USERNAME]', Source={StaticResource Lang}}"
                            DisplayMemberBinding="{Binding Username}"
                            Width="100" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
        <StackPanel
            x:Name="BottomField"
            Grid.Row="3"
            Margin="0,0,0,30"
            Height="Auto"
            Orientation="Vertical">
            <TextBlock
                x:Name="MoreThingsYouCanDoText"
                FontFamily="Tahoma"
                FontSize="11"
                FontWeight="Bold"
                Text="{Binding Path='[sAC_MORE_CAPTION]', Source={StaticResource Lang}}"/>
            <Separator
                Margin="0,10,0,8"/>
            <global:SliceControl
                Source="Assets/AddContact/plus.png"
                Text="{Binding Path='[sAC_MORE_ADDPSTN]', Source={StaticResource Lang}}"
                TextColor="#0066ff"
                TextFont="Tahoma"
                TextLeftMargin="22"
                TextSize="11"/>
            <global:SliceControl
                Margin="0,2,0,0"
                Source="Assets/AddContact/add.png"
                Text="{Binding Path='[sAC_MORE_IMPORT]', Source={StaticResource Lang}}"
                TextColor="#0066ff"
                TextFont="Tahoma"
                TextLeftMargin="22"
                TextSize="11"/>
            <global:SliceControl
                Margin="0,2,0,0"
                Source="Assets/AddContact/megaphone.png"
                Text="{Binding Path='[sAC_MORE_SHARE]', Source={StaticResource Lang}}"
                TextColor="#0066ff"
                TextFont="Tahoma"
                TextLeftMargin="22"
                TextSize="11"/>
        </StackPanel>
        <Grid
            x:Name="NextStepGrid"
            Grid.Row="0"
            Width="650"
            Height="Auto"
            Margin="0,10,0,0"
            HorizontalAlignment="Left"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock
                x:Name="TopCaptionNS"
                Grid.Row="0"
                FontFamily="Tahoma"
                FontSize="11"
                Margin="0,0,0,10"
                Text="{Binding Path='[sAC_ADD_CONFIRM_CAPTION]', Source={StaticResource Lang}}"/>
            <!-- Temp -->
            <TextBox
                x:Name="ContactMessage"
                Grid.Row="1"
                Width="250"
                FontFamily="Tahoma"
                Text="Hello, Skymu user here!" />
            <!-- Details of found contact -->
            <Border
                x:Name="FoundContactDetails"
                Grid.Row="2"
                Background="#FFF"
                BorderBrush="{StaticResource Card.Border}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,4,4">
                <Grid>
                    <Grid
                        Grid.Row="1"
                        Height="120">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!--  Profile picture column  -->
                        <Image
                            x:Name="CPAProfilePic"
                            Grid.Column="0"
                            Margin="4,4,5,9"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Stretch="UniformToFill">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource ProfilePictureConverter}">
                                    <Binding Source="FoundData" Path="ProfilePicture" />
                                    <Binding Source="FoundData" />
                                </MultiBinding>
                            </Image.Source>
                            <Image.Effect>
                                <DropShadowEffect
                                    BlurRadius="4"
                                    Direction="270"
                                    ShadowDepth="1"
                                    Color="{StaticResource Avatar.Shadow}" />
                            </Image.Effect>
                        </Image>
                        <!--  Information column  -->
                        <StackPanel
                            Grid.Column="1"
                            Margin="12,12"
                            Orientation="Vertical">
                            <!-- Display name -->
                            <TextBlock
                                Margin="9,0,0,0"
                                FontFamily="Tahoma"
                                FontSize="11"
                                Text="{Binding Path='DisplayName', Source='FoundData', TargetNullValue='Unnamed'}"
                                TextTrimming="CharacterEllipsis" />
                            <!--  Text status row ("I'm bored", etc)  -->
                            <StackPanel
                                Margin="0,0,0,15"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                Visibility="{Binding FoundData.Status, Converter={StaticResource NullDependentVisibilityConverter}}">
                                <Image
                                    Width="16"
                                    Height="16"
                                    Source="/Skyaeris/Assets/Universal/Chat/mood.png" />
                                <TextBlock
                                    Margin="9,0,0,0"
                                    FontFamily="Tahoma"
                                    FontSize="11"
                                    Text="{Binding FoundData.Status, TargetNullValue=''}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <!--  Time row for remote user. TODO: implement this in MiddleMan  -->
                            <StackPanel
                                x:Name="TimeRow"
                                Margin="0,0,0,15"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                                <Image
                                    Width="16"
                                    Height="16"
                                    Source="/Skyaeris/Assets/Universal/Chat/clock.png" />
                                <TextBlock
                                    Margin="9,0,0,0"
                                    FontFamily="Tahoma"
                                    FontSize="11"
                                    Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat={}{0:h:mm tt}}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <!--  Connection status row (online, offline, away, dnd)  -->
                            <StackPanel
                                x:Name="StatusRow"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal">
                                <global:SliceControl
                                    Width="14"
                                    Height="14"
                                    DefaultIndex="{Binding FoundData.ConnectionStatus, Converter={StaticResource ConnectionStatusConverter}}"
                                    ElementCount="22"
                                    Interactive="False"
                                    SliceMode="0"
                                    Source="/Skyaeris/Assets/Universal/Icon Bitmap/skype-status-small.png"
                                    StackDirection="Horizontal" />
                                <TextBlock
                                    Margin="11,0,0,0"
                                    FontFamily="Tahoma"
                                    FontSize="11"
                                    Text="{Binding FoundData.ConnectionStatus, Converter={StaticResource StatIntToText}}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <Grid
            x:Name="LastStepGrid"
            Grid.Row="0"
            Width="650"
            Height="Auto"
            Margin="0,10,0,0"
            HorizontalAlignment="Left"
            Visibility="Collapsed">
            <StackPanel Orientation="Vertical">
                <TextBlock
                    Text="I don't understand why I expеct MasuoTV"/>
                <TextBlock
                    Text="'Cause isn't it something that doesn't exist?"/>
                <TextBlock
                    Text="(hopefully the contact has been added"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
