    <Grid
        x:Name="MainGrid"
        Background="#FF00AFF0"
        ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  selector strip  -->
        <Grid Grid.Row="0" Background="#33000000">
            <StackPanel
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    x:Name="protocolText"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Effect="{StaticResource SkypeDropShadow}"
                    FontFamily="Segoe UI Historic"
                    FontSize="12"
                    Foreground="White"
                    Text="Sign in with" />
                <ComboBox
                    x:Name="comboProtocolBox"
                    Width="180"
                    Height="26"
                    Background="White"
                    BorderBrush="White"
                    FontFamily="Segoe UI Historic"
                    FontSize="12"
                    SelectionChanged="ProtocolSelectionChanged" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Width="720"
            Height="472"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            ClipToBounds="False">
            <Grid>

                <!--  N1 logo  -->
                <Image
                    x:Name="N1"
                    Height="61.75"
                    Margin="1,40,0,0"
                    VerticalAlignment="Top"
                    RenderTransformOrigin="0.5,0.5"
                    Source="{StaticResource SkypeIconWhite}">
                    <Image.RenderTransform>
                        <TranslateTransform x:Name="N1Transform" Y="152" />
                    </Image.RenderTransform>
                    <Image.Effect>
                        <StaticResource ResourceKey="FakeSlightSharpen" />
                    </Image.Effect>
                </Image>

                <!--  N2 Header  -->
                <Grid
                    x:Name="N2"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="N2Transform" Y="152" />
                    </Grid.RenderTransform>

                    <Label
                        Margin="0,125,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Background="{x:Null}"
                        Content="Sign in"
                        FontFamily="Segoe UI Historic"
                        FontSize="20"
                        Foreground="#FF38C4F9">
                        <Label.Effect>
                            <StaticResource ResourceKey="SkypeDropShadow" />
                        </Label.Effect>
                    </Label>

                    <Grid
                        x:Name="throbber"
                        Margin="0,120,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Visibility="Collapsed">
                        <Ellipse
                            Width="28"
                            Height="28"
                            Stroke="White"
                            StrokeThickness="3">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0" CenterX="14" CenterY="14" />
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Ellipse.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                RepeatBehavior="Forever"
                                                Storyboard.TargetName="SpinnerRotate"
                                                Storyboard.TargetProperty="Angle"
                                                From="0"
                                                To="360"
                                                Duration="0:0:1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <TextBlock
                        x:Name="header"
                        Margin="0,125,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Background="{x:Null}"
                        Effect="{StaticResource SkypeDropShadow}"
                        FontFamily="Segoe UI Historic"
                        FontSize="20"
                        Foreground="White" />
                </Grid>

                <!--  N3 pill  -->
                <Grid
                    x:Name="N3"
                    Margin="0,170,0,0"
                    VerticalAlignment="Top"
                    Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="N3Transform" Y="152" />
                    </Grid.RenderTransform>
                    <Grid x:Name="LoginControls">
                        <Border
                            Width="290"
                            Height="35"
                            HorizontalAlignment="Center"
                            Background="#FF0C7DAF"
                            CornerRadius="18">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI Historic"
                                FontSize="14"
                                Foreground="White"
                                Text="Token">
                                <TextBlock.Effect>
                                    <StaticResource ResourceKey="SkypeDropShadow" />
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Grid>

                <!--  N4 Login form  -->
                <Grid
                    x:Name="N4"
                    Margin="0,210,0,0"
                    VerticalAlignment="Top"
                    Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="N4Transform" Y="152" />
                    </Grid.RenderTransform>
                    <StackPanel Width="290" HorizontalAlignment="Center">
                        <TextBlock
                            x:Name="SkypeName"
                            Margin="4,0,0,3"
                            Effect="{StaticResource SkypeDropShadow}"
                            FontFamily="Segoe UI Historic"
                            FontSize="12"
                            Foreground="White"
                            Text="Skype Name" />
                        <Border
                            Height="33"
                            Margin="0,0,0,6"
                            Background="White"
                            CornerRadius="4">
                            <TextBox
                                x:Name="usernameBox"
                                Margin="8,0,8,0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Segoe UI Historic"
                                FontSize="13"
                                Foreground="#333" />
                        </Border>
                        <TextBlock
                            x:Name="Password"
                            Margin="4,0,0,3"
                            Effect="{StaticResource SkypeDropShadow}"
                            FontFamily="Segoe UI Historic"
                            FontSize="12"
                            Foreground="White"
                            Text="Password" />
                        <Border
                            Height="33"
                            Margin="0,0,0,4"
                            Background="White"
                            CornerRadius="4">
                            <PasswordBox
                                x:Name="passwordTokenBox"
                                Margin="8,0,8,0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Segoe UI Historic"
                                FontSize="13"
                                Foreground="#333" />
                        </Border>
                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                            <CheckBox
                                x:Name="SaveCredentials"
                                VerticalAlignment="Center"
                                Content="Remember me"
                                FontFamily="Segoe UI Historic"
                                FontSize="12"
                                Foreground="White" />
                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center">
                                <Hyperlink
                                    x:Name="forgotPasswordLink"
                                    FontFamily="Segoe UI Historic"
                                    FontSize="12"
                                    Foreground="White"
                                    NavigateUri="https://account.live.com/password/reset"
                                    RequestNavigate="Hyperlink_RequestNavigate">
                                    Forgot?
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                        <Border
                            Height="35"
                            Background="#FF0C7DAF"
                            CornerRadius="18">
                            <Button
                                x:Name="LoginButton"
                                Height="35"
                                Background="Transparent"
                                BorderBrush="{x:Null}"
                                BorderThickness="0"
                                Click="LoginButton_Click"
                                Content="Sign in"
                                Cursor="Hand"
                                FontFamily="Segoe UI Historic"
                                FontSize="14"
                                Foreground="White"
                                IsEnabled="False"
                                Opacity="0.4">
                                <Button.Effect>
                                    <StaticResource ResourceKey="SkypeDropShadow" />
                                </Button.Effect>
                            </Button>
                        </Border>
                    </StackPanel>
                </Grid>

                <!--  N5 Protocol icons  -->
                <Grid
                    x:Name="N5"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="N5Transform" Y="152" />
                    </Grid.RenderTransform>
                    <Image
                        Width="25"
                        Height="25"
                        Margin="1,133,0,0"
                        HorizontalAlignment="Center"
                        Opacity="1"
                        Source="{StaticResource SkypeIconWhite}">
                        <Image.Effect>
                            <StaticResource ResourceKey="FakeSlightSharpen" />
                        </Image.Effect>
                    </Image>
                    <Image
                        Width="25"
                        Height="25"
                        Margin="-77,132,0,0"
                        HorizontalAlignment="Center"
                        Opacity="1"
                        Source="{StaticResource DiscordIcon}">
                        <Image.Effect>
                            <StaticResource ResourceKey="FakeSlightSharpen" />
                        </Image.Effect>
                    </Image>
                    <Image
                        Width="25"
                        Height="25"
                        Margin="77,132,0,0"
                        HorizontalAlignment="Center"
                        Opacity="1"
                        Source="{StaticResource BlueskyIcon}">
                        <Image.Effect>
                            <StaticResource ResourceKey="FakeSlightSharpen" />
                        </Image.Effect>
                    </Image>
                </Grid>

                <!--  N6 Hyperlink footer  -->
                <Button
                    x:Name="N6"
                    Margin="313,339,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderBrush="{x:Null}"
                    BorderThickness="0"
                    Cursor="Hand"
                    Effect="{StaticResource SkypeDropShadow}"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <TranslateTransform x:Name="N6Transform" Y="152" />
                    </Button.RenderTransform>
                    <TextBlock
                        x:Name="footerPanel"
                        FontFamily="Segoe UI Historic"
                        FontSize="13"
                        Foreground="White"
                        MouseLeftButtonUp="FooterLink_Click"
                        Text="Join our Discord"
                        TextDecorations="Underline" />
                </Button>

                <!--  N7 Bottom  bar  -->
                <Grid
                    x:Name="N7"
                    Height="128"
                    Margin="0,388,0,0"
                    VerticalAlignment="Top"
                    Background="#FF0095CC"
                    RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="N7Transform" Y="172" />
                    </Grid.RenderTransform>
                    <Button
                        Margin="307,23,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderBrush="{x:Null}"
                        BorderThickness="0"
                        Content="Create an account"
                        Cursor="Hand"
                        Effect="{StaticResource SkypeDropShadow}"
                        FontFamily="Segoe UI Historic"
                        FontSize="13"
                        Foreground="White" />
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
