                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <DrawingImage x:Key="SkypeIconWhite">
            <DrawingImage.Drawing>
                <DrawingGroup ClipGeometry="M0,0 V384 H384 V0 H0 Z">
                    <GeometryDrawing Brush="#FFCCEFFC" Geometry="F1 M384,384z M0,0z M373.1,191.35Q373.1,153.6 359.05,120.95 343.7,86.4 320,62.7 295.7,38.4 262.4,23.7 227.2,9.6 192,9.6 176.65,9.6 157.45,12.8 133.75,0 106.9,0 62.1,0 31.35,32 0,63.35 0,108.15 0,136.3 13.45,160 10.25,177.3 10.25,191.35 10.25,227.85 24.95,262.4 39.05,295.7 63.35,320 87.05,343.7 120.95,359.05 153.6,373.1 192,373.1 209.9,373.1 223.35,370.55 247.7,384 276.5,384 321.9,384 352,352.65 384,321.9 384,276.5 384,248.95 369.9,224.65 373.1,206.7 373.1,191.35 M227.85,128Q212.5,111.35 185.6,111.35 168.3,111.35 158.7,118.4 149.1,125.45 149.1,136.95 149.1,153.6 183.7,160.65L225.9,170.25Q284.15,183.05 284.15,233.6 284.15,264.95 261.75,282.9 237.45,302.7 192.65,302.7 147.85,302.7 121.6,283.5 99.2,267.5 99.2,247.05 99.2,238.1 105.6,232.3 111.35,226.55 120.95,226.55 131.85,226.55 147.85,246.4 163.85,266.25 192.65,266.25 211.2,266.25 222.7,257.3 233.6,248.95 233.6,237.45 233.6,219.5 211.85,214.4L154.25,199.7Q99.85,186.25 99.85,139.5 99.85,105.6 128,88.3 152.3,72.95 188.8,72.95 220.15,72.95 247.05,87.7 275.2,103.05 275.2,124.15 275.2,133.1 268.15,138.9 261.75,144 252.15,144 243.2,144 227.85,128z" />
