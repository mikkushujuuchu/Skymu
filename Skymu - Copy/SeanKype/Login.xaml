                            </SplineDoubleKeyFrame.KeySpline>
                        </SplineDoubleKeyFrame>
                        <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="0">
                            <SplineDoubleKeyFrame.KeySpline>
                                <KeySpline ControlPoint1="0.0,0.5" ControlPoint2="0.5,1.0" />
                            </SplineDoubleKeyFrame.KeySpline>
                        </SplineDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <!--  N2  -->
                    <DoubleAnimationUsingKeyFrames
                        BeginTime="0:0:0.0333333"
                        Storyboard.TargetName="N2Transform"
                        Storyboard.TargetProperty="Y">
                        <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="-15">
                            <SplineDoubleKeyFrame.KeySpline>
                                <KeySpline ControlPoint1="1.0,0.0" ControlPoint2="0.667,0.9" />
                            </SplineDoubleKeyFrame.KeySpline>
