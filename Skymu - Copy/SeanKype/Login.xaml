                <DrawingGroup ClipGeometry="M0,0 V136.00954 H154.4882 V0 H0 Z">
                    <DrawingGroup Opacity="1" Transform="1,0,0,1,-221.0349,-26.972274">
                        <GeometryDrawing Brush="#FFCCEFFC" Geometry="F1 M154.4882,136.00954z M0,0z M272.25197,162.84012C262.63197,163.91895 255.84769,158.66813 249.10066,152.81146 239.45673,144.44017 233.51372,131.96879 241.55522,122.19951 249.34449,112.73666 264.84087,110.42038 264.84087,110.42038 264.84087,110.42038 245.94464,112.90361 234.18096,102.4362 228.1818,97.098095 224.81683,90.117652 223.98265,82.041872 222.90961,71.653711 221.15962,50.39885 221.0389,42.551787 220.90243,33.680542 224.26529,27.750181 230.12525,27.097526 244.14729,25.535817 260.61915,38.72895 276.62601,58.238403 292.18378,77.200502 298.27902,90.613944 298.27902,90.613944 298.27902,90.613944 304.37423,77.200502 319.93202,58.238403 335.93886,38.72895 352.41072,25.535817 366.43276,27.097526 372.29273,27.750181 375.65558,33.680542 375.51912,42.551787 375.39846,50.39885 373.6484,71.653711 372.57536,82.041872 371.74118,90.117652 368.37622,97.098095 362.37705,102.4362 350.61337,112.90361 331.71714,110.42038 331.71714,110.42038 331.71714,110.42038 347.21352,112.73666 355.00281,122.19951 363.0443,131.96879 357.10128,144.44017 347.45735,152.81146 340.71033,158.66813 333.92604,163.91895 324.30605,162.84012 306.80788,160.87782 298.27902,128.26924 298.27902,128.26924 298.27902,128.26924 289.75014,160.87782 272.25197,162.84012z" />
