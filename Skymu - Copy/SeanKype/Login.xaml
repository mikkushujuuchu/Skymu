            </DrawingImage.Drawing>
        </DrawingImage>

        <DropShadowEffect
            x:Key="SkypeDropShadow"
            BlurRadius="2"
            Opacity="0.20"
            RenderingBias="Quality"
            ShadowDepth="1.5"
            Color="Black" />
        <DropShadowEffect
            x:Key="FakeSlightSharpen"
            BlurRadius="2.25"
            Opacity="0.3"
            RenderingBias="Quality"
            ShadowDepth="0"
            Color="#FF0088DE" />
        <GradientStop x:Key="AnimatedStop" Offset="0.95" Color="#FF00AFF0" />

    </Window.Resources>

