                        Background="Transparent"
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource SidebarItemStyle}"
                        ItemTemplateSelector="{StaticResource SidebarSelector}"
                        ScrollViewer.CanContentScroll="False"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.IsDeferredScrollingEnabled="False"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        SelectionChanged="ConversationList_SelectionChanged">
                        <ListBox.Resources>
                            <Style BasedOn="{StaticResource SidebarScrollBarStyle}" TargetType="ScrollBar" />
                        </ListBox.Resources>
                    </ListBox>
                </Grid>

            </Grid>
        </Grid>

        <!--  ====== GRID SPLITTER ======  -->
        <GridSplitter
            Grid.Column="1"
            Width="6"
            Margin="-5,-2.5,0,-2.5"
            HorizontalAlignment="Center"
            Panel.ZIndex="2"
            Background="{DynamicResource SkLightGraySep2}"
            BorderBrush="Transparent"
            BorderThickness="2.5"
            ResizeBehavior="PreviousAndNext"
            ShowsPreview="False" />

        <!--  ====== RIGHT COLUMN ======  -->
        <Grid Grid.Column="2" Margin="-5,0,0,0">
            <WebBrowser x:Name="browser" Visibility="Collapsed" />
            <Frame
                x:Name="HomeUnavailable"
                Grid.Row="1"
                Visibility="Collapsed" />
        </Grid>
        <Grid
            x:Name="RightColumn"
            Grid.Column="2"
            Margin="-5,0,0,0">

            <!--  Chat header  -->
            <Border
                VerticalAlignment="Top"
                Panel.ZIndex="2"
                Background="{DynamicResource SkLight}"
                BorderBrush="{DynamicResource SkLightGraySep2}"
                BorderThickness="0,0,0,1">
                <Grid
                    Width="auto"
                    Height="100"
                    VerticalAlignment="Top"
                    Background="{DynamicResource SkWhite2}">
                    <Ellipse
                        Width="60"
                        Height="60"
                        Margin="10,10,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                        <Ellipse.Fill>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Grid Background="{DynamicResource SkWashedBlue}">
                                        <Image
                                            x:Name="ChatHeaderAvatar"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{DynamicResource DefaultProfileDrawingImage}"
                                            Stretch="UniformToFill" />
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Label
                        x:Name="LabelUsername1"
                        Width="250"
                        Height="39"
                        Margin="99.3,11,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Content=""
                        FontSize="21"
                        FontWeight="UltraLight"
                        Foreground="{DynamicResource SkBlack}">
                        <Label.LayoutTransform>
                            <ScaleTransform ScaleX="1.05" />
                        </Label.LayoutTransform>
                    </Label>
                    <TextBlock
                        x:Name="LabelStatus1"
                        Margin="104,47,305,37"
                        FontFamily="Segoe UI Historic"
                        FontSize="11"
                        Foreground="{DynamicResource SkMidGray}"
                        Text=""
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap">
                        <TextBlock.LayoutTransform>
                            <ScaleTransform ScaleX="1.09" />
                        </TextBlock.LayoutTransform>
                    </TextBlock>
                    <!--  add contact button  -->
                    <Ellipse
                        Width="40"
                        Height="40"
                        Margin="0,20,20,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Stroke="{StaticResource Accent}"
                        StrokeThickness="2">
                        <Ellipse.Fill>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Image
                                        RenderOptions.BitmapScalingMode="LowQuality"
                                        Source="{DynamicResource AddDrawingImage}"
                                        Stretch="Uniform" />
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!--  speed indicator  -->
                    <global:SliceControl
                        x:Name="WifiButton"
                        Width="44"
                        Margin="10,0,0,0"
                        Command="{Binding DataContext.RunSpeedTestCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        DefaultIndex="0"
                        ElementCount="5"
                        HoverIndex="1"
                        PressedIndex="2"
                        SliceMode="0"
                        Source="{Binding Converter={StaticResource ThemedAssetPathGenerator}, ConverterParameter=Pontis, Source='Chat/network-none.png'}"
                        StackDirection="Vertical" />
                    <!--  Video call button  -->
                    <!--  TODO change to SliceControl "{Binding VideoCallCommand}"  -->
                    <Ellipse
                        x:Name="VideoCallButton"
                        Width="40"
                        Height="40"
                        Margin="0,20,130,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Cursor="Hand">
                        <Ellipse.Fill>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Grid Background="{StaticResource Accent}">
                                        <Image
                                            RenderOptions.BitmapScalingMode="LowQuality"
                                            Source="/SeanKype/Assets/VideoCall.png"
                                            Stretch="Uniform" />
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!--  Voice call button  -->
                    <!--  TODO change to SliceControl "{Binding CallCommand}"  -->
                    <Ellipse
                        x:Name="VoiceCallButton"
                        Width="40"
                        Height="40"
                        Margin="0,20,75,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Cursor="Hand">
                        <Ellipse.Fill>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Grid Background="{StaticResource Accent}">
                                        <Image
                                            RenderOptions.BitmapScalingMode="LowQuality"
                                            Source="/SeanKype/Assets/VoiceCall.png"
                                            Stretch="Uniform" />
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!--  Loading throbber  for loadimg. TODO make spin  -->
                    <Grid
                        x:Name="throbber"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                        <Ellipse
                            Width="28"
                            Height="28"
                            Stroke="{StaticResource Accent}"
                            StrokeThickness="3">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="ThrobberRotate" Angle="0" CenterX="14" CenterY="14" />
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Ellipse.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                RepeatBehavior="Forever"
                                                Storyboard.TargetName="ThrobberRotate"
                                                Storyboard.TargetProperty="Angle"
                                                From="0"
                                                To="360"
                                                Duration="0:0:1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                </Grid>
            </Border>

            <!--  message feed  -->
            <ScrollViewer
                x:Name="MessageScrollFeed"
                Margin="0,101,0,130"
                Loaded="MessageScrollFeed_Loaded">
                <ItemsControl
                    x:Name="ConversationItemsList"
                    HorizontalAlignment="Stretch"
                    ItemTemplate="{StaticResource MessageTemplate}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </ScrollViewer>

            <!--  message input area  -->
            <Grid
                Width="auto"
                Height="130"
                VerticalAlignment="Bottom"
                Background="{DynamicResource SkWhite2}">
                <StackPanel
                    x:Name="TypingIndicator"
                    Height="16"
                    Margin="15,5,115,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="TypingIndicatorText"
                        VerticalAlignment="Center"
                        FontFamily="Segoe UI Historic"
                        FontSize="10"
                        FontStyle="Italic"
                        Foreground="{DynamicResource SkMidGray}" />
                </StackPanel>
                <Image
                    x:Name="EmojiButton"
                    Width="20"
                    Height="20"
                    Margin="15,28,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Cursor="Hand"
                    MouseLeftButtonUp="EmojiButton_Click"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="/Skyaeris/Assets/Light/Chat/emoji.png"
                    ToolTip="Emoji" />
                <Popup
                    x:Name="EmojiFlyout"
                    AllowsTransparency="True"
                    HorizontalOffset="-20"
                    Placement="Top"
                    PlacementTarget="{Binding ElementName=EmojiButton}"
                    StaysOpen="False">
                    <Border
                        Padding="2"
                        Background="{StaticResource EmojiFlyout.Background}"
                        BorderBrush="{StaticResource EmojiFlyout.Border}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ScrollViewer
                            MaxWidth="257"
                            MaxHeight="278"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Visible">
                            <WrapPanel x:Name="EmojiWrapPanel" Orientation="Horizontal" />
                        </ScrollViewer>
                    </Border>
                </Popup>
                <Rectangle
                    Height="1"
                    Margin="17,57,17,0"
                    VerticalAlignment="Top"
                    Fill="{DynamicResource SkDarkBlue}"
                    Stroke="{DynamicResource SkDarkBlue}" />
                <Ellipse
                    Width="32"
                    Height="32"
                    Margin="0,87,17,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Cursor="Hand"
                    MouseLeftButtonUp="SendButton_Click">
                    <Ellipse.Fill>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Grid Background="{StaticResource Accent}">
                                    <Image
                                        RenderOptions.BitmapScalingMode="LowQuality"
                                        Source="/SeanKype/Assets/Send.png"
                                        Stretch="Uniform" />
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <TextBox
                    x:Name="TextBoxMessage"
                    Margin="15,65,117,17"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    FontFamily="Segoe UI Historic"
                    FontSize="13"
                    FontStretch="Normal"
                    Foreground="{DynamicResource SkBlack}"
                    KeyDown="TextBoxMessage_KeyDown" />
            </Grid>

        </Grid>
    </Grid>
</Window>

