        <!--  Chat message DataTemplate...one group represnents one bubble  -->
        <DataTemplate x:Key="MessageTemplate" DataType="{x:Type vm:MessageGroup}">
            <Grid Margin="0,12,0,0" HorizontalAlignment="Stretch">

                <!--  RECIEVED BUBBLE  -->
                <StackPanel
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Visibility="{Binding Sender.Identifier, Converter={StaticResource SenderToReceivedVis}}">
                    <Ellipse
                        Width="36"
                        Height="36"
                        Margin="18,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                        <Ellipse.Fill>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Grid Background="{DynamicResource SkWashedBlue}">
                                        <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill">
                                            <Image.Source>
                                                <MultiBinding Converter="{StaticResource ByteArrayToImage}">
                                                    <Binding Path="Sender.ProfilePicture" />
                                                    <Binding Source="user" />
                                                </MultiBinding>
                                            </Image.Source>
                                        </Image>
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <StackPanel Orientation="Vertical">
                        <!--  (sender name above bubble in groups)  -->
                        <TextBlock
                            Margin="18,0,0,2"
                            FontFamily="Segoe UI Historic"
                            FontSize="11"
                            Foreground="{DynamicResource SkSteelBlue}"
                            Text="{Binding Sender.DisplayName}"
                            Visibility="{Binding ShowSenderName, Converter={StaticResource BoolToVis}}" />
                        <StackPanel Orientation="Horizontal">
                            <Image
                                Width="4.9"
                                Height="20"
                                Margin="13,7.5,0,0"
                                VerticalAlignment="Top"
                                RenderOptions.BitmapScalingMode="Fant"
                                Source="{DynamicResource BubbleArrowLeftDrawingImage}"
                                Visibility="{Binding IsImageGroup, Converter={StaticResource BoolToInverseVis}}" />
                            <!--  border for the entire group of messages  -->
                            <Border
                                MaxWidth="415"
                                Padding="17,9,17,6"
                                Background="{DynamicResource SkBubble}"
                                CornerRadius="4.5"
                                Visibility="{Binding IsImageGroup, Converter={StaticResource BoolToInverseVis}}">
                                <ItemsControl ItemsSource="{Binding Messages}">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Margin="-1,0,0,3"
                                                FontFamily="Segoe UI Historic"
                                                FontSize="13"
                                                Foreground="{DynamicResource SkBlack2}"
                                                LineHeight="22"
                                                Text="{Binding Text}"
                                                TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                            <!--  Image attachment (received)  -->
                            <Border
                                Margin="13,0,0,0"
                                ClipToBounds="True"
                                CornerRadius="8"
                                Visibility="{Binding IsImageGroup, Converter={StaticResource BoolToVis}}">
                                <Image
                                    MaxWidth="300"
                                    MaxHeight="300"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="{Binding Messages[0].Attachments, Converter={StaticResource MsgByteArrayToImage}}"
                                    Stretch="Uniform" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!--  SENT BUBBLE  -->
                <StackPanel
                    Margin="0,0,78,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Visibility="{Binding Sender.Identifier, Converter={StaticResource SenderToSentVis}}">
                    <!--  Image attachment (sent)  -->
                    <Border
                        ClipToBounds="True"
                        CornerRadius="8"
                        Visibility="{Binding IsImageGroup, Converter={StaticResource BoolToVis}}">
                        <Image
                            MaxWidth="300"
                            MaxHeight="300"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Source="{Binding Messages[0].Attachments, Converter={StaticResource MsgByteArrayToImage}}"
                            Stretch="Uniform" />
                    </Border>
                    <Border
                        MaxWidth="415"
                        Padding="17,9,17,6"
                        Background="{DynamicResource SkBubbleLight}"
                        CornerRadius="4.5"
                        Visibility="{Binding IsImageGroup, Converter={StaticResource BoolToInverseVis}}">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="-1,0,0,3"
                                        FontFamily="Segoe UI Historic"
                                        FontSize="13"
                                        Foreground="{DynamicResource SkBlack2}"
                                        LineHeight="22"
                                        Text="{Binding Text}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <Image
                        Width="6"
                        Height="20"
                        Margin="0,7.8,0,0"
                        VerticalAlignment="Top"
                        RenderOptions.BitmapScalingMode="Fant"
                        Source="{DynamicResource BubbleArrowRightDrawingImage}"
                        Visibility="{Binding IsImageGroup, Converter={StaticResource BoolToInverseVis}}" />
                </StackPanel>

                <!--  TimeStamp  -->
                <TextBlock
                    Margin="0,15,12,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    FontFamily="Segoe UI Historic"
                    FontSize="11"
                    Foreground="{DynamicResource SkSteelBlue}"
                    Text="{Binding Time, StringFormat=HH:mm}" />
            </Grid>
        </DataTemplate>

