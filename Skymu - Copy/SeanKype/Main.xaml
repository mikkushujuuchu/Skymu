        <Style x:Key="SidebarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#BBD6E0" BorderThickness="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType=ScrollBar}}" Value="Vertical">
                    <Setter Property="Width" Value="10" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType=ScrollBar}}" Value="Horizontal">
                    <Setter Property="Height" Value="10" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Background" Value="#00F5FCFE" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="RootGrid">
                            <Border x:Name="Rail" Background="{TemplateBinding Background}" />
                            <Track
                                x:Name="PART_Track"
                                Margin="-8,9,0,0"
                                IsDirectionReversed="True"
                                Maximum="{TemplateBinding Maximum}"
                                Minimum="{TemplateBinding Minimum}"
                                Orientation="{TemplateBinding Orientation}"
                                ViewportSize="{TemplateBinding ViewportSize}"
                                Value="{TemplateBinding Value}">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SidebarThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="RootGrid" Property="Width" Value="10" />
                                <Setter TargetName="Rail" Property="Width" Value="10" />
                                <Setter TargetName="PART_Track" Property="Width" Value="10" />
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="RootGrid" Property="Height" Value="10" />
                                <Setter TargetName="Rail" Property="Height" Value="10" />
                                <Setter TargetName="PART_Track" Property="Height" Value="10" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

