                Background="Transparent"
                Cursor="Hand">
                <Ellipse
                    Width="40"
                    Height="40"
                    Margin="15,5,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                    <Ellipse.Fill>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Grid Background="{DynamicResource SkWashedBlue}">
                                    <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill">
                                        <Image.Source>
                                            <MultiBinding Converter="{StaticResource ByteArrayToImage}">
                                                <Binding Path="Partner.ProfilePicture" />
                                                <Binding Source="user" />
                                            </MultiBinding>
                                        </Image.Source>
                                    </Image>
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Ellipse.Fill>
                </Ellipse>
