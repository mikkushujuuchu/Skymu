        <conv:ByteArrayToImageSourceConverter x:Key="ByteArrayToImage" />
        <conv:BoolToHiddenVisibilityConverter x:Key="BoolToHiddenVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
