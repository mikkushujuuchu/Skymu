<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="Theme.Name">New Discord</sys:String>
    <sys:String x:Key="Theme.Author">OmegaAOL</sys:String>
    <sys:String x:Key="Theme.Description">Dark theme using Discord's current blurple colors.</sys:String>
    <sys:Int32 x:Key="Theme.Version">1</sys:Int32>

    <LinearGradientBrush x:Key="Active.Titlebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF404ABE" />
        <GradientStop Offset="0.0634" Color="#FF4752C8" />
        <GradientStop Offset="0.0667" Color="#FF404ABE" />
        <GradientStop Offset="1.0" Color="#FF3540A8" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Active.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF313338" />
        <GradientStop Offset="1.0" Color="#FF2B2D31" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Active.Menubar" Color="#FF2B2D31" />
    <SolidColorBrush x:Key="Active.Background" Color="#FF2B2D31" />

    <LinearGradientBrush x:Key="Inactive.Titlebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF1E1F22" />
        <GradientStop Offset="0.0634" Color="#FF2B2D31" />
        <GradientStop Offset="0.0667" Color="#FF232428" />
        <GradientStop Offset="1.0" Color="#FF1E1F22" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Inactive.Window" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0" Color="#FF2B2D31" />
        <GradientStop Offset="1.0" Color="#FF232428" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Inactive.Menubar" Color="#FF232428" />
    <SolidColorBrush x:Key="Inactive.Background" Color="#FF232428" />

    <SolidColorBrush x:Key="Background" Color="#FF2B2D31" />
    <SolidColorBrush x:Key="Card.Background" Color="#FF313338" />
    <SolidColorBrush x:Key="Card.Border" Color="#26FFFFFF" />

    <SolidColorBrush x:Key="Text.VeryHighContrast" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Text.HighContrast" Color="#FFF2F3F5" />
    <SolidColorBrush x:Key="Text.MediumContrast" Color="#FFB5BAC1" />
    <SolidColorBrush x:Key="Text.LowContrast" Color="#FF80848E" />
    <SolidColorBrush x:Key="Text.VeryLowContrast" Color="#FF383A40" />
    <SolidColorBrush x:Key="Text.Hyperlink" Color="#FF5865F2" />
    <SolidColorBrush x:Key="Text.Highlight" Color="#FF5865F2" />
    <SolidColorBrush x:Key="Text.Header" Color="#FF5865F2" />

    <SolidColorBrush x:Key="Metro.Background" Color="#FF313338" />
    <SolidColorBrush x:Key="Metro.Border" Color="#FF1E1F22" />
    <SolidColorBrush x:Key="Metro.Sidebar.UserCountTab" Color="#FF2B2D31" />
    <SolidColorBrush x:Key="Accent" Color="#FF5865F2" />

    <SolidColorBrush x:Key="Message.Bubble.Me" Color="#FF35373C" />
    <SolidColorBrush x:Key="Message.Bubble.Other" Color="#FF383A40" />
    <SolidColorBrush x:Key="Message.Sender.Me" Color="#FFB5BAC1" />
    <SolidColorBrush x:Key="Message.Sender.Other" Color="#FF5865F2" />
    <SolidColorBrush x:Key="Message.Sender.Unread" Color="#FFFAA61A" />
    <SolidColorBrush x:Key="Message.Sender.Forward" Color="#FF23A559" />
    <SolidColorBrush x:Key="Message.Border" Color="#FF1E1F22" />

    <SolidColorBrush x:Key="Chatbar.Divider" Color="#FF1E1F22" />
    <SolidColorBrush x:Key="Sidebar.Header" Color="#FF232428" />
    <SolidColorBrush x:Key="Sidebar.Divider.Opaque" Color="#FF1E1F22" />
    <SolidColorBrush x:Key="Sidebar.Divider.Translucent" Color="#AA1E1F22" />
    <SolidColorBrush x:Key="Avatar.Border" Color="#805865F2" />

    <SolidColorBrush x:Key="EmojiFlyout.Background" Color="#CC111214" />
    <SolidColorBrush x:Key="EmojiFlyout.Border" Color="#FF1E1F22" />

    <Color x:Key="Avatar.Shadow">#80000000</Color>
    <Color x:Key="WindowFrame.Button.Close.Glow">#ED4245</Color>
    <Color x:Key="WindowFrame.Button.Generic.Glow">#5865F2</Color>

</ResourceDictionary>