<Application
    x:Class="Skymu.Universal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Skymu"
    xmlns:preferences="clr-namespace:Skymu.Preferences"
    ShutdownMode="OnExplicitShutdown"
    Startup="App_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/PresentationFramework.Aero;component/themes/Aero.NormalColor.xaml" />
                <ResourceDictionary Source="pack://siteoforigin:,,,/Themes/default.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <local:LanguageManager x:Key="Lang" />
            <Style
                x:Key="Window"
                BasedOn="{StaticResource {x:Type Window}}"
                TargetType="{x:Type Window}">
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
                <Setter Property="TextOptions.TextHintingMode" Value="Auto" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Source={x:Static preferences:Settings.Default}, Path=[UseClearType]}" Value="True">
                        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
                        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style
                x:Key="Page"
                BasedOn="{StaticResource {x:Type Page}}"
                TargetType="{x:Type Page}">
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
                <Setter Property="TextOptions.TextHintingMode" Value="Auto" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Source={x:Static preferences:Settings.Default}, Path=[UseClearType]}" Value="True">
                        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
                        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="Hyperlink">
                <!--  This fixes the red hyperlink hover color  -->
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource Text.Header}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style BasedOn="{x:Null}" TargetType="{x:Type MenuItem}">
                <!--  This fixes the horrible WPF Aero PresentationFramework menu items  -->
                <Style.Triggers>
                    <Trigger Property="Role" Value="TopLevelHeader">
                        <Setter Property="Height" Value="20" />
                        <Setter Property="MinHeight" Value="20" />
                        <Setter Property="MaxHeight" Value="20" />
                        <Setter Property="Padding" Value="6,3" />
                        <Setter Property="Margin" Value="0" />
                    </Trigger>
                    <Trigger Property="Role" Value="TopLevelItem">
                        <Setter Property="Height" Value="20" />
                        <Setter Property="MinHeight" Value="20" />
                        <Setter Property="MaxHeight" Value="20" />
                        <Setter Property="Padding" Value="6,3" />
                        <Setter Property="Margin" Value="0" />
                    </Trigger>
                    <Trigger Property="Role" Value="SubmenuHeader">
                        <Setter Property="Padding" Value="6,3,0,0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Height" Value="22" />
                        <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}" />
                        <Setter Property="FontSize" Value="{DynamicResource {x:Static SystemFonts.MessageFontSizeKey}}" />
                        <Setter Property="Foreground" Value="Black" />
                    </Trigger>
                    <Trigger Property="Role" Value="SubmenuItem">
                        <Setter Property="Padding" Value="6,3,0,0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Height" Value="22" />
                        <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}" />
                        <Setter Property="FontSize" Value="{DynamicResource {x:Static SystemFonts.MessageFontSizeKey}}" />
                        <Setter Property="Foreground" Value="Black" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="{x:Type ContextMenu}">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
            </Style>
            <Style TargetType="Image">
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor" />
            </Style>
            <Style TargetType="ListBox">
                <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True" />
                <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling" />
                <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True" />
            </Style>
            <Style TargetType="ListView">
                <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True" />
                <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling" />
                <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>